{
  "mcpServers": {
    "cella": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "-m",
        "cella.mcp_server",
        "--router",
        "--profile",
        "core"
      ],
      "env": {
        "PYTHONPATH": "src"
      }
    },
    "wreath-engine": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "tools/wreath_engine",
        "run",
        "wreath-engine-mcp"
      ]
    }
  }
}
