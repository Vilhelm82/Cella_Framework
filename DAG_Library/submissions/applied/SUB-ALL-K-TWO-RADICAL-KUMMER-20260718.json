      "claims": [
        {
          "claim_id": "ALLK-2RAD-C1",
          "statement": "For every k>=3, alpha_k=sum_r u^r e_{k-2r}(w), beta_k=sum_r u^r e_{k-1-2r}(w), and gamma_k=2(alpha_k+P) lie in the normalized mass field and satisfy alpha_k^2-u beta_k^2=P^2 and gamma_k(gamma_k-4P)=4u beta_k^2.",
          "hypotheses": [
            "characteristic zero",
            "algebraically independent generic parameters",
            "w_i^2=u+N_i^2",
            "4M=sum_i w_i",
            "P=product_i N_i"
          ],
          "scope": "canonical norm-derived second radicand for every k>=3",
          "claim_status": "proved",
          "proof_ids": [
            "DBP:paper:weighted_multiquadratic_monodromy"
          ],
          "evidence_ids": [
            "DBP:evidence:k3_k6_radicand_kill"
          ]
        },
        {
          "claim_id": "ALLK-2RAD-C2",
          "statement": "Even and odd signed contact divisors give valuation rows (1,0) and (1,1); all off-sheet entries are even, so orbit saturation makes the 2 delta_k conjugate square classes independent.",
          "hypotheses": [
            "the nonempty generic open locus excluding the explicitly listed contact, collision, discriminant and characteristic-two divisors",
            "generic base monodromy S_delta_k"
          ],
          "scope": "Kummer relation module over the splitting field",
          "claim_status": "proved",
          "proof_ids": [
            "DBP:thm:kummer_wreath_lift"
          ],
          "evidence_ids": [
            "DBP:evidence:k3_k6_radicand_kill"
          ]
        },
        {
          "claim_id": "ALLK-2RAD-C3",
          "statement": "The two-radical extension K(sqrt(u),sqrt(gamma_k)) has degree 4 over K, its normal closure has degree 2^(2 delta_k) delta_k! over F, and its Galois group is C2^2 wr S_delta_k.",
          "hypotheses": [
            "the hypotheses and generic open locus of ALLK-2RAD-C1 and ALLK-2RAD-C2",
            "delta_k=2^(k-1) for odd k and delta_k=2^(k-1)-binom(k,k/2)/2 for even k"
          ],
          "scope": "generic canonical two-channel cover for every k>=3",
          "claim_status": "proved",
          "proof_ids": [
            "DBP:paper:weighted_multiquadratic_monodromy",
            "DBP:thm:kummer_wreath_lift"
          ],
          "evidence_ids": [
            "DBP:evidence:k3_k6_radicand_kill"
          ]
        }
