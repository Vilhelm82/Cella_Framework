      "claims": [
        {
          "claim_id": "AHV1-K4-CLEAN-C1",
          "statement": "For each of a=(0,2,3,7) and a=(1,4,16,64), the exact norm has 18 distinct finite simple branch values whose explicit Hurwitz transpositions have identity ordered product and generate S5.",
          "hypotheses": [
            "w_i^2=u+a_i",
            "y=sum_i w_i",
            "the stated fixed parameter tuple"
          ],
          "scope": "two explicit k=4 instances",
          "claim_status": "machine-verified",
          "proof_ids": [],
          "evidence_ids": [
            "topological_control.json",
            "decoration_live.json"
          ]
        },
        {
          "claim_id": "AHV1-K4-CLEAN-C2",
          "statement": "The integral chain and thimble matrices give H0=Z, H1=Z^10, H2=Z, relative lattice Z^14, vanishing-cycle SNF (1,1,1,1), full integral thimble generation, and Gram SNF (1,1,1,5).",
          "hypotheses": [
            "the certified ordered Hurwitz systems"
          ],
          "scope": "both explicit k=4 instances",
          "claim_status": "machine-verified",
          "proof_ids": [],
          "evidence_ids": [
            "control_chain_matrices.json",
            "control_thimbles.json",
            "decoration_chain_matrices.json",
            "decoration_thimbles.json"
          ]
        },
        {
          "claim_id": "AHV1-K4-CLEAN-C3",
          "statement": "At N=(1,2,4,8), the canonical channels u and gamma_R9=2(P+e4(w)) have orbit-saturated parity matrix [[I5,0],[I5,I5]] of F2-rank 10, giving the static k=4 closure C2^2 wr S5 of order 122880.",
          "hypotheses": [
            "the exact even and odd contact witnesses",
            "the independently certified transitive S5 base action",
            "the Kummer Module Wreath Lift Theorem"
          ],
          "scope": "the decoration-live k=4 instance only",
          "claim_status": "proved",
          "proof_ids": [
            "DBP:thm:kummer_wreath_lift"
          ],
          "evidence_ids": [
            "decoration_kummer_parity.json"
          ]
        }
