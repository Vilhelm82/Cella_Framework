{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cella.local/schemas/dag-v1.json",
  "title": "Cella canonical research DAG",
  "type": "object",
  "required": ["schema_version", "graph_id", "revision", "direction", "authority_policy", "nodes", "edges", "extensions"],
  "properties": {
    "schema_version": {"const": 1},
    "graph_id": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.:-]{1,127}$"},
    "revision": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "direction": {"const": "from is the grammatical subject: from -relation-> to"},
    "authority_policy": {"type": "string"},
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "type", "claim_status", "lifecycle_status", "reachability", "tracked", "layer", "summary", "source_refs", "external_ids", "facets", "visual_hints", "retrieval", "extensions"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "type": {"type": "string"},
          "claim_status": {"type": ["string", "null"]},
          "lifecycle_status": {"type": ["string", "null"]},
          "reachability": {"type": ["string", "null"]},
          "tracked": {"type": "boolean"},
          "layer": {"type": "string"},
          "summary": {"type": "string"},
          "source_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["pointer", "sha256"],
              "properties": {
                "pointer": {"type": "string"},
                "sha256": {"type": ["string", "null"]}
              },
              "additionalProperties": false
            }
          },
          "external_ids": {"type": "object", "additionalProperties": {"type": "array", "items": {"type": "string"}}},
          "facets": {"type": "object"},
          "visual_hints": {"type": "object"},
          "retrieval": {
            "type": "object",
            "required": ["key_terms", "retrieval_questions", "context_priority", "context_role"],
            "properties": {
              "key_terms": {"type": "array", "items": {"type": "string"}},
              "retrieval_questions": {"type": "array", "items": {"type": "string"}},
              "context_priority": {"enum": ["low", "normal", "high", "critical"]},
              "context_role": {"enum": ["core", "supporting", "historical", "frontier"]}
            },
            "additionalProperties": false
          },
          "extensions": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "relation", "label", "basis", "source_refs", "facets", "extensions"],
        "properties": {
          "id": {"type": "string"},
          "from": {"type": "string"},
          "to": {"type": "string"},
          "relation": {"type": "string"},
          "label": {"type": ["string", "null"]},
          "basis": {"type": ["string", "null"]},
          "source_refs": {"type": "array"},
          "facets": {"type": "object"},
          "extensions": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "extensions": {"type": "object"}
  },
  "additionalProperties": false
}
