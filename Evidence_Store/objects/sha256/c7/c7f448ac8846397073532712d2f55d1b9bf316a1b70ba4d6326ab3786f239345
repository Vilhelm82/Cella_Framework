        HardenedDualArmProbe(cfg)


# === H2 — N2 same-channel with opt-in =====================================

@pytest.mark.slow
def test_h2_same_channel_with_optin_runs_but_all_records_zero_separation() -> None:
    cfg = _base_config(
        armW_channel="F4_float64",
        armN_channel="F4_float64",
        armW_route_id="sr_four_form_F4_W",
        armN_route_id="sr_four_form_F4_N",
        same_route_control=True,
        label="hardened_same_route_control",
    )
    probe = HardenedDualArmProbe(cfg)
    data = probe.run()
    # No record should resolve
    assert data["headline"]["resolved_count"] == 0
    # The zero-separation reason should dominate the breakdown for records
    # where ARM-N is active and valid (i.e., inside a core gap)
    breakdown = data["headline"]["underpromotion_breakdown"]
    # Tolerate the possibility that some records fall into armN_inactive
    # (those outside any ARM-W gap); but among unresolved records that are
    # inside an ARM-W gap, the dominant reason must be zero_path_separation.
    # The hardened_outcome reflects the most informative ceiling.
    valid_core_zero = breakdown.get("armN_zero_path_separation", 0)
    assert (
        valid_core_zero > 0
        or data["headline"]["hardened_outcome"]
        in {
            "active_handoff_gap_unresolved_zero_separation",
            "active_handoff_no_armN_activation",
            "no_active_handoff",
        }
    ), f"unexpected hardened outcome on same-route control: {data['headline']}"


# === H3 — N3 diagnostic route =============================================

@pytest.mark.slow
def test_h3_diagnostic_route_caps_outcome() -> None:
    cfg = _base_config(
        armN_route_kind="diagnostic",
        label="hardened_diagnostic_route",
    )
    probe = HardenedDualArmProbe(cfg)
    assert probe.diagnostic_route_present is True
    data = probe.run()
    assert data["diagnostic_route_present"] is True
    assert data["headline"]["hardened_outcome"] == "active_handoff_diagnostic_only"
    assert data["headline"]["resolved_count"] == 0
    # Every record must carry c3_non_diagnostic_route=False
    for rec in data["scans"]["primary"]["records"]:
        cl = rec.get("hardened_checklist", {})
        assert cl["c3_non_diagnostic_route"] is False
        assert rec["hardened_status"] != "gap_resolved"


