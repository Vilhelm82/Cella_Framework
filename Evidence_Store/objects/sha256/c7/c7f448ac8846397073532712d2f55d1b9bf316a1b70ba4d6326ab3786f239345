# === H10 — allow-list constants are frozen ===============================

def test_h10_allow_lists_are_frozensets() -> None:
    """Ensure the allow-lists are immutable so they can't be widened at
    runtime to bypass the principles."""
    assert isinstance(ALLOWED_ROUTE_KINDS, frozenset)
    assert isinstance(ALLOWED_ACTIVATION_RULES, frozenset)
    assert isinstance(ALLOWED_SELECTION_RULES, frozenset)
    with pytest.raises(AttributeError):
        ALLOWED_SELECTION_RULES.add("smallest_residual")  # type: ignore[attr-defined]
