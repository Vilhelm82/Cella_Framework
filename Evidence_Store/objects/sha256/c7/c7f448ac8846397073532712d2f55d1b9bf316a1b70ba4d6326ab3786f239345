"""
Hardened Dual-Arm Probe (V1) tests.

Preregistry: Build_Docs/Reports/hardened_dual_arm_probe/preregistry.md (FROZEN 2026-05-18).

Seven tests:
  H0  happy path     — F2 wide / F4 microscope construction + run produces a
                       hardened headline; resolved_count is recorded
                       (the empirical value is part of the closeout, not pre-tested).
  H1  N1 same-channel without opt-in  — construction AssertionError
  H2  N2 same-channel with opt-in     — runs but all valid-core records carry
                                        underpromotion_reason=armN_zero_path_separation
  H3  N3 diagnostic route             — runs but hardened_outcome capped at
                                        active_handoff_diagnostic_only
  H4  N4 target-aware selection       — construction AssertionError
  H5  N5 non-armW_falloff activation  — construction AssertionError
  H6  N6 post-construction mutation   — FrozenInstanceError
  H7  N7 armN predicate exposes ARM-W — construction AssertionError

These tests run the v11 campaign internally, so they are heavier than unit
tests. They are not in the conftest SLOW_TEST_FILES list but each test is
quick enough on its own (the v11 campaign runs in a few seconds).
"""
from __future__ import annotations

from dataclasses import FrozenInstanceError

import pytest

from scratch.hardened_dual_arm_probe import (
    DualArmConfig,
    HardenedDualArmProbe,
    ALLOWED_ROUTE_KINDS,
    ALLOWED_ACTIVATION_RULES,
    ALLOWED_SELECTION_RULES,
)


def _base_config(**overrides) -> DualArmConfig:
    base = dict(
        armW_channel="F2_float64",
        armN_channel="F4_float64",
        armW_route_id="sr_four_form_F2",
        armN_route_id="sr_four_form_F4",
        armW_route_kind="production",
        armN_route_kind="production",
        activation_rule="armW_falloff",
        selection_rule="predeclared_priority",
        same_route_control=False,
        label="hardened_test",
    )
    base.update(overrides)
    return DualArmConfig(**base)


# === H0 — Happy path =======================================================

@pytest.mark.slow
def test_h0_happy_path_f2_vs_f4_runs_and_emits_headline() -> None:
    """Happy path: F2 wide / F4 microscope hardened probe constructs and runs.

    Verifies the hardened artifact has the expected top-level structure and
    that the 6-condition checklist is stamped on each record. The actual
    resolved_count value is empirical — captured in the closeout.
    """
    probe = HardenedDualArmProbe(_base_config())
    data = probe.run()
    assert data["probe_version"] == "hardened_v1"
    assert data["config_validation"] == "passed"
    assert data["diagnostic_route_present"] is False
    assert "headline" in data
    assert "resolved_count" in data["headline"]
    assert "underpromotion_breakdown" in data["headline"]
    assert "legacy_v11_outcome" in data["headline"]
    assert "hardened_outcome" in data["headline"]
    # Every primary-scan record should carry the checklist
    primary = data["scans"]["primary"]
    assert primary.get("records"), "expected non-empty primary scan"
    for rec in primary["records"]:
        cl = rec.get("hardened_checklist")
        assert cl is not None, f"missing checklist on record at β={rec.get('beta')}"
        for key in (
            "c1_path_separation",
            "c2_own_instrument_law",
            "c3_non_diagnostic_route",
            "c4_no_target_aware_selection",
            "c5_armW_derived_activation",
            "c6_partition_guard_stable",
            "inside_armW_gap",
            "all_six_conditions",
        ):
            assert key in cl, f"missing checklist key {key}"
        # c2, c3, c4 should be True under a non-diagnostic production config
        assert cl["c2_own_instrument_law"] is True
        assert cl["c3_non_diagnostic_route"] is True
        assert cl["c4_no_target_aware_selection"] is True
    # V4 validity stamp present
    val = data["validity"]
    for field in ("defined", "finite", "observable", "selectable", "advanceable"):
        assert field in val


# === H1 — N1 same-channel without opt-in ===================================

def test_h1_same_channel_without_optin_raises() -> None:
    with pytest.raises(AssertionError, match="armW_channel == armN_channel"):
        cfg = _base_config(
            armW_channel="F4_float64",
            armN_channel="F4_float64",
            armW_route_id="sr_four_form_F4_W",
            armN_route_id="sr_four_form_F4_N",
            same_route_control=False,
        )
        HardenedDualArmProbe(cfg)


def test_h1b_same_route_id_without_optin_raises() -> None:
    with pytest.raises(AssertionError, match="armW_route_id == armN_route_id"):
        cfg = _base_config(
