# === H6 — N6 post-construction mutation raises ============================

def test_h6_post_construction_mutation_raises() -> None:
    cfg = _base_config()
    probe = HardenedDualArmProbe(cfg)
    with pytest.raises(FrozenInstanceError):
        probe.config.activation_rule = "independent"  # type: ignore[misc]
    with pytest.raises(FrozenInstanceError):
        probe.config.armN_channel = "F1_float64"  # type: ignore[misc]


# === H7 — N7 ARM-N predicate exposes ARM-W field raises ==================

def test_h7_armN_predicate_with_arm_w_param_raises() -> None:
    def bad_predicate(enough_points, instrument, arm_w_verdict):
        return bool(enough_points and arm_w_verdict)

    with pytest.raises(AssertionError, match="arm_w_verdict|own instrument law"):
        HardenedDualArmProbe(
            _base_config(), armN_validity_predicate=bad_predicate
        )


def test_h7b_armN_predicate_with_armW_param_raises() -> None:
    def bad_predicate(enough_points, instrument, armW_inference):
        return bool(enough_points and armW_inference)

    with pytest.raises(AssertionError, match="armW_inference|own instrument law"):
        HardenedDualArmProbe(
            _base_config(), armN_validity_predicate=bad_predicate
        )


