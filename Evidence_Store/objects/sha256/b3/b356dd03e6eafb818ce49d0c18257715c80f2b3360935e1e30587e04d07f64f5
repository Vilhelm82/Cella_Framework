def slot_08_family_tangent_signature_norm(fixture: str, variant: str) -> Slot:
    name = "slot_08_family_tangent_signature_norm"
    entry = _lifted_entry(fixture)
    if entry is None:
        return _na_slot(name)
    tangent = entry.get("family_tangent")
    if tangent is None:
        return _unobs_slot(name)
    try:
        components = [float(c) for c in tangent]
    except (TypeError, ValueError):
        return _failed_slot(name, "family_tangent not iterable of floats")
    norm = math.sqrt(sum(c * c for c in components))
    return _defined_slot(name, round(norm, 6), bits=32)


