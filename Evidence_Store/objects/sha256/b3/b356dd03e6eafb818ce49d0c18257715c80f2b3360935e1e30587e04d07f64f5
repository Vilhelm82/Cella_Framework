def compute_fingerprint_beta(fixture: str, variant: str = "A") -> dict:
    slots: list[Slot] = []
    for fn in SLOT_FUNCTIONS_PHASE_BETA:
        try:
            slot = fn(fixture, variant)
        except Exception as exc:  # noqa: BLE001
            slot = _failed_slot(fn.__name__, str(exc))
        slots.append(slot)
    total_bits = sum(s.bits for s in slots)
    defined_count = sum(1 for s in slots if s.status == "defined")
    return {
        "fixture": fixture,
        "variant": variant,
        "fingerprint": {
            s.name: {"value": s.value, "status": s.status} for s in slots
        },
        "compactness": {
            "total_bits": int(total_bits),
            "budget_bits": 256,
            "in_budget": bool(total_bits <= 256),
        },
        "validity": {
            "defined": defined_count > 0,
            "finite": all(_slot_finite(s) for s in slots if s.status == "defined"),
            "observable": any(s.status == "defined" for s in slots),
            "selectable": True,
            "advanceable": True,
        },
    }


def distinguishability_matrix(
    fingerprints: list[dict],
) -> tuple[list[list[int]], list[str]]:
    n = len(fingerprints)
    names = [fp["fixture"] for fp in fingerprints]
    matrix = [[0] * n for _ in range(n)]
    for i in range(n):
        for j in range(n):
            if i == j:
                continue
            disagreements = 0
            fp_i = fingerprints[i]["fingerprint"]
            fp_j = fingerprints[j]["fingerprint"]
            for slot_name, s_i in fp_i.items():
                s_j = fp_j[slot_name]
                if s_i["status"] != "defined" or s_j["status"] != "defined":
                    continue
                if _values_equal(s_i["value"], s_j["value"]):
                    continue
                disagreements += 1
            matrix[i][j] = disagreements
    return matrix, names


def slot_level_route_invariance(
    variant_a_fps: list[dict], variant_b_fps: list[dict]
) -> dict:
    """For each slot, count how many fixtures show route invariance."""
    slot_names = list(variant_a_fps[0]["fingerprint"].keys())
    per_slot: dict[str, dict] = {}
    for slot_name in slot_names:
        invariant_fixtures = []
        variant_fixtures = []
        na_fixtures = []
        for fp_a, fp_b in zip(variant_a_fps, variant_b_fps):
            s_a = fp_a["fingerprint"][slot_name]
            s_b = fp_b["fingerprint"][slot_name]
            if s_a["status"] != "defined" or s_b["status"] != "defined":
                na_fixtures.append(fp_a["fixture"])
                continue
            if _values_equal(s_a["value"], s_b["value"]):
                invariant_fixtures.append(fp_a["fixture"])
            else:
                variant_fixtures.append(fp_a["fixture"])
        per_slot[slot_name] = {
            "invariant_count": len(invariant_fixtures),
            "varies_count": len(variant_fixtures),
            "na_count": len(na_fixtures),
            "varies_in_fixtures": variant_fixtures,
        }
    return per_slot


def minimum_distinguishing_subset(
    fingerprints: list[dict],
) -> tuple[list[str], int]:
    n = len(fingerprints)
    if n < 2:
        return [], 0
    slot_names = list(fingerprints[0]["fingerprint"].keys())
    pair_disagreements: dict[tuple[int, int], set[str]] = {}
    for i in range(n):
        for j in range(i + 1, n):
            fp_i = fingerprints[i]["fingerprint"]
            fp_j = fingerprints[j]["fingerprint"]
            slots = set()
            for sn in slot_names:
                s_i = fp_i[sn]
                s_j = fp_j[sn]
                if s_i["status"] != "defined" or s_j["status"] != "defined":
                    continue
                if not _values_equal(s_i["value"], s_j["value"]):
                    slots.add(sn)
            pair_disagreements[(i, j)] = slots
    uncovered = set(k for k, v in pair_disagreements.items() if v)
    chosen: list[str] = []
    while uncovered:
        scores = {
            sn: sum(1 for pair in uncovered if sn in pair_disagreements[pair])
            for sn in slot_names
            if sn not in chosen
        }
        if not scores or max(scores.values()) == 0:
            break
        best = max(scores, key=lambda s: scores[s])
        chosen.append(best)
        uncovered = {p for p in uncovered if best not in pair_disagreements[p]}
    indist = [k for k, v in pair_disagreements.items() if not v]
    return chosen, len(indist)


def evaluate_phase_beta_predictions(
    fingerprints: list[dict],
    matrix: list[list[int]],
    slot_route_inv: dict,
    min_subset: list[str],
) -> dict[str, Any]:
    names = [fp["fixture"] for fp in fingerprints]
    n = len(names)

    # P_β1: ≥ 12 of 15 pairs distinguishable + 6 cross-family pairs distinguishable
    pair_count = 0
    distinguishable = 0
    cross_family_pairs = [
        ("SR", "Morris_Thorne"), ("SR", "Kerr_ISCO_a09"),
        ("pure_algebraic", "Morris_Thorne"), ("pure_algebraic", "Kerr_ISCO_a09"),
        ("cube_root", "Morris_Thorne"), ("cube_root", "Kerr_ISCO_a09"),
    ]
    cross_distinguishable = 0
    for i in range(n):
        for j in range(i + 1, n):
            pair_count += 1
            if matrix[i][j] >= 1:
                distinguishable += 1
            pair = (names[i], names[j])
            if pair in cross_family_pairs or pair[::-1] in cross_family_pairs:
                if matrix[i][j] >= 1:
                    cross_distinguishable += 1
    p_beta_1 = distinguishable >= 12
    p_beta_1_cross = cross_distinguishable == 6

    # P_β2: lifted-singularity within-class aliasing breaks
    lift_names = ("Schwarzschild", "Morris_Thorne", "Kerr_ISCO_a09")
    lift_pairs_distinguishable = []
    for i, a in enumerate(lift_names):
        for b in lift_names[i + 1:]:
            if a not in names or b not in names:
                continue
            ai = names.index(a)
            bi = names.index(b)
            lift_pairs_distinguishable.append((a, b, matrix[ai][bi]))
    p_beta_2 = all(disagreements >= 1 for _, _, disagreements in lift_pairs_distinguishable)

    # P_β3: slot 15 produces nonzero variation for ≥ 4 of 6 fixtures
    slot_15 = slot_route_inv.get("slot_15_route_variation_signature", {})
    nonzero_count = 0
    for fp in fingerprints:
        s = fp["fingerprint"].get("slot_15_route_variation_signature", {})
        if s.get("status") == "defined" and s.get("value", 0.0) != 0.0:
            nonzero_count += 1
    p_beta_3 = nonzero_count >= 4

    # P_β4: ≥ 5 of 6 in compactness budget
    in_budget = sum(1 for fp in fingerprints if fp["compactness"]["in_budget"])
    p_beta_4 = in_budget >= 5

    # P_β5: minimum distinguishing subset includes ≥ 1 universal slot
    universal = {
        "slot_13_critical_point_curvature_magnitude_log10",
        "slot_14_critical_point_conditioning_index_log10",
    }
    p_beta_5 = bool(set(min_subset) & universal)

    # P_β6: slot taxonomy verified empirically
    # Class-confirming slots should have invariant_count == applicable_count
    # Cross-family slots should be defined for every fixture
    # Route-sensitive slot 15 should be `varies_count >= 1`
    universal_defined_everywhere = all(
        fp["fingerprint"][slot]["status"] == "defined"
        for fp in fingerprints
        for slot in universal
    )
    route_sensitive_varies = slot_15.get("varies_count", 0) >= 1
    p_beta_6 = universal_defined_everywhere  # tightened condition

    return {
        "P_beta_1_distinguishable_geq_12_of_15": bool(p_beta_1),
        "P_beta_1_all_6_cross_family_pairs_distinguishable": bool(p_beta_1_cross),
        "P_beta_2_lifted_within_class_aliasing_breaks": bool(p_beta_2),
        "P_beta_3_slot_15_nonzero_in_geq_4_fixtures": bool(p_beta_3),
        "P_beta_4_compactness_geq_5_of_6": bool(p_beta_4),
        "P_beta_5_min_subset_includes_universal_slot": bool(p_beta_5),
        "P_beta_6_universal_slots_defined_everywhere": bool(p_beta_6),
        "diag_distinguishable_pairs": distinguishable,
        "diag_cross_family_distinguishable_pairs": cross_distinguishable,
        "diag_lift_within_class_pairs": [
            {"a": a, "b": b, "disagreements": d}
            for a, b, d in lift_pairs_distinguishable
        ],
        "diag_slot_15_nonzero_fixture_count": nonzero_count,
        "diag_in_budget_fixture_count": in_budget,
    }


def identify_failure_modes_beta(
    fingerprints: list[dict],
    matrix: list[list[int]],
    slot_route_inv: dict,
) -> list[str]:
    failures = []
    n = len(fingerprints)
    all_identical = all(
        matrix[i][j] == 0 for i in range(n) for j in range(n) if i != j
    )
    if all_identical:
        failures.append("F1")
    has_alias = any(
        matrix[i][j] == 0 for i in range(n) for j in range(n) if i != j
    )
    if has_alias and not all_identical:
        failures.append("F2")
    # F3' — route invariance < 80% on a slot that should be invariant
    structurally_invariant_slots = [
        s
        for s in fingerprints[0]["fingerprint"].keys()
        if s != "slot_15_route_variation_signature"
    ]
    for slot in structurally_invariant_slots:
        slot_data = slot_route_inv.get(slot, {})
        if slot_data.get("varies_count", 0) > 0:
            failures.append(f"F3'_{slot}")
    # F4
    high_unobs = sum(
        1
        for fp in fingerprints
        if (
            sum(1 for s in fp["fingerprint"].values() if s["status"] == "unobservable")
            / len(fp["fingerprint"])
            >= 0.50
        )
    )
    if high_unobs >= 3:
        failures.append("F4")
    if all(not fp["compactness"]["in_budget"] for fp in fingerprints):
        failures.append("F5")
    return failures


def derive_verdict_beta(predictions: dict, failures: list[str]) -> str:
    # F1/F2 are hard failures
    if any(f in failures for f in ("F1", "F2")):
        return "barcode_hypothesis_not_supported_at_phase_beta"
    # If everything passes
    pred_keys = [k for k in predictions if k.startswith("P_beta_") and not k.startswith("P_beta_1_all")]
    if all(predictions[k] for k in pred_keys):
        return "barcode_hypothesis_supported_at_phase_beta"
    if predictions["P_beta_1_distinguishable_geq_12_of_15"]:
        return "barcode_hypothesis_supported_with_remaining_aliasing"
    return "barcode_hypothesis_supported_with_caveats"


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------


def run_atlas_beta() -> dict:
    fingerprints_A = [compute_fingerprint_beta(f, "A") for f in PHASE_ALPHA_FIXTURES]
    fingerprints_B = [compute_fingerprint_beta(f, "B") for f in PHASE_ALPHA_FIXTURES]
    matrix, names = distinguishability_matrix(fingerprints_A)
    slot_route_inv = slot_level_route_invariance(fingerprints_A, fingerprints_B)
    min_subset, indist = minimum_distinguishing_subset(fingerprints_A)
    failures = identify_failure_modes_beta(fingerprints_A, matrix, slot_route_inv)
    predictions = evaluate_phase_beta_predictions(
        fingerprints_A, matrix, slot_route_inv, min_subset
    )
    verdict = derive_verdict_beta(predictions, failures)

    return {
        "atlas_version": "phase_beta_v1",
        "fixtures": list(PHASE_ALPHA_FIXTURES),
        "variants_per_fixture": ["A", "B"],
        "fingerprints_variant_A": fingerprints_A,
        "fingerprints_variant_B": fingerprints_B,
        "distinguishability_matrix": matrix,
        "distinguishability_matrix_row_labels": names,
        "indistinguishable_pair_count": indist,
        "slot_level_route_invariance": slot_route_inv,
        "minimum_distinguishing_subset": min_subset,
        "predictions": predictions,
        "failure_modes_observed": failures,
        "verdict": verdict,
    }


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--output", default=str(ARTIFACT))
    args = parser.parse_args()
    REPORT_DIR.mkdir(parents=True, exist_ok=True)
    data = run_atlas_beta()
    Path(args.output).write_text(json.dumps(data, indent=2, sort_keys=True))
    print(f"atlas-β artifact written to {args.output}")
    print(f"  verdict: {data['verdict']}")
    print(f"  failure_modes_observed: {data['failure_modes_observed']}")
    print(f"  predictions:")
    for k, v in data["predictions"].items():
        if isinstance(v, bool):
            marker = "✓" if v else "✗"
            print(f"    {marker} {k}")
    print(f"  diagnostics:")
    for k, v in data["predictions"].items():
        if k.startswith("diag_"):
            print(f"    {k}: {v}")
    print(f"  minimum_distinguishing_subset: {data['minimum_distinguishing_subset']}")
    print(f"  indistinguishable_pair_count: {data['indistinguishable_pair_count']}")
    print(f"  distinguishability_matrix:")
    labels = data["distinguishability_matrix_row_labels"]
    print("    " + " ".join(f"{n[:6]:>7}" for n in labels))
    for i, row in enumerate(data["distinguishability_matrix"]):
        print(f"    {labels[i][:6]:>6} " + " ".join(f"{c:>7}" for c in row))


if __name__ == "__main__":
    main()
