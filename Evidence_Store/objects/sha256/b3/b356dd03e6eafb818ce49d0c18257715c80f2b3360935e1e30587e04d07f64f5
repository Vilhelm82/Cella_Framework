# Critical-β per fixture.
#
# For four-form fixtures: chosen *inside* the singularity-approach region
# (above the Sterbenz boundary), so that residuals are nonzero and the
# arithmetic chains have room to differ between routings. Evaluating at
# the Sterbenz boundary exactly produces all-ULP-scale residuals which
# collapse slots 13–15 numerically.
#
# Specific choices, fixed pre-measurement:
#   SR        : β = 0.85   (Sterbenz boundary 1/√2 ≈ 0.707; singularity at β=1)
#   Schw      : r = 5      (Sterbenz boundary r=4; ISCO at r=6)
#   pure_alg  : x = 0.7    (Sterbenz boundary x=0.5; singularity at x=1)
#   cube_root : x = 0.7    (same)
# These are "interior probe points" in the deep-binade-loss region.
CRITICAL_BETA: dict[str, float | None] = {
    "SR": 0.85,
    "Schwarzschild": 5.0,
    "pure_algebraic": 0.7,
    "cube_root": 0.7,
    "Morris_Thorne": None,           # critical point is multi-dim, no β scalar
    "Kerr_ISCO_a09": None,
}


def _ulp(x: float) -> float:
    """ULP via the ``typed_ulp`` substrate primitive (GAP-003, precision='float64').

    Migrated from inline IEEE 754 ULP helper as part of the DRY-003 substrate
    consolidation. Byte-compatible with the original on finite normal inputs.
    """
    return float(typed_ulp(x, precision="float64").value.ulp)


def _four_form_at(fixture: str, var: float) -> dict[str, float] | None:
    if fixture == "SR":
        return sr_four_form(var)
    if fixture == "pure_algebraic":
        return pa_four_form(var)
    if fixture == "cube_root":
        return cbrt_four_form(var)
    if fixture == "Schwarzschild":
        return {
            "F1": F1_of_r(var),
            "F2": F2_of_r(var),
            "F3": F3_of_r(var),
            "F4": F4_of_r(var),
        }
    return None


