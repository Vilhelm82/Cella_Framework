def _route_a_four_form_residual(fixture: str, var: float) -> float | None:
    """Variant A: canonical c1 = ((R^n) - 1) + (x_term) at the critical var.

    For four-form fixtures, this is conceptually F2 with the routing that
    produces the c1 lattice character per Test A.
    """
    if fixture == "SR":
        # SR: c1 = (eta^2 - 1) + beta^2 with eta = sqrt(1 - beta^2)
        eta = (1.0 - var * var) ** 0.5
        return (eta * eta - 1.0) + (var * var)
    if fixture == "pure_algebraic":
        # f = 1 - x; R = sqrt(f); c1 = (R^2 - 1) + x
        f = 1.0 - var
        R = f ** 0.5
        return (R * R - 1.0) + var
    if fixture == "cube_root":
        # f = 1 - x; R = cbrt(f); c1 = (R^3 - 1) + x
        f = 1.0 - var
        R = f ** (1.0 / 3.0)
        return (R * R * R - 1.0) + var
    if fixture == "Schwarzschild":
        # f = 1 - 2/r; R = sqrt(f); c1 = (R^2 - 1) + 2/r
        f = 1.0 - 2.0 / var
        R = f ** 0.5
        return (R * R - 1.0) + (2.0 / var)
    return None


def _route_b_four_form_residual(fixture: str, var: float) -> float | None:
    """Variant B: route-permuted c2 = (R^n) + (x_term - 1) at the critical var."""
    if fixture == "SR":
        eta = (1.0 - var * var) ** 0.5
        return (eta * eta) + (var * var - 1.0)
    if fixture == "pure_algebraic":
        f = 1.0 - var
        R = f ** 0.5
        return (R * R) + (var - 1.0)
    if fixture == "cube_root":
        f = 1.0 - var
        R = f ** (1.0 / 3.0)
        return (R * R * R) + (var - 1.0)
    if fixture == "Schwarzschild":
        f = 1.0 - 2.0 / var
        R = f ** 0.5
        return (R * R) + (2.0 / var - 1.0)
    return None


def slot_15_route_variation_signature(fixture: str, variant: str) -> Slot:
    name = "slot_15_route_variation_signature"
    critical_var = CRITICAL_BETA.get(fixture)
    if critical_var is not None:
        # Four-form fixtures: |c1 - c2| / ulp(reference) at critical β
        a = _route_a_four_form_residual(fixture, critical_var)
        b = _route_b_four_form_residual(fixture, critical_var)
        if a is None or b is None:
            return _failed_slot(name, "no route-permuted residual")
        # Reference for ulp: f at the critical var (the "1 - x" form)
        if fixture == "SR":
            f = 1.0 - critical_var * critical_var
        elif fixture in {"pure_algebraic", "cube_root"}:
            f = 1.0 - critical_var
        elif fixture == "Schwarzschild":
            f = 1.0 - 2.0 / critical_var
        else:
            f = 1.0
        delta_ulp = abs(a - b) / _ulp(f)
        # Variant A=A returns delta_ulp; Variant B=A is undefined since
        # this slot is by design route-sensitive — Variant A and Variant B
        # of the slot are *the same* outcome on this slot, because the
        # slot computes both orderings internally and returns their
        # comparison. Document this in the closeout.
        return _defined_slot(name, round(delta_ulp, 3), bits=32)
    # Lifted-singularity fixtures: F_joint at critical point in two
    # summation orders
    entry = _lifted_entry(fixture)
    if entry is None:
        return _na_slot(name)
    eigs = entry.get("hessian_eigenvalues_ascending")
    if eigs is None:
        return _unobs_slot(name)
    # At the critical point, F_joint = 0 mathematically. The route
    # variation in the assembly ΣFᵢ² is bounded by the eigenvalue scale.
    # Use a proxy: the float64 value of F_joint at the critical point as
    # reported by the audit (if available).
    f_joint = entry.get("F_joint")
    if f_joint is None:
        return _unobs_slot(name)
    # We don't have two assembly orders in the audit artifact; emit the
    # absolute value of F_joint as the route-variation proxy.
    max_eig_mag = max(abs(float(e)) for e in eigs) if eigs else 1.0
    if max_eig_mag == 0.0:
        max_eig_mag = 1.0
    delta_ulp = abs(float(f_joint)) / _ulp(max_eig_mag)
    return _defined_slot(name, round(delta_ulp, 3), bits=32)


