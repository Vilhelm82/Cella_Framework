def slot_09_pair_jacobian_log10_spread(fixture: str, variant: str) -> Slot:
    name = "slot_09_pair_jacobian_log10_spread"
    entry = _lifted_entry(fixture)
    if entry is None:
        return _na_slot(name)
    svals = entry.get("constraint_jacobian_svals")
    if svals is None or len(svals) < 2:
        return _unobs_slot(name)
    try:
        sv = sorted(abs(float(s)) for s in svals if float(s) != 0.0)
    except (TypeError, ValueError):
        return _failed_slot(name, "svals not iterable of floats")
    if not sv or sv[0] == 0.0:
        return _unobs_slot(name)
    spread = math.log10(sv[-1] / sv[0])
    return _defined_slot(name, round(spread, 6), bits=32)


