def slot_13_critical_point_curvature_magnitude(fixture: str, variant: str) -> Slot:
    name = "slot_13_critical_point_curvature_magnitude_log10"
    # Four-form fixtures: max |F_i(critical_var)|
    critical_var = CRITICAL_BETA.get(fixture)
    if critical_var is not None:
        forms = _four_form_at(fixture, critical_var)
        if forms is None:
            return _failed_slot(name, "no four-form computation for fixture")
        magnitudes = [abs(v) for v in forms.values()]
        max_mag = max(magnitudes) if magnitudes else 0.0
        if max_mag == 0.0:
            # All F_i exactly zero — emit smallest possible log10
            return _defined_slot(name, round(math.log10(_ulp(1.0)), 6), bits=32)
        return _defined_slot(name, round(math.log10(max_mag), 6), bits=32)
    # Lifted-singularity fixtures: max |Hessian eigenvalue|
    entry = _lifted_entry(fixture)
    if entry is None:
        return _na_slot(name)
    eigs = entry.get("hessian_eigenvalues_ascending")
    if eigs is None:
        return _unobs_slot(name)
    try:
        magnitudes = [abs(float(e)) for e in eigs]
    except (TypeError, ValueError):
        return _failed_slot(name, "eigenvalues not iterable of floats")
    max_mag = max(magnitudes) if magnitudes else 0.0
    if max_mag == 0.0:
        return _unobs_slot(name)
    return _defined_slot(name, round(math.log10(max_mag), 6), bits=32)


