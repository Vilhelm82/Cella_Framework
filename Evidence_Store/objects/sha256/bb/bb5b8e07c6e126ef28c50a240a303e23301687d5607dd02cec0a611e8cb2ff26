{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cella.cce.dbp_native.schema_1_1.released_six.v1",
  "title": "PF-0 confirmed DBP native request domain",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "adapter_id",
    "adapter_version",
    "target",
    "requested_bits",
    "family_manifest_digest",
    "exact_path_digest",
    "selected_state_digest",
    "coefficient_ring",
    "proof_budget"
  ],
  "properties": {
    "request_id": {"type": "string", "minLength": 1},
    "adapter_id": {"const": "cella.continuation.adapters.dbp_native_v1"},
    "adapter_version": {"const": "1.1"},
    "target": {"enum": ["primary", "dual_cpv"]},
    "requested_bits": {"enum": [192, 256, 384]},
    "family_manifest_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "exact_path_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "selected_state_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "coefficient_ring": {"enum": ["Z", "Z[1/2,i]"]},
    "proof_budget": {
      "type": "object",
      "required": ["max_steps", "max_recurrence_order", "max_work_bits"],
      "properties": {
        "max_steps": {"type": "integer", "minimum": 1},
        "max_recurrence_order": {"type": "integer", "minimum": 1},
        "max_work_bits": {"type": "integer", "minimum": 1}
      }
    }
  },
  "cross_field_constraints": [
    "primary requires its locked exact path and selected-state digests and coefficient ring Z",
    "dual_cpv requires its locked exact path and selected-state digests and coefficient ring Z[1/2,i]",
    "only the Cartesian product of the two targets and three released precisions is admitted"
  ]
}
