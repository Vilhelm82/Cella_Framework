import numpy as np
from lloyd_v4.primitives import typed_ulp


ROOT = Path(__file__).resolve().parents[1]
REPORT_DIR = ROOT / "Build_Docs" / "Reports" / "c2_lattice_substrate_derivation"
ARTIFACT = REPORT_DIR / "artifact.json"


# Dense grid size for the Sterbenz-region sweep
GRID_DENSITY = 5000


def _ulp(x: float) -> float:
    """ULP via the ``typed_ulp`` substrate primitive (GAP-003, precision='float64').

    Migrated from inline IEEE 754 ULP helper as part of the DRY-003 substrate
    consolidation. Byte-compatible with the original on finite normal inputs.
    """
    return float(typed_ulp(x, precision="float64").value.ulp)


# ---------------------------------------------------------------------------
# Fixture-specific c1/c2 computations
# ---------------------------------------------------------------------------


def _sr_c2(beta: float) -> tuple[float, float]:
    """For SR: f = 1 - β². x_term = β². c2 = R² + (β² - 1) where R = sqrt(f).
    Returns (c2, ulp(f))."""
    x_term = beta * beta
    f = 1.0 - x_term
    R = f ** 0.5
    V = R * R
    c2 = V + (x_term - 1.0)
    return c2, _ulp(f)


def _schwarzschild_c2(r: float) -> tuple[float, float]:
    """Schwarzschild: f = 1 - 2/r. x_term = 2/r. c2 = R² + (2/r - 1).
    R = sqrt(f). Returns (c2, ulp(f))."""
    x_term = 2.0 / r
    f = 1.0 - x_term
    R = f ** 0.5
    V = R * R
    c2 = V + (x_term - 1.0)
    return c2, _ulp(f)


def _pure_algebraic_c2(x: float) -> tuple[float, float]:
    """Pure algebraic: f = 1 - x. x_term = x. c2 = R² + (x - 1)."""
    f = 1.0 - x
    R = f ** 0.5
    V = R * R
    c2 = V + (x - 1.0)
    return c2, _ulp(f)


def _cube_root_c2_pow(x: float) -> tuple[float, float]:
    """Cube root via pow(f, 1/3) route.
    f = 1 - x. x_term = x. R = f**(1/3). c2 = R³ + (x - 1).
    R³ computed as (R · R) · R in float64.

    `f ** (1.0/3.0)` is computed via `exp(log(f) / 3)` in CPython's pow,
    typically giving error within ~1 ulp (transcendental-route).
    """
    f = 1.0 - x
    R = f ** (1.0 / 3.0)
    R2 = R * R
    V = R2 * R
    c2 = V + (x - 1.0)
    return c2, _ulp(f)


def _cube_root_c2_npcbrt(x: float) -> tuple[float, float]:
    """Cube root via numpy.cbrt route — Test A's implementation.
    `np.cbrt` is a dedicated cbrt that may be correctly rounded or
    within-1-ulp depending on libm. Test A uses this; we mirror.
    """
    f = 1.0 - x
    R = float(np.cbrt(f))
    R2 = R * R
    V = R2 * R
    c2 = V + (x - 1.0)
    return c2, _ulp(f)


# Backwards-compat alias — primary cube-root fixture uses np.cbrt (matches Test A)
def _cube_root_c2(x: float) -> tuple[float, float]:
    return _cube_root_c2_npcbrt(x)


# Fixture definitions
FIXTURES = {
