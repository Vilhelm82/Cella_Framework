def _next_after(v: float, direction: float) -> float:
    return math.nextafter(v, direction)


def analyze_fixture(name: str, fn: Callable, grid: List[float]) -> Dict:
    p = fn(grid[0])["p"]
    max_cancel_resid = 0.0
    max_pert_change = 0.0
    f4_operand_diff_count = 0
    f4_operand_equal_count = 0
    f3_max_abs = 0.0
    rows = []

    for coord in grid:
        d = fn(coord)
        R = d["R"]
        f_direct = d["f_direct"]
        x_term = d["x_term"]
        f_alt = d["f_alt"]
        F1, F2, F3, F4 = d["F1"], d["F2"], d["F3"], d["F4"]

        closed = (1.0 - x_term) - f_direct
        observed = F1 - F2
        cancel_resid = abs(observed - closed)
        max_cancel_resid = max(max_cancel_resid, cancel_resid)

        for direction in (math.inf, -math.inf):
            R_pert = _next_after(R, direction)
            if p == 2:
                Rp = R_pert * R_pert
            else:
                Rp = R_pert * R_pert * R_pert
            F1_pert = Rp - f_direct
            F2_pert = Rp - 1.0 + x_term
            pert_diff = (F1_pert - F2_pert)
            max_pert_change = max(max_pert_change, abs(pert_diff - observed))

        if f_alt != f_direct:
            f4_operand_diff_count += 1
        else:
            f4_operand_equal_count += 1

        f3_max_abs = max(f3_max_abs, abs(F3))

        rows.append(dict(
            coord=coord,
            F1_minus_F2=observed,
            closed_form=closed,
            cancel_resid=cancel_resid,
        ))

    n = len(grid)
    return dict(
        fixture=name,
        p=p,
        n_points=n,
        retrodiction_F3_max_abs=f3_max_abs,
        retrodiction_F3_all_zero=(f3_max_abs == 0.0),
        closed_form="(1 - x_term) - f_direct",
        max_cancel_residual=max_cancel_resid,
        max_F1F2_change_under_1ulp_R_perturb=max_pert_change,
        f4_operand_differs_count=f4_operand_diff_count,
        f4_operand_equal_count=f4_operand_equal_count,
        e_F1F2_common_mode_count=n,  # by construction in this reconstruction
    )


def main() -> None:
    results = {}
    for name, (fn, grid) in FIXTURES.items():
        results[name] = analyze_fixture(name, fn, grid)

    # Write compact retrodiction evidence (no per-point dump for size)
    compact = {}
    for name, r in results.items():
        compact[name] = {k: v for k, v in r.items() if k not in ("rows",)}

    out_path = OUT_DIR / "retrodiction.json"
    out_path.write_text(json.dumps(compact, indent=2, default=str))

    print("=== RETRODICTION GATE RESULTS ===")
    all_pass = True
    for name, r in results.items():
        target = KNOWN_TARGETS.get(name, {})
        max_resid = r["max_cancel_residual"]
        max_pert = r["max_F1F2_change_under_1ulp_R_perturb"]
        f4_diff = r["f4_operand_differs_count"]
        f4_eq = r["f4_operand_equal_count"]

        t_max_resid = target.get("max_cancel_residual")
        t_max_pert = target.get("max_F1F2_change_under_1ulp_R_perturb")
        t_f4_diff = target.get("f4_operand_differs_count")
        t_f4_eq = target.get("f4_operand_equal_count")

        resid_ok = (t_max_resid is None) or math.isclose(max_resid, t_max_resid, rel_tol=0, abs_tol=1e-20)
        pert_ok = (t_max_pert is None) or math.isclose(max_pert, t_max_pert, rel_tol=0, abs_tol=1e-20)
        f4_ok = (t_f4_diff is None) or (f4_diff == t_f4_diff and f4_eq == t_f4_eq)

        status = "PASS" if (resid_ok and pert_ok and f4_ok) else "FAIL"
        if status == "FAIL":
            all_pass = False

        print(f"\n{name}: {status}")
        print(f"  max_cancel_residual: {max_resid:.6e}  (target {t_max_resid})  {'OK' if resid_ok else 'MISMATCH'}")
        print(f"  max_pert_change:     {max_pert:.6e}  (target {t_max_pert})  {'OK' if pert_ok else 'MISMATCH'}")
        print(f"  F4 differs/equal:    {f4_diff}/{f4_eq}  (target {t_f4_diff}/{t_f4_eq})  {'OK' if f4_ok else 'MISMATCH'}")
        print(f"  F3 max abs:          {r['retrodiction_F3_max_abs']:.3e}  (all zero: {r['retrodiction_F3_all_zero']})")

    print("\n=== OVERALL RETRODICTION GATE ===")
    if all_pass:
        print("PASSED — byte-stable reproduction of Retest C summary statistics achieved.")
        print(f"Evidence written to: {out_path}")
    else:
        print("FAILED — do not proceed to dense Sterbenz work.")
        raise SystemExit(1)


if __name__ == "__main__":
    main()