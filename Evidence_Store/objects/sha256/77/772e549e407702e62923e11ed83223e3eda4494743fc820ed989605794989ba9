# --- Schwarzschild ISCO (k=2 constraints in n=3 vars: r, Q, M; X is lift) ---
# F_orbit = M r^2 - Q r + 3 M Q
# F_stab  = -2 M r^2 + 3 Q r - 12 M Q
# At ISCO: r = 6M, Q = 12 M^2  (solving F_orbit = F_stab = 0 with M=1)
def schwarzschild_isco_spec() -> FixtureSpec:
    M_val = 1.0
    r_isco = 6.0 * M_val
    Q_isco = 12.0 * M_val * M_val
    return FixtureSpec(
        name="schwarzschild_isco",
        n_phys=3,
        K_constraints=2,
        var_labels=("r", "Q", "M"),
        critical_point=(r_isco, Q_isco, M_val),
        constraint_funcs=(
            lambda r, Q, M: M * r * r - Q * r + 3.0 * M * Q,
            lambda r, Q, M: -2.0 * M * r * r + 3.0 * Q * r - 12.0 * M * Q,
        ),
        # Family tangent: ISCO family scales r ~ M, Q ~ M^2 — tangent (6, 24, 1, 0) at M=1
        family_tangent=(6.0, 24.0, 1.0, 0.0),
        notes="V3 reference: metric_tensor_joint_singularity_audit.py; r=6M, Q=12M^2",
    )


# --- Schwarzschild photon sphere (k=2 in n=3 vars: r, B, M; X is lift) ---
# F_orbit = B*(r - 2M) - r^3
# F_ext = B*r - 3*r^3
# At photon sphere: r = 3M, B = 27M^2
def schwarzschild_photon_spec() -> FixtureSpec:
    M_val = 1.0
    r_ps = 3.0 * M_val
    B_ps = 27.0 * M_val * M_val
    return FixtureSpec(
        name="schwarzschild_photon",
        n_phys=3,
        K_constraints=2,
        var_labels=("r", "B", "M"),
        critical_point=(r_ps, B_ps, M_val),
        constraint_funcs=(
            lambda r, B, M: B * (r - 2.0 * M) - r ** 3,
            lambda r, B, M: B * r - 3.0 * r ** 3,
        ),
        # Photon sphere family: r ~ M, B ~ M^2; tangent (3, 54, 1, 0) at M=1
        family_tangent=(3.0, 54.0, 1.0, 0.0),
        notes="V3 reference: photon_sphere_joint_probe_nvar.py; r=3M, B=27M^2",
    )


# --- Morris-Thorne wormhole throat (k=2 in n=3 vars: r, a, kappa; X lift) ---
# F_throat = a^2 / r - r
# F_flare = r / a^2 - kappa
# At throat: r = a, kappa = 1/a   (with a0 = 1 -> r=1, kappa=1)
def morris_thorne_spec() -> FixtureSpec:
    a0 = 1.0
    r_th = a0
    kap0 = 1.0 / a0
    return FixtureSpec(
        name="morris_thorne_throat",
        n_phys=3,
        K_constraints=2,
        var_labels=("r", "a", "kappa"),
        critical_point=(r_th, a0, kap0),
        constraint_funcs=(
            lambda r, a, k: (a * a) / r - r,
            lambda r, a, k: r / (a * a) - k,
        ),
        # Throat family: r=a, kappa=1/a; tangent in (r, a, kappa) is (1, 1, -1/a^2) = (1, 1, -1)
        # at a=1; lifted: (1, 1, -1, 0)
        family_tangent=(1.0, 1.0, -1.0, 0.0),
        notes="V3 reference: morris_thorne_throat_joint_probe.py; Ellis/MT b(r)=a^2/r",
    )


# --- Kerr 5D ISCO (K=3 in n=4 vars: r, E, x, a; X lift) ---
# Native Kerr equatorial timelike radial potential at fixed (E, x, a):
#   R(r, E, x, a) = (E r^2 - a x)^2 - Δ (r^2 + x^2)
# ISCO defined by three simultaneous conditions:
#   F0 = R = 0                (circular orbit)
#   F1 = dR/dr = 0            (radial extremum)
#   F2 = d²R/dr² = 0          (marginal stability)
# Bardeen-Press-Teukolsky exact ISCO radii.


def _delta(r: float, a: float) -> float:
    return r * r - 2.0 * r + a * a


def _F0_kerr(r: float, E: float, x: float, a: float) -> float:
    A = E * r * r - a * x
    return A * A - _delta(r, a) * (r * r + x * x)


def _F1_kerr(r: float, E: float, x: float, a: float) -> float:
    A = E * r * r - a * x
    D = _delta(r, a)
    return 4.0 * E * r * A - (2.0 * r - 2.0) * (r * r + x * x) - 2.0 * r * D


def _F2_kerr(r: float, E: float, x: float, a: float) -> float:
    return (
        12.0 * E * E * r * r
        - 4.0 * a * E * x
        - 12.0 * r * r
        + 12.0 * r
        - 2.0 * x * x
        - 2.0 * a * a
    )


def _isco_radius(a: float, prograde: bool) -> float:
    """Bardeen-Press-Teukolsky exact equatorial Kerr ISCO radius, M=1."""
    z1 = 1.0 + (1.0 - a * a) ** (1.0 / 3.0) * (
        (1.0 + a) ** (1.0 / 3.0) + (1.0 - a) ** (1.0 / 3.0)
    )
    z2 = math.sqrt(3.0 * a * a + z1 * z1)
    if prograde:
        return 3.0 + z2 - math.sqrt((3.0 - z1) * (3.0 + z1 + 2.0 * z2))
    return 3.0 + z2 + math.sqrt((3.0 - z1) * (3.0 + z1 + 2.0 * z2))


def _circular_branch_values(r: float, a: float, prograde: bool) -> tuple[float, float] | None:
    """Exact (E, x = Lz - aE) on the equatorial timelike circular-orbit branch."""
    sr = math.sqrt(r)
    if prograde:
        denom_core = r ** 1.5 - 3.0 * sr + 2.0 * a
        if denom_core <= 0.0:
            return None
        denom = r ** 0.75 * math.sqrt(denom_core)
        E = (r ** 1.5 - 2.0 * sr + a) / denom
        x = r ** 0.75 * (sr - a) / math.sqrt(denom_core)
    else:
        denom_core = r ** 1.5 - 3.0 * sr - 2.0 * a
        if denom_core <= 0.0:
            return None
        denom = r ** 0.75 * math.sqrt(denom_core)
        E = (r ** 1.5 - 2.0 * sr - a) / denom
        x = -r ** 0.75 * (sr + a) / math.sqrt(denom_core)
    return E, x


def _kerr_isco_family_tangent(a0: float, prograde: bool, h: float = 1e-4) -> tuple[float, ...]:
    """Compute (dr_isco/da, dE/da, dx/da, 1, 0) via central FD in a.

    The 1 in the a-slot is the family parameter direction; the trailing 0
    is the lift variable X (held at 0 along the family).
    """
    r_plus = _isco_radius(a0 + h, prograde)
    r_minus = _isco_radius(a0 - h, prograde)
    vals_plus = _circular_branch_values(r_plus, a0 + h, prograde)
    vals_minus = _circular_branch_values(r_minus, a0 - h, prograde)
    dr_da = (r_plus - r_minus) / (2.0 * h)
    dE_da = (vals_plus[0] - vals_minus[0]) / (2.0 * h)
    dx_da = (vals_plus[1] - vals_minus[1]) / (2.0 * h)
    return (dr_da, dE_da, dx_da, 1.0, 0.0)


def kerr_isco_spec(a_value: float, prograde: bool) -> FixtureSpec:
    """Kerr 5D ISCO fixture at given spin parameter a (0 < a < 1) and branch."""
    r_isco = _isco_radius(a_value, prograde)
    vals = _circular_branch_values(r_isco, a_value, prograde)
    if vals is None:
        raise ValueError(f"Could not evaluate circular branch at a={a_value}, prograde={prograde}")
    E_isco, x_isco = vals
    branch_label = "prograde" if prograde else "retrograde"
    return FixtureSpec(
        name=f"kerr_isco_{branch_label}_a{a_value:.3f}".replace(".", "p"),
        n_phys=4,
        K_constraints=3,
        var_labels=("r", "E", "x", "a"),
        critical_point=(r_isco, E_isco, x_isco, a_value),
        constraint_funcs=(_F0_kerr, _F1_kerr, _F2_kerr),
        family_tangent=_kerr_isco_family_tangent(a_value, prograde),
        notes=(
            f"V3 reference: kerr_isco_joint_probe_5d.py; a={a_value}, {branch_label}; "
            f"Bardeen-Press-Teukolsky ISCO. K=3 constraints, n_phys=4."
        ),
    )


# --- Rayleigh-Bénard convection onset (k=2 in n=3 vars: Ra, k, Ta; X lift) ---
# F_marginal = Ra * k^2 - (pi^2 + k^2)^3 - pi^2 * Ta
# F_critical = (pi^2 + k^2)^2 * (2 k^2 - pi^2) - pi^2 * Ta
# At Ta=0: Ra_c = 27 pi^4 / 4 ~ 657.51, k_c = pi/sqrt(2) ~ 2.221
def rayleigh_benard_spec() -> FixtureSpec:
    Ta = 0.0
    k_c = math.pi / math.sqrt(2.0)
    Ra_c = 27.0 * math.pi ** 4 / 4.0
    return FixtureSpec(
        name="rayleigh_benard_onset",
        n_phys=3,
        K_constraints=2,
        var_labels=("Ra", "k", "Ta"),
        critical_point=(Ra_c, k_c, Ta),
        constraint_funcs=(
            lambda Ra, k, Ta: Ra * k * k - (math.pi ** 2 + k * k) ** 3 - math.pi ** 2 * Ta,
            lambda Ra, k, Ta: (math.pi ** 2 + k * k) ** 2 * (2.0 * k * k - math.pi ** 2) - math.pi ** 2 * Ta,
        ),
        # Family tangent at Ta=0: dRa/dTa = 2, dk/dTa = sqrt(2)/(9 pi^3), dTa = 1
        family_tangent=(2.0, math.sqrt(2.0) / (9.0 * math.pi ** 3), 1.0, 0.0),
        notes="V3 reference: rayleigh_benard_lifted_probe.py; Navier-Stokes / non-GR confirmation",
    )


