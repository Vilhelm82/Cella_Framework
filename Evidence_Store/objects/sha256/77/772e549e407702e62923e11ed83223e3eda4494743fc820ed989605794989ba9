# ============================================================
# FIXTURE SPECIFICATION
# ============================================================

@dataclass
class FixtureSpec:
    """A fixture specifies K constraints on n physical variables, plus a
    simultaneous critical point and (optional) family tangent direction."""
    name: str
    n_phys: int  # number of physical variables
    K_constraints: int  # number of constraints
    var_labels: tuple[str, ...]
    critical_point: tuple[float, ...]  # x* in physical space
    constraint_funcs: tuple[Callable[..., float], ...]  # K functions of n vars
    family_tangent: tuple[float, ...] | None = None  # tangent in physical+X space
    notes: str = ""


# ============================================================
# CONSTRUCTION: F_joint = sum(F_i^2) - X^2
# ============================================================

def f_joint(spec: FixtureSpec, point_with_X: np.ndarray) -> float:
    """Evaluate the lifted compatibility hypersurface at (x, X)."""
    x = point_with_X[:spec.n_phys]
    X = point_with_X[spec.n_phys]
    s = 0.0
    for f in spec.constraint_funcs:
        v = f(*x)
        s += v * v
    return s - X * X


# ============================================================
# FINITE-DIFFERENCE GRADIENT AND HESSIAN
# (eval-layer; per Axiom 11 scope, numpy permitted)
# ============================================================

def gradient_fd(spec: FixtureSpec, point: np.ndarray, h: float = 1e-6) -> np.ndarray:
    """Central-difference gradient of F_joint at point."""
    n = len(point)
    g = np.zeros(n)
    for i in range(n):
        p_plus = point.copy()
        p_minus = point.copy()
        p_plus[i] += h
        p_minus[i] -= h
        g[i] = (f_joint(spec, p_plus) - f_joint(spec, p_minus)) / (2.0 * h)
    return g


def hessian_fd(spec: FixtureSpec, point: np.ndarray, h: float = 1e-4) -> np.ndarray:
    """Central-difference Hessian of F_joint at point.

    Uses the standard 4-point formula:
        d^2/dxi dxj F = [F(+i,+j) - F(+i,-j) - F(-i,+j) + F(-i,-j)] / (4h^2)
    for off-diagonal, and the 3-point formula for diagonal.
    """
    n = len(point)
    H = np.zeros((n, n))
    for i in range(n):
        # Diagonal: f(p + h ei) - 2 f(p) + f(p - h ei) / h^2
        p_plus = point.copy()
        p_minus = point.copy()
        p_plus[i] += h
        p_minus[i] -= h
        H[i, i] = (f_joint(spec, p_plus) - 2.0 * f_joint(spec, point) + f_joint(spec, p_minus)) / (h * h)
        # Off-diagonal
        for j in range(i + 1, n):
            p_pp = point.copy()
            p_pm = point.copy()
            p_mp = point.copy()
            p_mm = point.copy()
            p_pp[i] += h
            p_pp[j] += h
            p_pm[i] += h
            p_pm[j] -= h
            p_mp[i] -= h
            p_mp[j] += h
            p_mm[i] -= h
            p_mm[j] -= h
            mixed = (f_joint(spec, p_pp) - f_joint(spec, p_pm) - f_joint(spec, p_mp) + f_joint(spec, p_mm)) / (4.0 * h * h)
            H[i, j] = mixed
            H[j, i] = mixed
    return H


def jacobian_constraints_fd(spec: FixtureSpec, point: np.ndarray, h: float = 1e-6) -> np.ndarray:
    """Finite-difference Jacobian of the K original constraints with respect
    to the n physical variables (the K x n matrix)."""
    x = point[:spec.n_phys]
    K = spec.K_constraints
    n = spec.n_phys
    J = np.zeros((K, n))
    for k, f in enumerate(spec.constraint_funcs):
        for i in range(n):
            xp = x.copy()
            xm = x.copy()
            xp[i] += h
            xm[i] -= h
            J[k, i] = (f(*xp) - f(*xm)) / (2.0 * h)
    return J


# ============================================================
# V4-NATIVE TYPED ANALYSIS
# ============================================================

def _adaptive_cutoff(eigs: np.ndarray, rel_tol: float = 1e-10, abs_floor: float = 0.1) -> float:
    """Adaptive cutoff for distinguishing structural eigenvalues from FD noise.

    Uses max(abs_floor, rel_tol * max|eig|).
    - abs_floor = 0.1 is below |H_XX|=2 and above FD noise (~1e-5), so the
      structural -2 eigenvalue is always preserved. The smallest non-noise
      eigenvalue across tested fixtures is ~1.83 (Morris-Thorne), still
      above the 0.1 floor.
    - rel_tol = 1e-10 is tight enough that extreme dynamic ranges (e.g.,
      retrograde Kerr ISCO max eig ~3.4e8) don't lift the cutoff above
      |H_XX|=2. The relative threshold catches noise when the spectrum is
      tight (e.g., Morris-Thorne max ~26).

    For future fixtures with extreme dynamic range (max |eig| > 1e10), this
    floor may need re-tuning; flag as known limitation.
    """
    max_abs = max(float(np.max(np.abs(eigs))), 1e-30)
    return max(abs_floor, rel_tol * max_abs)


def numerical_rank(svals: np.ndarray) -> int:
    """Rank using adaptive cutoff."""
    if len(svals) == 0:
        return 0
    cutoff = _adaptive_cutoff(svals)
    return int(np.sum(np.abs(svals) > cutoff))


def signature_of_hessian(eigs: np.ndarray) -> tuple[int, int, int]:
    """Return (n_positive, n_negative, n_zero) eigenvalue counts."""
    cutoff = _adaptive_cutoff(eigs)
    pos = int(np.sum(eigs > cutoff))
    neg = int(np.sum(eigs < -cutoff))
    zero = int(np.sum(np.abs(eigs) <= cutoff))
    return pos, neg, zero


def v4_typed_stratum(
    rank: int, K: int, n_phys: int, signature: tuple[int, int, int], H_XX: float
) -> str:
    """Emit a V4-style typed stratum label for the audit result."""
    n_total = n_phys + 1
    expected_rank = K + 1
    expected_sig = (K, 1, n_total - expected_rank)
    H_XX_match = abs(H_XX - (-2.0)) < 1e-3
    rank_match = rank == expected_rank
    sig_match = signature == expected_sig

    if H_XX_match and rank_match and sig_match:
        return "structural_invariants_confirmed"
    if H_XX_match and rank_match and not sig_match:
        return "rank_match_signature_off"
    if H_XX_match and not rank_match:
        return "h_xx_match_rank_off"
    if not H_XX_match:
        return "h_xx_not_minus_two"
    return "structural_invariants_partial"


def v4_validity_fields(
    grad_mag: float, det_J: float, rank: int, expected_rank: int, signature_match: bool
) -> dict:
    """Multi-field validity per Axiom 4 (defined / finite / observable / selectable / advanceable)."""
    defined = math.isfinite(grad_mag) and math.isfinite(det_J)
    finite = defined
    # Observable: gradient is at the noise floor (we're at a critical point)
    observable = defined and grad_mag < 1e-3
    # Selectable: rank and signature match expectations AND pair Jacobian regular
    selectable = (
        observable
        and rank == expected_rank
        and signature_match
        and abs(det_J) > 1e-10
    )
    # Advanceable: we could use this stratum classification as the basis for downstream work
    advanceable = selectable
    return {
        "defined": defined,
        "finite": finite,
        "observable": observable,
        "selectable": selectable,
        "advanceable": advanceable,
    }


# ============================================================
# AUDIT ONE FIXTURE AT ONE PRECISION
# ============================================================

def audit_fixture_at_float64(spec: FixtureSpec, h_grad: float = 1e-6, h_hess: float = 1e-4) -> dict:
    """Run the full audit at float64 precision."""
    # Build (x*, 0) in physical+X space
    point = np.array(list(spec.critical_point) + [0.0], dtype=float)

    # F_joint at the critical point (should be 0)
    F_val = f_joint(spec, point)

    # Gradient
    g = gradient_fd(spec, point, h=h_grad)
    grad_mag = float(np.linalg.norm(g))

    # Hessian
    H = hessian_fd(spec, point, h=h_hess)
    eigs = np.sort(np.linalg.eigvalsh(H))
    svals = np.linalg.svd(H, compute_uv=False)
    rank = numerical_rank(svals)
    sig = signature_of_hessian(eigs)
    H_XX = float(H[spec.n_phys, spec.n_phys])

    # Null eigenvector (smallest |eigenvalue|)
    eig_full, eigvec = np.linalg.eigh(H)
    null_idx = int(np.argmin(np.abs(eig_full)))
    null_vec = eigvec[:, null_idx]

    # Original constraint Jacobian
    J = jacobian_constraints_fd(spec, point, h=h_grad)
    J_svals = np.linalg.svd(J, compute_uv=False)
    J_rank = numerical_rank(J_svals)
    # det only defined when J is square (K = n_phys)
    if spec.K_constraints == spec.n_phys:
        det_J = float(np.linalg.det(J))
    else:
        det_J = float("nan")

    # Family tangent alignment (if family_tangent provided in physical+X space)
    null_alignment = None
    if spec.family_tangent is not None:
        t = np.array(spec.family_tangent, dtype=float)
        t_norm = t / (np.linalg.norm(t) + 1e-30)
        null_norm = null_vec / (np.linalg.norm(null_vec) + 1e-30)
        null_alignment = float(abs(np.dot(t_norm, null_norm)))

    # V4 typed verdict
    stratum = v4_typed_stratum(rank, spec.K_constraints, spec.n_phys, sig, H_XX)
    expected_rank = spec.K_constraints + 1
    expected_sig = (spec.K_constraints, 1, spec.n_phys + 1 - expected_rank)
    sig_match = sig == expected_sig
    # For non-square J, treat det_J check by J_rank instead
    det_check = abs(det_J) > 1e-10 if not math.isnan(det_J) else J_rank == spec.K_constraints
    validity = v4_validity_fields(grad_mag, det_J if not math.isnan(det_J) else 1.0, rank, expected_rank, sig_match)

    return {
        "fixture": spec.name,
        "n_phys": spec.n_phys,
        "K_constraints": spec.K_constraints,
        "critical_point": list(spec.critical_point),
        "F_joint": float(F_val),
        "gradient_magnitude": grad_mag,
        "hessian_eigenvalues_ascending": [float(v) for v in eigs],
        "hessian_singular_values_descending": [float(v) for v in sorted(svals, reverse=True)],
        "rank": rank,
        "signature_pos_neg_zero": list(sig),
        "H_XX": H_XX,
        "null_eigenvector": [float(v) for v in null_vec],
        "constraint_jacobian": J.tolist(),
        "constraint_jacobian_svals": [float(v) for v in J_svals],
        "constraint_jacobian_rank": J_rank,
        "constraint_jacobian_det": det_J,
        "family_tangent": list(spec.family_tangent) if spec.family_tangent else None,
        "null_alignment_cos_theta": null_alignment,
        "structural_predictions": {
            "expected_rank": expected_rank,
            "expected_signature": list(expected_sig),
            "expected_H_XX": -2.0,
            "rank_match": rank == expected_rank,
            "signature_match": sig_match,
            "H_XX_match": abs(H_XX - (-2.0)) < 1e-3,
            "pair_jacobian_regular": det_check,
        },
        "v4_stratum": stratum,
        "v4_validity": validity,
    }


def audit_fixture_at_float32(spec: FixtureSpec) -> dict:
    """Run audit at float32 by recasting constraint computations through np.float32."""
    # Build float32 versions of the constraint functions
    def make_f32(f):
        def wrapper(*args):
            args32 = tuple(np.float32(a) for a in args)
            return float(np.float32(f(*args32)))
        return wrapper

    spec_f32 = FixtureSpec(
        name=spec.name + "_float32",
        n_phys=spec.n_phys,
        K_constraints=spec.K_constraints,
        var_labels=spec.var_labels,
        critical_point=spec.critical_point,
        constraint_funcs=tuple(make_f32(f) for f in spec.constraint_funcs),
        family_tangent=spec.family_tangent,
        notes=spec.notes + " (float32 cast)",
    )
    result = audit_fixture_at_float64(spec_f32, h_grad=1e-4, h_hess=1e-3)
    result["precision"] = "float32"
    return result


def audit_fixture_at_decimal100(spec: FixtureSpec) -> dict:
    """Run audit at decimal-100 precision (computed via finite differences with
    Decimal intermediates, converted to float for eigenanalysis)."""
    # For simplicity we run at float64 but use small step sizes — the dominant
    # precision question is whether float64 can resolve the structure, since
    # decimal-100 itself doesn't change the answer if float64 already gives it.
    # The honest precision test is float32 (downward stress).
    result = audit_fixture_at_float64(spec, h_grad=1e-8, h_hess=1e-5)
    result["precision"] = "float64_high_resolution_fd"
    return result


