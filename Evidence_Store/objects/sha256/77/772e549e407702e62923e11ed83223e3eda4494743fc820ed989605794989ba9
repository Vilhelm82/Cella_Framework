def main() -> None:
    np.set_printoptions(suppress=True, precision=10)
    REPORT_DIR.mkdir(parents=True, exist_ok=True)

    fixtures = [
        schwarzschild_isco_spec(),
        schwarzschild_photon_spec(),
        morris_thorne_spec(),
        rayleigh_benard_spec(),
        kerr_isco_spec(0.9, prograde=True),
        kerr_isco_spec(0.9, prograde=False),
    ]

    # Spin continuity check for Kerr ISCO across a ∈ {0.1, 0.3, 0.5, 0.7, 0.9, 0.99}
    spin_continuity: dict[str, dict] = {"prograde": {}, "retrograde": {}}
    for a_val in (0.1, 0.3, 0.5, 0.7, 0.9, 0.99):
        for branch_name, prograde in [("prograde", True), ("retrograde", False)]:
            try:
                spec = kerr_isco_spec(a_val, prograde=prograde)
                result = audit_fixture_at_float64(spec)
                spin_continuity[branch_name][f"a_{a_val:.2f}"] = {
                    "a": a_val,
                    "r_isco": spec.critical_point[0],
                    "stratum": result["v4_stratum"],
                    "rank": result["rank"],
                    "signature": result["signature_pos_neg_zero"],
                    "H_XX": result["H_XX"],
                    "null_alignment": result["null_alignment_cos_theta"],
                    "pair_jacobian_rank": result["constraint_jacobian_rank"],
                    "pair_jacobian_regular": result["structural_predictions"]["pair_jacobian_regular"],
                }
            except Exception as e:
                spin_continuity[branch_name][f"a_{a_val:.2f}"] = {"error": str(e)}

    results_per_fixture: dict[str, dict] = {}
    for spec in fixtures:
        per_precision: dict[str, dict] = {}
        per_precision["float64"] = audit_fixture_at_float64(spec)
        per_precision["float64"]["precision"] = "float64"
        per_precision["float64_high_resolution_fd"] = audit_fixture_at_decimal100(spec)
        per_precision["float32"] = audit_fixture_at_float32(spec)
        results_per_fixture[spec.name] = per_precision

    # Cross-fixture aggregator
    cross_fixture: dict = {
        "structural_invariants_all_fixtures": True,
        "details_per_fixture_float64": {},
    }
    for fname, prec_results in results_per_fixture.items():
        r64 = prec_results["float64"]
        all_match = (
            r64["structural_predictions"]["rank_match"]
            and r64["structural_predictions"]["signature_match"]
            and r64["structural_predictions"]["H_XX_match"]
        )
        if not all_match:
            cross_fixture["structural_invariants_all_fixtures"] = False
        cross_fixture["details_per_fixture_float64"][fname] = {
            "stratum": r64["v4_stratum"],
            "rank": r64["rank"],
            "signature": r64["signature_pos_neg_zero"],
            "H_XX": r64["H_XX"],
            "rank_match": r64["structural_predictions"]["rank_match"],
            "signature_match": r64["structural_predictions"]["signature_match"],
            "H_XX_match": r64["structural_predictions"]["H_XX_match"],
            "pair_jacobian_regular": r64["structural_predictions"]["pair_jacobian_regular"],
            "null_alignment": r64["null_alignment_cos_theta"],
        }

    artifact = {
        "audit_name": "lifted_singularity_v4_audit",
        "preregistry": str(REPORT_DIR / "preregistry.md"),
        "frozen_predictions_summary": (
            "S1-S5 structural (predicted by construction); E1-E3 empirical "
            "(predicted to hold across all fixtures). H_XX = -2 is structural "
            "not a discovery; null alignment with family tangent is the real "
            "empirical claim."
        ),
        "results_per_fixture": results_per_fixture,
        "cross_fixture_invariance": cross_fixture,
        "kerr_spin_continuity": spin_continuity,
    }

    ARTIFACT.write_text(json.dumps(artifact, indent=2, default=float, sort_keys=True))
    print(f"Artifact written to {ARTIFACT}")
    print()
    print("=== Per-fixture float64 summary ===")
    print(f"{'fixture':<28} {'stratum':<36} {'rank':<6} {'sig':<14} {'H_XX':<8} {'PJ_reg':<8} {'null_align':<10}")
    print("-" * 120)
    for fname, d in cross_fixture["details_per_fixture_float64"].items():
        sig_s = f"({d['signature'][0]},{d['signature'][1]},{d['signature'][2]})"
        align_s = f"{d['null_alignment']:.4f}" if d['null_alignment'] is not None else "N/A"
        print(f"{fname:<28} {d['stratum']:<36} {d['rank']:<6} {sig_s:<14} {d['H_XX']:<8.4f} {str(d['pair_jacobian_regular']):<8} {align_s:<10}")
    print()
    print(f"=== Cross-fixture structural invariance: {cross_fixture['structural_invariants_all_fixtures']} ===")
    print()
    print("=== Multi-precision (rank should be invariant across precisions) ===")
    print(f"{'fixture':<28} {'precision':<35} {'rank':<6} {'H_XX':<8}")
    print("-" * 80)
    for fname, prec_results in results_per_fixture.items():
        for prec_label, r in prec_results.items():
            print(f"{fname:<28} {prec_label:<35} {r['rank']:<6} {r['H_XX']:<8.4f}")


if __name__ == "__main__":
    main()
