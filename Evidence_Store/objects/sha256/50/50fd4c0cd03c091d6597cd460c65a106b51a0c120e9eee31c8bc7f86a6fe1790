# Known targets from prior dense task (layer 2) - key values
PRIOR_DENSE_TARGETS = {
    "schwarzschild": {"max_deviation_f1f2_from_closed": 1.3877787807814457e-17},
    "sr": {"max_deviation_f1f2_from_closed": 1.1102230246251565e-16},
