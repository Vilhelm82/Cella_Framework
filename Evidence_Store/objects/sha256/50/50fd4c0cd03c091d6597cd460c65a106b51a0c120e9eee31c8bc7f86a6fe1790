RETEST_C_DIR = Path(__file__).resolve().parents[2] / "_revalidation" / "retestC"
PRIOR_TASK_DIR = Path(__file__).resolve().parents[1] / "f1_f2_common_mode_rejection_sterbenz_dense"

# Known targets from Retest C (layer 1)
RETEST_C_TARGETS = {
    "schwarzschild": {"max_cancel_residual": 5.551115123125783e-17, "f4_operand_differs_count": 108, "f4_operand_equal_count": 29},
    "sr": {"max_cancel_residual": 1.1102230246251565e-16, "f4_operand_differs_count": 55, "f4_operand_equal_count": 82},
