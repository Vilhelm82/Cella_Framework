def main():
    print("=== LAYER 1: Retest C ===")
    l1 = run_layer1_retest_c()
    l1_pass = True
    for name, res in l1.items():
        t = RETEST_C_TARGETS[name]
        ok = (math.isclose(res["max_cancel_residual"], t["max_cancel_residual"], abs_tol=1e-20) and
              res["f4_diff"] == t["f4_diff"] and res["f4_eq"] == t["f4_eq"])
        status = "PASS" if ok else "FAIL"
        if not ok: l1_pass = False
        print(f"  {name}: {status}")

    print("\n=== LAYER 2: Prior ULP j-quantization (reported values from previous artifact) ===")
    l2 = run_layer2_prior_ulp()
    l2_pass = "error" not in l2
    for name, res in l2.items():
        if name in PRIOR_ULP_TARGETS:
            t = PRIOR_ULP_TARGETS[name]
            ok = math.isclose(res["j_variance"], t["j_variance"], rel_tol=0.01)
            status = "PASS" if ok else "FAIL"
            if not ok: l2_pass = False
            print(f"  {name}: {status} (var={res['j_variance']:.6e})")

    print("\n=== LAYER 3: Lifted Singularity Audit ===")
    l3 = run_layer3_lifted()
    l3_pass = l3["audit_artifact_exists"]
    print(f"  Artifact exists: {l3_pass}")
    print(f"  Structural claim: {l3['claimed_structural']}")
    print(f"  Empirical claim:  {l3['claimed_empirical']}")

    overall = l1_pass and l2_pass and l3_pass
    print(f"\n=== OVERALL 3-LAYER RETRODICTION GATE: {'PASSED' if overall else 'FAILED'} ===")

    out = {"layer1": l1, "layer2": l2, "layer3": l3, "overall_pass": overall}
    (TASK_DIR / "retrodiction.json").write_text(json.dumps(out, indent=2, default=str))

    if not overall:
        raise SystemExit(1)


if __name__ == "__main__":
    main()