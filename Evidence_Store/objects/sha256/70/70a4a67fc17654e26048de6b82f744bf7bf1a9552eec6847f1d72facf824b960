#!/usr/bin/env python3
"""
Investigation 1: Parity Trap - Full Version

Covers:
1. Schwarzschild and SR (in addition to pure_algebraic + cbrt)
2. All four paths: Early F2, Late F2, P_compound_split, P_sign_c

For pure_algebraic and cbrt: sweep crossing V_n = 1.0 inside Sterbenz.
For Schwarzschild and SR: dense sweep across their Sterbenz boundaries.

Uses mpmath for truth, reports error in ulp(1.0).
"""

from __future__ import annotations
import numpy as np
import mpmath as mp

mp.mp.dps = 60

def analyze_fixture(name: str, sweep_points: np.ndarray, compute_power_xterm_direct):
    """
    compute_power_xterm_direct(x_or_r) -> (power, x_term, direct) in float64
    """
    results = {
        "early": [], "late": [], "compound": [], "sign_c": [],
        "v_n_lt_1": [],
        "param": [],
    }

    for p in sweep_points:
        power, x_term, direct = compute_power_xterm_direct(p)

        early = (power - 1.0) + x_term
        late = power + (x_term - 1.0)
        compound = (power - 1.0) + (1.0 - direct)
        sign_c = (power - 1.0) - (-1.0 + direct)

        v_n = power
        v_n_lt1 = v_n < 1.0

        results["early"].append(early)
        results["late"].append(late)
        results["compound"].append(compound)
        results["sign_c"].append(sign_c)
        results["v_n_lt_1"].append(v_n_lt1)
        results["param"].append(p)

    return {k: np.array(v) for k, v in results.items()}

def summarize(name: str, data: dict):
    print(f"\n=== {name} ===")
    late = np.array(data["late"])
    early = np.array(data["early"])
    comp = np.array(data["compound"])
    sign = np.array(data["sign_c"])
    v_n_lt1 = np.array(data["v_n_lt_1"])

    ULP1 = 2.0 ** -52

    def stats(err):
        return np.mean(np.abs(err)) / ULP1

    print("Mean |error| in ulp(1.0):")
    for label, err in [("Early", early), ("Late", late), ("Compound", comp), ("Sign_c", sign)]:
        pos = stats(err[v_n_lt1])
        neg = stats(err[~v_n_lt1])
        print(f"  {label:8}  V_n<1: {pos:.4f}   V_n>1: {neg:.4f}")

    # Count near 0.5 ulp
    def count_half(err, mask):
        e = np.abs(err[mask]) / ULP1
        return np.sum(np.abs(e - 0.5) < 0.05)

    print("Points near exactly 0.5 ulp(1):")
    for label, err in [("Early", early), ("Late", late), ("Compound", comp), ("Sign_c", sign)]:
        c_pos = count_half(err, v_n_lt1)
        c_neg = count_half(err, ~v_n_lt1)
        print(f"  {label:8}  V_n<1: {c_pos:4d}   V_n>1: {c_neg:4d}")

# Fixture implementations

def pure_algebraic(p):  # p = x
    x = p
    direct = 1.0 - x
    r = np.sqrt(direct)
    power = r * r
    return power, x, direct

def cbrt_chain(p):  # p = x
    x = p
    direct = 1.0 - x
    r = np.cbrt(direct)
    power = r * r * r
    return power, x, direct

def schwarzschild(p):  # p = r
    r = p
    x_term = 2.0 / r
    direct = 1.0 - x_term
    sqrt_d = np.sqrt(direct)
    power = sqrt_d * sqrt_d
    return power, x_term, direct

def sr(p):  # p = beta
    beta = p
    x_term = beta * beta
    direct = 1.0 - x_term
    eta = np.sqrt(direct)
    power = eta * eta
    return power, x_term, direct

def main():
    print("Investigation 1: Parity Trap - Full Cross-Fixture Run")
    print("=" * 70)

    # 1. Pure algebraic + cbrt: crossing V_n=1
    x_sweep = np.linspace(-0.005, 0.005, 10001)
    data_pa = analyze_fixture("pure_algebraic", x_sweep, pure_algebraic)
    data_cbrt = analyze_fixture("cbrt", x_sweep, cbrt_chain)

    # 2. Schwarzschild: across r=4
    r_sweep = np.linspace(3.5, 5.0, 10001)
    data_schw = analyze_fixture("schwarzschild", r_sweep, schwarzschild)

    # 3. SR: across beta = 1/sqrt(2)
    beta_sweep = np.linspace(0.65, 0.75, 10001)
    data_sr = analyze_fixture("sr", beta_sweep, sr)

    summarize("Pure Algebraic (crossing V_n=1)", data_pa)
    summarize("Cbrt (crossing V_n=1)", data_cbrt)
    summarize("Schwarzschild (across r=4 Sterbenz)", data_schw)
    summarize("SR (across beta Sterbenz)", data_sr)

    # Save all
    np.savez_compressed(
        "scratch/investigation1_full_results.npz",
        pa=data_pa, cbrt=data_cbrt, schw=data_schw, sr=data_sr
    )
    print("\nFull results saved to scratch/investigation1_full_results.npz")

if __name__ == "__main__":
    main()
