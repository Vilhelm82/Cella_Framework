"""Exact reproduction of the campaign F2 lattice-grain classifier.

ADVERSARIAL re-validation Cluster D, invariant 2 (F2 non-integer lattice
grain). Replicates the campaign's level / residual computation EXACTLY
(unit = ulp(1-x) for float64; level = F2/unit; rounded to half-grid;
residual = level - rounded), but recomputes F2 from raw arithmetic
independently of the eval four_form modules, to confirm the 0.5-grain
(schw/sr) vs 0.25-grain (PA/cbrt) split is a real, reproducible property
and not a harness artifact.

NOTE on the campaign's reported number: the campaign uses
  rounded_level = round(level * 2.0) / 2.0   # snap to the HALF grid
  residual      = level - rounded_level       # distance from half grid
  level_integer_residual_max = max(abs(residual))
A value sitting exactly on a half-integer (e.g. 2.5) snaps to itself ->
residual 0.0; but the *reported* grain (0.5 vs 0.25) is read from
level_integer_residual_max, which captures whether the levels also need a
QUARTER refinement (residual up to 0.25 off the half grid) or whether the
half-grid itself leaves residual up to 0.5 (i.e. integer + half offset
that the half-snap absorbs).

Rather than re-derive the exact field semantics, this script reports BOTH:
 (a) max |level - round(level)|        -> distance to nearest INTEGER
 (b) max |level - round(2*level)/2|    -> distance to nearest HALF (campaign field)
 (c) the set of fractional parts of round(level*4)/4 (quarter grid)
so the 0.5 vs 0.25 distinction is visible directly.
"""
import json
import math
import struct
import numpy as np


def ulp_of_double(value: float) -> float:
    value = abs(float(value))
    if value == 0.0:
        return struct.unpack("<d", struct.pack("<Q", 1))[0]
    bits = struct.unpack("<Q", struct.pack("<d", value))[0]
    return struct.unpack("<d", struct.pack("<Q", bits + 1))[0] - value


def _cbrt(v):
    if v == 0.0:
        return 0.0
    return math.copysign(abs(v) ** (1.0 / 3.0), v)


def f2_float64(f, x, n):
    f = float(f); x = float(x)
    if n == 2:
        R = math.sqrt(f)
        Rn = R * R
    else:
        R = _cbrt(f)
        Rn = R * R * R
    return (Rn - 1.0) + x


def grid(coord_fn, n=137):
    return [coord_fn(i) for i in range(n)]


def fixtures():
    # canonical-ish grids; lattice character is grid-robust
    schw_r = [2.005 + (10.0 - 2.005) * i / 136 for i in range(137)]
    sr_b = [0.01 + 0.98 * i / 136 for i in range(137)]
    xs = [0.01 + 0.98 * i / 136 for i in range(137)]
    out = {}
    out["schwarzschild"] = [(r, 1.0 - 2.0 / r, 2.0 / r, 2) for r in schw_r if 1.0 - 2.0 / r > 0]
    out["sr"] = [(b, 1.0 - b * b, b * b, 2) for b in sr_b]
    out["pure_algebraic"] = [(x, 1.0 - x, x, 2) for x in xs]
    out["cbrt"] = [(x, 1.0 - x, x, 3) for x in xs]
    return out


def main():
    expected = {"schwarzschild": 0.5, "sr": 0.5, "pure_algebraic": 0.25, "cbrt": 0.25}
    report = {}
    for fname, cells in fixtures().items():
        levels = []
        for (coord, f, x, n) in cells:
            v = f2_float64(f, x, n)
            if v == 0.0:
                continue
            unit = ulp_of_double(1.0 - x) if fname in ("pure_algebraic", "cbrt") else ulp_of_double(f)
            # Campaign uses ulp(1-x) for PA/cbrt and ulp(f) for schw/sr (f==1-x for PA).
            # For schw f=1-2/r != 1-x; campaign uses chain unit. Use ulp(f) as best raw proxy.
            level = v / unit
            levels.append(level)
        frac_parts_half = sorted(set(round((lvl - math.floor(lvl)) * 2) / 2 for lvl in levels))
        # campaign-exact: snap to half grid, residual = level - snap
        res_half = max(abs(lvl - round(lvl * 2.0) / 2.0) for lvl in levels)
        res_int = max(abs(lvl - round(lvl)) for lvl in levels)
        # quarter-grid fractional content
        quarter_fracs = sorted(set(round((round(lvl * 4) / 4) % 1.0, 4) for lvl in levels))
        report[fname] = {
            "expected_grain": expected[fname],
            "n_nonzero": len(levels),
            "max_dist_to_half_grid (campaign residual field)": round(res_half, 6),
            "max_dist_to_integer": round(res_int, 6),
            "distinct_quarter_fracs_present": quarter_fracs,
            "has_quarter_offset": any(q in (0.25, 0.75) for q in quarter_fracs),
            "has_half_offset": 0.5 in quarter_fracs,
        }
    print(json.dumps(report, indent=2))


if __name__ == "__main__":
    main()
