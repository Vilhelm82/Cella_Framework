def stress_test_universal_slots(fixture: str) -> dict | None:
    """For four-form fixtures, evaluate slots 13/14/15/16 at each probe
    point individually. Returns None for non-four-form fixtures."""
    if fixture not in PROBE_WINDOW:
        return None
    rows: list[dict] = []
    for probe in PROBE_WINDOW[fixture]:
        forms = _four_form_at(fixture, probe)
        if forms is None:
            continue
        all_mags = [abs(v) for v in forms.values()]
        nonzero_mags = sorted(m for m in all_mags if m > 0.0)
        # Slot 13 at this point
        if nonzero_mags:
            s13 = round(math.log10(max(nonzero_mags)), 4)
        else:
            s13 = None
        # Slot 14 at this point
        if len(nonzero_mags) >= 2:
            s14 = round(math.log10(nonzero_mags[-1] / nonzero_mags[0]), 4)
        else:
            s14 = None
        # Slot 15 at this point
        a = _route_a_four_form_residual(fixture, probe)
        b = _route_b_four_form_residual(fixture, probe)
        if a is not None and b is not None:
            if fixture == "SR":
                f = 1.0 - probe * probe
            elif fixture in {"pure_algebraic", "cube_root"}:
                f = 1.0 - probe
            elif fixture == "Schwarzschild":
                f = 1.0 - 2.0 / probe
            else:
                f = 1.0
            s15 = round(abs(a - b) / _ulp(f), 3)
        else:
            s15 = None
        # Slot 16 at this point
        if all_mags and probe != 0.0 and max(all_mags) > 0.0:
            s16 = round(math.log2(abs(probe)) - math.log2(max(all_mags)), 4)
        else:
            s16 = None
        rows.append(
            {
                "probe": probe,
                "slot_13": s13,
                "slot_14": s14,
                "slot_15": s15,
                "slot_16": s16,
            }
        )
    return {"rows": rows}


