def _quantize_fraction(f: float) -> int:
    """Quantize a fraction in [0, 1] to 0..255."""
    return min(255, max(0, int(round(f * 255.0))))


def slot_11c_dual_arm_split(fixture: str, variant: str) -> Slot:
    name = "slot_11c_dual_arm_split"
    if not DUAL_ARM_CAPABLE.get(fixture, False):
        return _na_slot(name)
    data = _load_json(HARDENED_ARTIFACT)
    if data is None:
        return _unobs_slot(name)
    headline = data.get("headline", {})
    total = headline.get("total_records", 0)
    resolved = headline.get("resolved_count", 0)
    zero_sep = headline.get("underpromotion_breakdown", {}).get(
        "armN_zero_path_separation", 0
    )
    if total == 0:
        return _unobs_slot(name)
    inactive = total - resolved - zero_sep
    return _defined_slot(
        name,
        {
            "resolved_q": _quantize_fraction(resolved / total),
            "zero_sep_q": _quantize_fraction(zero_sep / total),
            "inactive_q": _quantize_fraction(inactive / total),
        },
        bits=24,
    )


# ---------------------------------------------------------------------------
# Refined slot 13: window-mean curvature magnitude (kept at 16 bits)
# ---------------------------------------------------------------------------

def slot_13r_critical_curvature_log10(fixture: str, variant: str) -> Slot:
    name = "slot_13r_critical_curvature_log10"
    if fixture in PROBE_WINDOW:
        all_mags: list[float] = []
        for var in PROBE_WINDOW[fixture]:
            forms = _four_form_at(fixture, var)
            if forms is None:
                continue
            all_mags.extend(abs(v) for v in forms.values())
        nonzero_mags = [m for m in all_mags if m > 0.0]
        if not nonzero_mags:
            return _unobs_slot(name)
        return _defined_slot(name, round(math.log10(max(nonzero_mags)), 4), bits=16)
    entry = _lifted_entry(fixture)
    if entry is None:
        return _na_slot(name)
    eigs = entry.get("hessian_eigenvalues_ascending")
    if eigs is None:
        return _unobs_slot(name)
    try:
        magnitudes = [abs(float(e)) for e in eigs]
    except (TypeError, ValueError):
        return _failed_slot(name, "eigenvalues not iterable")
    max_mag = max(magnitudes) if magnitudes else 0.0
    if max_mag == 0.0:
        return _unobs_slot(name)
    return _defined_slot(name, round(math.log10(max_mag), 4), bits=16)


# ---------------------------------------------------------------------------
# Refined slot 14: window max/min (3 probe points → 12 magnitudes per fixture)
# ---------------------------------------------------------------------------

def slot_14r_conditioning_index_log10(fixture: str, variant: str) -> Slot:
    name = "slot_14r_conditioning_index_log10"
    if fixture in PROBE_WINDOW:
        all_mags: list[float] = []
        for var in PROBE_WINDOW[fixture]:
            forms = _four_form_at(fixture, var)
            if forms is None:
                continue
            all_mags.extend(abs(v) for v in forms.values())
        nonzero_mags = sorted(m for m in all_mags if m > 0.0)
        if len(nonzero_mags) < 2:
            return _unobs_slot(name)
        spread = math.log10(nonzero_mags[-1] / nonzero_mags[0])
        return _defined_slot(name, round(spread, 4), bits=16)
    entry = _lifted_entry(fixture)
    if entry is None:
        return _na_slot(name)
    eigs = entry.get("hessian_eigenvalues_ascending")
    if eigs is None:
        return _unobs_slot(name)
    try:
        magnitudes = sorted(
            abs(float(e)) for e in eigs if abs(float(e)) > 0.0
        )
    except (TypeError, ValueError):
        return _failed_slot(name, "eigenvalues not iterable")
    if len(magnitudes) < 2:
        return _unobs_slot(name)
    return _defined_slot(
        name, round(math.log10(magnitudes[-1] / magnitudes[0]), 4), bits=16
    )


# ---------------------------------------------------------------------------
# Refined slot 15: max route variation over the window
# ---------------------------------------------------------------------------

def slot_15r_route_variation_signature(fixture: str, variant: str) -> Slot:
    name = "slot_15r_route_variation_signature"
    if fixture in PROBE_WINDOW:
        max_dev = 0.0
        any_computed = False
        for var in PROBE_WINDOW[fixture]:
            a = _route_a_four_form_residual(fixture, var)
            b = _route_b_four_form_residual(fixture, var)
            if a is None or b is None:
                continue
            if fixture == "SR":
                f = 1.0 - var * var
            elif fixture in {"pure_algebraic", "cube_root"}:
                f = 1.0 - var
            elif fixture == "Schwarzschild":
                f = 1.0 - 2.0 / var
            else:
                f = 1.0
            dev = abs(a - b) / _ulp(f)
            max_dev = max(max_dev, dev)
            any_computed = True
        if not any_computed:
            return _failed_slot(name, "no four-form")
        return _defined_slot(name, round(max_dev, 3), bits=24)
    entry = _lifted_entry(fixture)
    if entry is None:
        return _na_slot(name)
    f_joint = entry.get("F_joint")
    eigs = entry.get("hessian_eigenvalues_ascending")
    if f_joint is None or eigs is None:
        return _unobs_slot(name)
    max_eig_mag = max(abs(float(e)) for e in eigs) if eigs else 1.0
    if max_eig_mag == 0.0:
        max_eig_mag = 1.0
    return _defined_slot(
        name, round(abs(float(f_joint)) / _ulp(max_eig_mag), 3), bits=24
    )


# ---------------------------------------------------------------------------
# NEW slot 16: binade_loss_depth_log2 (UNIVERSAL)
# ---------------------------------------------------------------------------

def slot_16_binade_loss_depth_log2(fixture: str, variant: str) -> Slot:
    name = "slot_16_binade_loss_depth_log2"
    if fixture in PROBE_WINDOW:
        # Use the central probe point of the window
        probe = PROBE_WINDOW[fixture][1]
        forms = _four_form_at(fixture, probe)
        if forms is None:
            return _failed_slot(name, "no four-form")
        max_mag = max(abs(v) for v in forms.values())
        if max_mag == 0.0:
            return _unobs_slot(name)
        operand_mag = abs(probe)
        if operand_mag == 0.0:
            return _unobs_slot(name)
        # binade_loss = log2(operand) - log2(result)
        # Positive: result is below operand (cancellation occurred)
        # Negative: result is above operand (no cancellation, growth)
        depth = math.log2(operand_mag) - math.log2(max_mag)
        return _defined_slot(name, round(depth, 4), bits=16)
    # Lifted-singularity fixtures
    entry = _lifted_entry(fixture)
    if entry is None:
        return _na_slot(name)
    critical = entry.get("critical_point")
    eigs = entry.get("hessian_eigenvalues_ascending")
    if critical is None or eigs is None:
        return _unobs_slot(name)
    try:
        operand_mag = math.sqrt(sum(float(c) ** 2 for c in critical))
    except (TypeError, ValueError):
        return _failed_slot(name, "critical_point not numeric")
    max_mag = max(abs(float(e)) for e in eigs) if eigs else 0.0
    if max_mag == 0.0 or operand_mag == 0.0:
        return _unobs_slot(name)
    depth = math.log2(operand_mag) - math.log2(max_mag)
    return _defined_slot(name, round(depth, 4), bits=16)


