def slot_03c_c1_max_abs_level(fixture: str, variant: str) -> Slot:
    name = "slot_03c_c1_max_abs_level"
    entry = _test_a_entry(fixture)
    if entry is None:
        return _na_slot(name)
    levels = entry.get("c1_classification", {}).get("unique_levels", [])
    if not levels:
        return _unobs_slot(name)
    return _defined_slot(name, round(max(abs(float(lv)) for lv in levels), 6), bits=16)


