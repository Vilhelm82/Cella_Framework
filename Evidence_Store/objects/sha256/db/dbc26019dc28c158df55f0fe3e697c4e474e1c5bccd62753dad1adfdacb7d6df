"""Lens A:instrument-artifact independent refutation harness.

EVAL-LAYER ONLY. Instruments (numpy, decimal, fractions.Fraction) are
MEASUREMENT APPARATUS, never substrate. Every numerical claim is backed by an
IEEE 754 value or an exact (Fraction / Decimal) reduction.

Three jobs:
 (1) Re-read phase2A_boundary_trace.json; confirm/refute that PA/Schw
     first_dirty_f MOVES with the decimal anchor tier and SR is anchor-INVARIANT.
 (2) SR candidate-real probe: independently re-run the C_{p,k}=a_k+u_p*b_k fit
     near f=0.74291253059288 with (a) float128 tier REMOVED and (b) decimal
     anchor raised to decimal_200, decimal_300. Does SR's boundary MOVE?
 (3) Degenerate-fit mechanism: at collapse cells count DISTINCT NONZERO
     per-precision residuals. <2 => 2-param linear fit under-determined =>
     R^2 departure is a fitting artifact, not a substrate boundary.

Reads the recorded trace for anchors; recomputes binary/decimal residuals
independently of the original harness (own arithmetic) for the SR probe.
"""
from __future__ import annotations
import json, math
from decimal import Decimal, localcontext
from fractions import Fraction
import numpy as np

TRACE = '/home/william_lloydlt/projects/V4/Lloyd_Engine_V4/scratch/phase2A_boundary_trace.json'
OUT = '/home/william_lloydlt/projects/V4/Lloyd_Engine_V4/scratch/_A_lens_refutation_results.json'

DT = {"float32": np.float32, "float64": np.float64, "float128": np.float128}


def u_p_float(label: str) -> float:
    if label in DT:
        return float(np.finfo(DT[label]).eps) / 2.0
    if label.startswith("decimal_"):
        prec = int(label.split("_", 1)[1])
        return float(Decimal(5) * (Decimal(10) ** Decimal(-prec)))
    raise ValueError(label)


def operand_for_f(fixture, f):
    if fixture == "schwarzschild":
        return 2.0 / (1.0 - f)
    if fixture == "sr":
        return float(np.sqrt(1.0 - f))
    if fixture in ("pure_algebraic", "cbrt_chain"):
        return 1.0 - f
    raise ValueError(fixture)


def binary_residual(fixture, operand, label, path="F1"):
    s = DT[label]
    one = s(1.0); two = s(2.0); value = s(operand)
    if fixture == "schwarzschild":
        direct = one - two / value; root = np.sqrt(direct); power = root * root
    elif fixture == "sr":
        squared = value * value; direct = one - squared; root = np.sqrt(direct); power = root * root
    elif fixture == "pure_algebraic":
        direct = one - value; root = np.sqrt(direct); power = root * root
    elif fixture == "cbrt_chain":
        direct = one - value; root = np.cbrt(direct); power = root * root * root
    else:
        raise ValueError(fixture)
    return abs(float(power - direct))


def decimal_residual(fixture, operand, prec, path="F1"):
    with localcontext() as ctx:
        ctx.prec = prec
        one = Decimal(1); two = Decimal(2)
        value = Decimal.from_float(float(operand))
        if fixture == "schwarzschild":
            direct = one - two / value
        elif fixture == "sr":
            squared = value * value; direct = one - squared
        elif fixture == "pure_algebraic":
            direct = one - value
        else:
            raise ValueError(fixture)
        root = direct.sqrt(); power = root * root
        return abs(float(power - direct))


def r_squared(xs, ys):
    n = len(xs)
    mx = sum(xs) / n; my = sum(ys) / n
    sxx = sum((x - mx) ** 2 for x in xs)
    sxy = sum((x - mx) * (y - my) for x, y in zip(xs, ys))
    if sxx == 0:
        return None, None, None
    slope = sxy / sxx
    intercept = my - slope * mx
    ss_tot = sum((y - my) ** 2 for y in ys)
    ss_res = sum((y - (slope * x + intercept)) ** 2 for x, y in zip(xs, ys))
    if ss_tot == 0:
        r2 = 1.0 if ss_res == 0 else 0.0
    else:
        r2 = 1.0 - ss_res / ss_tot
    return r2, slope, intercept


def fit_at_f(fixture, f, binary_labels, anchor_label):
    operand = operand_for_f(fixture, f)
    xs = []; ys = []; per = {}
    for lab in binary_labels:
        r = binary_residual(fixture, operand, lab); xs.append(u_p_float(lab)); ys.append(r); per[lab] = r
    if anchor_label is not None:
        prec = int(anchor_label.split("_", 1)[1])
        r = decimal_residual(fixture, operand, prec); xs.append(u_p_float(anchor_label)); ys.append(r); per[anchor_label] = r
    r2, slope, intercept = r_squared(xs, ys)
    nz = [y for y in ys if y != 0.0]
    return {
        "f": f, "operand": operand, "operand_hex": operand.hex(),
        "binary_labels": list(binary_labels), "anchor": anchor_label,
        "r_squared": r2, "slope": slope, "intercept": intercept,
        "per_precision_residual": per,
        "n_tiers_total": len(ys), "n_tiers_nonzero": len(nz),
        "n_distinct_nonzero_residuals": len(set(nz)),
        "fit_carries_substrate_signal": bool(len(set(nz)) >= 2),
    }


def first_dirty_on_grid(fixture, binary_labels, anchor_label, grid, r2_tol=1.0 - 1e-9):
    first_dirty = None; last_clean = None
    for f in grid:
        pt = fit_at_f(fixture, f, binary_labels, anchor_label)
        if pt["r_squared"] is not None and pt["r_squared"] >= r2_tol:
            last_clean = pt
        else:
            first_dirty = pt
            break
    return last_clean, first_dirty


def f_grid(n_per_decade=24, f_max=0.9, f_min_exp=12):
    lo = -float(f_min_exp); hi = math.log10(f_max)
    n = int(round((hi - lo) * n_per_decade)) + 1
    out = []
    for i in range(n):
        t = hi + (lo - hi) * (i / (n - 1)); out.append(10.0 ** t)
    out.append(0.5)
    return tuple(sorted(set(out), reverse=True))


