#!/usr/bin/env python3
"""Validator for phase2C harness. Exits 0 only if every expected condition
holds and the artifact is byte-stable across 3 fresh runs. Writes a digest to
_p2c_validator.json regardless. Distinct nonzero exit codes per failure mode."""
import subprocess, sys, os, json, hashlib

base = os.path.dirname(os.path.abspath(__file__))
hp = os.path.join(base, "phase2C_nested_window_harness.py")
art = os.path.join(base, "phase2C_typed_result.json")

for f in ("PHASE2C_PROOF.txt", "phase2C_typed_result.json", "phase2C_status.json"):
    p = os.path.join(base, f)
    if os.path.exists(p):
        os.remove(p)

r = subprocess.run([sys.executable, hp, "--prove"], cwd=base,
                   capture_output=True, text=True)
if r.returncode != 0:
    open(os.path.join(base, "_p2c_validator.json"), "w").write(json.dumps(
        {"harness_rc": r.returncode, "stderr": r.stderr, "stdout": r.stdout},
        indent=2) + "\n")
    sys.exit(20)
if not os.path.exists(art):
    sys.exit(21)

a = json.load(open(art))
res = {x["fixture_key"]: x for x in a["results"]}
C, D, E = res["C"]["payload"], res["D"]["payload"], res["E"]["payload"]
C_alg_params = res["C"]["model_fits"]["M_A_algebraic"]["params"]

fails = []
def chk(name, cond):
    if not cond:
        fails.append(name)

chk("C_algebraic", C["classification"] == "algebraic_branch")
chk("C_winA", C["winning_ic_model_aic"] == "M_A_algebraic")
chk("C_winB", C["winning_ic_model_bic"] == "M_A_algebraic")
chk("C_sinf", C["s_inf_estimate"] is not None and abs(C["s_inf_estimate"] - 1.25) <= 1e-6)
chk("C_nw_stable", C["nested_window_stability_status"] == "STABLE")
chk("D_nonalg", D["classification"] == "non_algebraic_drift")
chk("D_winL", D["winning_ic_model_aic"] == "M_L_logarithmic")
chk("E_nonalg", E["classification"] == "non_algebraic_drift")
chk("E_winE_aic", E["winning_ic_model_aic"] == "M_E_essential")
chk("E_winE_bic", E["winning_ic_model_bic"] == "M_E_essential")
chk("E_rejected", E["algebraic_rejected_as_branch"] is True)
chk("gate_i", a["burden_gates"]["gate_i_fixture_E_rejected_as_algebraic_branch"]["met"] is True)
chk("gate_ii", a["burden_gates"]["gate_ii_fixture_C_s_inf_isolated_from_bias"]["met"] is True)

def sha():
    subprocess.run([sys.executable, hp], cwd=base, capture_output=True, text=True, check=True)
    return hashlib.sha256(open(art, "rb").read()).hexdigest()

h1 = hashlib.sha256(open(art, "rb").read()).hexdigest()
h2 = sha()
h3 = sha()
chk("byte_stable", h1 == h2 == h3)

digest = {
    "fails": fails,
    "all_pass": not fails,
    "C": {"class": C["classification"], "winA": C["winning_ic_model_aic"],
          "winB": C["winning_ic_model_bic"], "sinf": C["s_inf_estimate"],
          "sinf_err": C["s_inf_abs_error"], "nw": C["nested_window_stability_status"],
          "dAIC": C["delta_aic_over_runnerup"], "dBIC": C["delta_bic_over_runnerup"],
          "nw_slopes": C["nested_window_window_slopes"],
          "rho_pair": [C_alg_params.get("rho"), C_alg_params.get("rho2")],
          "A_rss": res["C"]["model_fits"]["M_A_algebraic"]["rss"],
          "A_k": res["C"]["model_fits"]["M_A_algebraic"]["k_params"]},
    "D": {"class": D["classification"], "winA": D["winning_ic_model_aic"],
          "winB": D["winning_ic_model_bic"], "dAIC": D["delta_aic_over_runnerup"],
          "nw": D["nested_window_stability_status"]},
    "E": {"class": E["classification"], "winA": E["winning_ic_model_aic"],
          "winB": E["winning_ic_model_bic"], "rejected": E["algebraic_rejected_as_branch"],
          "dAIC": E["delta_aic_over_runnerup"], "dBIC": E["delta_bic_over_runnerup"],
          "nw": E["nested_window_stability_status"]},
    "sha256_artifact": h1,
    "byte_stable": (h1 == h2 == h3),
    "artifact_bytes": os.path.getsize(art),
}
open(os.path.join(base, "_p2c_validator.json"), "w").write(
    json.dumps(digest, indent=2, sort_keys=True) + "\n")

# Verdict file whose NAME encodes pass/fail (readable even when display is dark).
for vf in os.listdir(base):
    if vf.startswith("VERDICT_"):
        os.remove(os.path.join(base, vf))
vname = "VERDICT_PASS" if (not fails and digest["byte_stable"]) else "VERDICT_FAIL_" + "_".join(fails)
open(os.path.join(base, vname), "w").write(json.dumps(digest, indent=2, sort_keys=True) + "\n")

sys.exit(50 if fails else 0)
