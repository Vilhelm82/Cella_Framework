"""REGULAR_INTEGER coverage probe — V4-disciplined exploratory test.

Pre-registration (binding before measurement):

Three positive-integer-alpha power-law observables at x0=0, probed via
singular_alpha_jet_bundle:

  I1 linear     : f(x) = x        , predicted alpha = 1
  I2 quadratic  : f(x) = x**2     , predicted alpha = 2
  I3 cubic      : f(x) = x**3     , predicted alpha = 3

x0 = 0, h_values = same 12-point sweep, eta = 1e-6, declared_alpha_models = ().

Mathematical setup:
  For f(x) = x^n at x0=0: g_singular(h) = h^n.
  transfer = n * h^(n-1).
  log|transfer| = log(n) + (n-1)*log(h).
  slope = n - 1.
  observed_alpha = slope + 1 = n.

So integer-alpha observables should give observed_alpha precisely at the
positive integer value, with the chain's precision-floor noise (~1e-11)
around it.

Predictions (the test):
- All three emit status SINGULAR_JET_REGULAR_INTEGER_ALPHA (inner ALPHA_REGULAR_INTEGER)
- observed_alpha within 1e-10 of the predicted integer
- Validity: selectable=True, advanceable=True (usable readings, can be integrated forward)

Falsifiability:
- Any observable misclassified as FRACTIONAL_BRANCH (would mean integer-classifier
  is unreachable in practice, since these are the cleanest possible integer cases)
- bias from integer > 1e-9
- Refusal (UNSTABLE, INSUFFICIENT_DATA, etc.) for trivial monomials

If REGULAR_INTEGER fires here, the cell is real. If it doesn't fire even on
pure x^n, the cell is calculus-designed-but-unreachable, which is significant
content about the calculus itself.
"""
from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path("/home/william_lloydlt/projects/V4/Lloyd_Engine_V4")
sys.path.insert(0, str(ROOT / "src"))

from lloyd_v4.primitives.singular_alpha_jet_bundle import singular_alpha_jet_bundle


def make_sweep() -> list[float]:
    return [10.0 ** (-2.0 - (7.0 / 11.0) * i) for i in range(12)]


OBSERVABLES = [
    ("I1_linear",    lambda x: x,           1.0),
    ("I2_quadratic", lambda x: x * x,       2.0),
    ("I3_cubic",     lambda x: x * x * x,   3.0),
]


def main() -> None:
    h_values = make_sweep()
    eta = 1e-6
    x0 = 0.0

    print("=" * 130)
    print("REGULAR_INTEGER coverage probe — positive integer alpha via singular_alpha_jet_bundle")
    print("=" * 130)
    print(f"x0 = {x0}, h sweep: 12 points log-spaced from 1e-2 to 1e-9, eta = {eta}")
    print()

    results = []
    for label, func, alpha_true in OBSERVABLES:
        result = singular_alpha_jet_bundle(
            func=func,
            x0=x0,
            h_values=h_values,
            probe_id=f"regular_integer_{label}_001",
            function_label=label,
            eta=eta,
        )
        obs = result.value.observed_alpha
        bias = (obs - alpha_true) if obs is not None else None
        underlying = result.value.alpha_probe_observation
        std_err = underlying.standard_error if underlying is not None else None
        stability = underlying.alpha_stability_status.value if underlying is not None else "n/a"
        window_span = underlying.alpha_window_span if underlying is not None else None
        n_obs = underlying.n_observed if underlying is not None else 0
        n_in = underlying.n_input_observations if underlying is not None else 0
        inner = result.value.alpha_status.value if result.value.alpha_status is not None else "n/a"

        results.append({
            "label": label,
            "alpha_true": alpha_true,
            "obs": obs,
            "bias": bias,
            "std_err": std_err,
            "stability": stability,
            "window_span": window_span,
            "outer_status": result.status.value,
            "inner_status": inner,
            "selectable": result.validity.selectable,
            "advanceable": result.validity.advanceable,
            "n_obs": n_obs,
            "n_in": n_in,
        })

    # --- Headline ---
    print(f"{'observable':<14}  {'alpha_true':>10}  {'V4 obs_alpha':>22}  {'bias':>14}  "
          f"{'std_err':>14}  {'|bias/sigma|':>14}")
    print("-" * 110)
    for r in results:
        if r["bias"] is None:
            continue
        sig = abs(r["bias"] / r["std_err"]) if r["std_err"] and r["std_err"] > 0 else float("inf")
        print(f"{r['label']:<14}  {r['alpha_true']:>10.1f}  {r['obs']!r:>22}  "
              f"{r['bias']:>+14.3e}  {r['std_err']:>14.3e}  {sig:>14.2f}")

    # --- Status ---
    print()
    print(f"{'observable':<14}  {'outer status':>42}  {'inner alpha status':>30}  "
          f"{'selectable':>11}  {'advanceable':>12}  {'n_obs/n_in':>10}")
    print("-" * 130)
    for r in results:
        n_str = f"{r['n_obs']}/{r['n_in']}"
        print(f"{r['label']:<14}  {r['outer_status']:>42}  {r['inner_status']:>30}  "
              f"{str(r['selectable']):>11}  {str(r['advanceable']):>12}  {n_str:>10}")

    # --- Stability/window ---
    print()
    print(f"{'observable':<14}  {'stability':>12}  {'window_span':>14}")
    for r in results:
        ws = f"{r['window_span']:14.3e}" if r['window_span'] is not None else "      N/A     "
        print(f"{r['label']:<14}  {r['stability']:>12}  {ws}")

    # --- Verdict ---
    print()
    print("=" * 130)
    fired = sum(1 for r in results if r["inner_status"] == "alpha_regular_integer")
    print(f"REGULAR_INTEGER fired in {fired}/{len(results)} cases.")
    if fired == len(results):
        print("CELL CONFIRMED — alpha_regular_integer is reachable for pure integer-alpha monomials.")
    elif fired == 0:
        print("CELL UNREACHABLE — even pure monomials don't trip the integer classifier.")
    else:
        print(f"CELL PARTIALLY REACHED — {fired} of {len(results)} fired; investigate which alpha values qualify.")


if __name__ == "__main__":
    main()
