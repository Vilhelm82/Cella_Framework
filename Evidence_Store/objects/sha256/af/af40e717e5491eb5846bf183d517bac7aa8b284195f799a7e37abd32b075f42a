#!/usr/bin/env python3
"""
Investigation 1: Probing the Parity Trap (The 2^{-54} Guard Bit)

Fresh implementation. No reliance on old artifacts.

Goal:
- Sweep x_term across 0 (V_n crossing 1.0) inside the Sterbenz region.
- For Late F2: power + (x - 1)
- For Early F2: (power - 1) + x
- Use high-precision oracle (mpmath) as ground truth.
- Detect if a systematic 0.5 ULP artifact appears strictly on one side of x=0 (V_n < 1).
- Check for mirrored behavior on the other side for Early F2.
- This tests whether the "phase transition" is 2D (distance + parity of V_n vs 1).

Usage:
    PYTHONPATH=src python scratch/investigation1_parity_trap.py
"""

from __future__ import annotations
import numpy as np
import mpmath as mp

# High precision settings
mp.mp.dps = 80   # plenty for float64 analysis

ULP64 = 2.0 ** -52

def pure_algebraic_late_f2(x: float) -> float:
    """Late reassociation: power + (x - 1)"""
    direct = 1.0 - x
    r = np.sqrt(direct)
    power = r * r
    return power + (x - 1.0)

def pure_algebraic_early_f2(x: float) -> float:
    """Early form used as standard F2"""
    direct = 1.0 - x
    r = np.sqrt(direct)
    power = r * r
    return (power - 1.0) + x

def exact_residual(x: mp.mpf) -> mp.mpf:
    """
    Mathematically exact value of the identity.
    For pure algebraic: power should equal direct = 1 - x
    So residual should be exactly 0.
    """
    return mp.mpf(0)

def analyze_sweep(x_values: np.ndarray) -> dict:
    results = {
        "x": [],
        "v_n": [],                    # power in float64
        "v_n_lt_1": [],               # boolean: V_n < 1.0
        "late_float": [],
        "early_float": [],
        "late_error": [],             # late - exact (using mpmath truth)
        "early_error": [],
        "late_error_ulp": [],         # error normalized by ulp of result
        "early_error_ulp": [],
    }

    for x in x_values:
        x_mp = mp.mpf(x)

        # Float64 computations
        late_f = pure_algebraic_late_f2(x)
        early_f = pure_algebraic_early_f2(x)

        # V_n in float64
        direct = 1.0 - x
        r = np.sqrt(direct)
        v_n = r * r

        # High precision truth for the residual
        # Late F2 mathematically equals 0
        # We compute the "true" late value at high precision and see float error
        true_late = mp.mpf(0)   # by construction of the identity

        # But to be rigorous, compute the high-prec version of late path
        # (though for this identity it's exactly 0)
        late_error = late_f - 0.0
        early_error = early_f - 0.0

        # Normalize error by ulp of the result scale
        # The result lives at scale ~|x| near 0
        scale = max(abs(late_f), abs(early_f), 2.0**-1022)
        ulp_result = np.ldexp(1.0, np.frexp(scale)[1] - 52)

        late_error_ulp = late_error / ulp_result if ulp_result > 0 else 0.0
        early_error_ulp = early_error / ulp_result if ulp_result > 0 else 0.0

        results["x"].append(x)
        results["v_n"].append(v_n)
        results["v_n_lt_1"].append(v_n < 1.0)
        results["late_float"].append(late_f)
        results["early_float"].append(early_f)
        results["late_error"].append(late_error)
        results["early_error"].append(early_error)
        results["late_error_ulp"].append(late_error_ulp)
        results["early_error_ulp"].append(early_error_ulp)

    return results

def main():
    print("Investigation 1: Probing the Parity Trap")
    print("=" * 70)
    print("Sweep across x=0 (V_n crossing 1.0) inside Sterbenz region (x <= 0.5)")
    print("Using mpmath dps=80 as oracle.")
    print()

    # Dense sweep around x=0, well inside Sterbenz (x<=0.5)
    # Focus on the transition region
    x_neg = np.linspace(-0.01, -1e-8, 5000)
    x_pos = np.linspace(1e-8, 0.01, 5000)
    x_values = np.concatenate([x_neg, x_pos])

    data = analyze_sweep(x_values)

    # Find the transition point
    v_n_lt1 = np.array(data["v_n_lt_1"])
    late_err_ulp = np.array(data["late_error_ulp"])
    early_err_ulp = np.array(data["early_error_ulp"])

    # Look for systematic 0.5 ulp bias on one side
    pos_mask = v_n_lt1
    neg_mask = ~v_n_lt1

    print("Late F2 error (in ULPs of result):")
    print(f"  On V_n < 1 side (positive x):  mean abs = {np.mean(np.abs(late_err_ulp[pos_mask])):.6f}")
    print(f"  On V_n > 1 side (negative x):  mean abs = {np.mean(np.abs(late_err_ulp[neg_mask])):.6f}")

    print("\nEarly F2 error (in ULPs of result):")
    print(f"  On V_n < 1 side (positive x):  mean abs = {np.mean(np.abs(early_err_ulp[pos_mask])):.6f}")
    print(f"  On V_n > 1 side (negative x):  mean abs = {np.mean(np.abs(early_err_ulp[neg_mask])):.6f}")

    # Look for exact 0.5 ULP clustering
    def count_near_half_ulp(errors_ulp, tol=0.05):
        half = 0.5
        return np.sum(np.abs(np.abs(errors_ulp) - half) < tol)

    print("\nPoints with |error| very close to 0.5 ULP (Late F2):")
    print(f"  Positive x (V_n<1): {count_near_half_ulp(late_err_ulp[pos_mask])} / {np.sum(pos_mask)}")
    print(f"  Negative x (V_n>1): {count_near_half_ulp(late_err_ulp[neg_mask])} / {np.sum(neg_mask)}")

    print("\nPoints with |error| very close to 0.5 ULP (Early F2):")
    print(f"  Positive x (V_n<1): {count_near_half_ulp(early_err_ulp[pos_mask])} / {np.sum(pos_mask)}")
    print(f"  Negative x (V_n>1): {count_near_half_ulp(early_err_ulp[neg_mask])} / {np.sum(neg_mask)}")

    # Save detailed data for further analysis
    np.savez_compressed(
        "scratch/investigation1_parity_trap_results.npz",
        x=np.array(data["x"]),
        v_n=np.array(data["v_n"]),
        v_n_lt_1=np.array(data["v_n_lt_1"]),
        late_error_ulp=late_err_ulp,
        early_error_ulp=early_err_ulp,
    )
    print("\nDetailed results saved to scratch/investigation1_parity_trap_results.npz")

    # Simple conclusion
    late_pos = late_err_ulp[pos_mask]
    late_neg = late_err_ulp[neg_mask]

    if np.mean(np.abs(late_pos)) > 2 * np.mean(np.abs(late_neg)):
        print("\n>>> Observation: Late F2 shows significantly larger error on V_n < 1 side.")
    elif np.mean(np.abs(late_neg)) > 2 * np.mean(np.abs(late_pos)):
        print("\n>>> Observation: Late F2 shows significantly larger error on V_n > 1 side.")
    else:
        print("\n>>> Observation: No strong one-sided bias detected for Late F2 in this sweep.")

if __name__ == "__main__":
    main()
