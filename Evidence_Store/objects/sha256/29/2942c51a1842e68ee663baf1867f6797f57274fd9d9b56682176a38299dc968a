def _default_F2_F4_config() -> DualArmConfig:
    return DualArmConfig(
        armW_channel="F2_float64",
        armN_channel="F4_float64",
        armW_route_id="sr_four_form_F2",
        armN_route_id="sr_four_form_F4",
        armW_route_kind="production",
        armN_route_kind="production",
        activation_rule="armW_falloff",
        selection_rule="predeclared_priority",
        same_route_control=False,
        label="hardened_F2_wide_F4_microscope",
    )


def main() -> None:
    parser = argparse.ArgumentParser(description="Hardened dual-arm probe (V1).")
    parser.add_argument("--armW", default="F2_float64", help="ARM-W channel")
    parser.add_argument("--armN", default="F4_float64", help="ARM-N channel")
    parser.add_argument("--output", default=str(ARTIFACT))
    parser.add_argument(
        "--same-route-control",
        action="store_true",
        help="Opt into a zero-separation control fixture (same channel on both arms)",
    )
    parser.add_argument(
        "--armW-route-kind",
        default="production",
        choices=sorted(ALLOWED_ROUTE_KINDS),
    )
    parser.add_argument(
        "--armN-route-kind",
        default="production",
        choices=sorted(ALLOWED_ROUTE_KINDS),
    )
    parser.add_argument(
        "--label",
        default="hardened_F2_wide_F4_microscope",
    )
    args = parser.parse_args()

    cfg = DualArmConfig(
        armW_channel=args.armW,
        armN_channel=args.armN,
        armW_route_id=f"sr_four_form_{args.armW.removesuffix('_float64')}",
        armN_route_id=f"sr_four_form_{args.armN.removesuffix('_float64')}",
        armW_route_kind=args.armW_route_kind,
        armN_route_kind=args.armN_route_kind,
        activation_rule="armW_falloff",
        selection_rule="predeclared_priority",
        same_route_control=args.same_route_control,
        label=args.label,
    )

    probe = HardenedDualArmProbe(cfg)
    data = probe.run()
    path = write_artifact(data, Path(args.output))

    print(f"hardened-v1 artifact written to {path}")
    print(f"  ARM-W channel: {args.armW}")
    print(f"  ARM-N channel: {args.armN}")
    print(f"  diagnostic_route_present: {data['diagnostic_route_present']}")
    print(f"  hardened_outcome: {data['headline']['hardened_outcome']}")
    print(f"  resolved_count: {data['headline']['resolved_count']}")
    print(f"  legacy_v11_outcome: {data['headline']['legacy_v11_outcome']}")
    print(
        f"  underpromotion_breakdown: "
        f"{json.dumps(data['headline']['underpromotion_breakdown'], sort_keys=True)}"
    )
    print(f"  validity: {json.dumps(data['validity'], sort_keys=True)}")


if __name__ == "__main__":
    main()
