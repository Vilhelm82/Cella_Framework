from __future__ import annotations

import json
import sys
from pathlib import Path
from typing import Callable


ROOT = Path(__file__).resolve().parents[3]
sys.path.insert(0, str(ROOT / "src"))

from lloyd_v4.core.serialization import to_json_safe
from lloyd_v4.core.status import AlphaProbeStatus, SweepSignatureStatus
from lloyd_v4.primitives import (
    directional_alpha_probe,
    sweep_signature_probe,  # for standalone cross-check if needed
)


OUT_DIR = Path(__file__).resolve().parent
F_VALUES = tuple(10.0 ** (-1.0 + (-8.0 / 7.0) * index) for index in range(8))
ETA = 3e-7


def f1(r: float, b: float, m: float) -> float:
    return b * (r - 2.0 * m) - r**3


def f2(r: float, b: float, m: float) -> float:
    return b * r - 3.0 * r**3


def naive_observable(form: Callable[[float, float, float], float], direction: tuple[float, float, float]):
    point = (3.0, 27.0, 1.0)

    def observable(f: float) -> float:
        return form(
            point[0] + f * direction[0],
            point[1] + f * direction[1],
            point[2] + f * direction[2],
        )

    return observable


CASES = (
    ("stable", "F1_along_r", lambda f: -9.0 * f**2 - f**3, AlphaProbeStatus.ALPHA_FRACTIONAL_BRANCH, SweepSignatureStatus.SWEEP_SIGNATURE_CLEAN),
    ("stable", "F1_along_B", lambda f: f, AlphaProbeStatus.ALPHA_FRACTIONAL_BRANCH, SweepSignatureStatus.SWEEP_SIGNATURE_CLEAN),
    ("stable", "F1_along_M", lambda f: -54.0 * f, AlphaProbeStatus.ALPHA_FRACTIONAL_BRANCH, SweepSignatureStatus.SWEEP_SIGNATURE_CLEAN),
    ("stable", "F2_along_r", lambda f: -54.0 * f - 27.0 * f**2 - 3.0 * f**3, AlphaProbeStatus.ALPHA_FRACTIONAL_BRANCH, SweepSignatureStatus.SWEEP_SIGNATURE_CLEAN),
    ("stable", "F2_along_B", lambda f: 3.0 * f, AlphaProbeStatus.ALPHA_FRACTIONAL_BRANCH, SweepSignatureStatus.SWEEP_SIGNATURE_CLEAN),
    ("stable", "F2_along_M", lambda f: 0.0, AlphaProbeStatus.ALPHA_DOMAIN_REFUSED, SweepSignatureStatus.SWEEP_SIGNATURE_DEGENERATE_INPUT),
    ("stable", "F1_along_tangent", lambda f: -27.0 * f**2 - 27.0 * f**3, AlphaProbeStatus.ALPHA_FRACTIONAL_BRANCH, SweepSignatureStatus.SWEEP_SIGNATURE_CLEAN),
    ("stable", "F2_along_tangent", lambda f: -81.0 * f**2 - 81.0 * f**3, AlphaProbeStatus.ALPHA_FRACTIONAL_BRANCH, SweepSignatureStatus.SWEEP_SIGNATURE_CLEAN),
    ("naive", "F1_along_r", naive_observable(f1, (1.0, 0.0, 0.0)), AlphaProbeStatus.ALPHA_UNSTABLE_WINDOW, SweepSignatureStatus.SWEEP_SIGNATURE_CANCELLATION_DOMINATED),
    ("naive", "F1_along_B", naive_observable(f1, (0.0, 1.0, 0.0)), AlphaProbeStatus.ALPHA_UNSTABLE_WINDOW, SweepSignatureStatus.SWEEP_SIGNATURE_CLEAN),
    ("naive", "F1_along_M", naive_observable(f1, (0.0, 0.0, 1.0)), AlphaProbeStatus.ALPHA_INSUFFICIENT_DATA, SweepSignatureStatus.SWEEP_SIGNATURE_CLEAN),
    ("naive", "F2_along_r", naive_observable(f2, (1.0, 0.0, 0.0)), AlphaProbeStatus.ALPHA_FRACTIONAL_BRANCH, SweepSignatureStatus.SWEEP_SIGNATURE_CLEAN),
    ("naive", "F2_along_B", naive_observable(f2, (0.0, 1.0, 0.0)), AlphaProbeStatus.ALPHA_FRACTIONAL_BRANCH, SweepSignatureStatus.SWEEP_SIGNATURE_CLEAN),
    ("naive", "F2_along_M", naive_observable(f2, (0.0, 0.0, 1.0)), AlphaProbeStatus.ALPHA_DOMAIN_REFUSED, SweepSignatureStatus.SWEEP_SIGNATURE_DEGENERATE_INPUT),
    ("naive", "F1_along_tangent", naive_observable(f1, (3.0, 54.0, 1.0)), AlphaProbeStatus.ALPHA_CANCELLATION_DOMINATED, SweepSignatureStatus.SWEEP_SIGNATURE_CANCELLATION_DOMINATED),
    ("naive", "F2_along_tangent", naive_observable(f2, (3.0, 54.0, 1.0)), AlphaProbeStatus.ALPHA_CANCELLATION_DOMINATED, SweepSignatureStatus.SWEEP_SIGNATURE_CANCELLATION_DOMINATED),
)


def main() -> None:
    records = []
    for form_kind, label, observable, expected_alpha, expected_sweep in CASES:
        probe_id = f"{form_kind}_{label}"
        alpha_result = directional_alpha_probe(
            observable,
            F_VALUES,
            probe_id=probe_id,
            function_label=probe_id,
            eta=ETA,
            companion_sweep_signature=True,
        )
        companion = alpha_result.value
        sweep_status = companion.companion_sweep_signature_status
        records.append(
            {
                "case": probe_id,
                "form_kind": form_kind,
                "label": label,
                "alpha_status": alpha_result.status.value,
                "expected_alpha": expected_alpha.value,
                "alpha_match": alpha_result.status is expected_alpha,
                "sweep_companion_status": sweep_status.value if sweep_status else None,
                "expected_sweep": expected_sweep.value,
                "sweep_match": sweep_status is expected_sweep if sweep_status else False,
                "alpha_value": alpha_result.value.to_json_safe(),
                "companion_sweep_value": companion.companion_sweep_signature_observation.to_json_safe() if companion.companion_sweep_signature_observation else None,
                "alpha_result": to_json_safe(alpha_result),
            }
        )

    payload = {
        "calibration": "task036_alpha_probe_sweep_signature_companion",
        "f_values": list(F_VALUES),
        "eta": ETA,
        "records": records,
        "notes": "Joint run with companion_sweep_signature=True on the 16 GR photon-sphere cases from task035. Patterns asserted in acceptance criteria 8.",
    }
    (OUT_DIR / "joint_observations.json").write_text(
        json.dumps(payload, indent=2, sort_keys=True, allow_nan=False) + "\n",
        encoding="utf-8",
    )
    (OUT_DIR / "joint_observations.md").write_text(_markdown(records), encoding="utf-8")
    print(f"wrote {len(records)} joint records to {OUT_DIR}")


def _markdown(records: list[dict[str, object]]) -> str:
    lines = [
        "# Task 036 Alpha + Sweep Signature Companion Joint Calibration (16 GR Photon-Sphere Cases)",
        "",
        f"Sweep: {len(F_VALUES)} log-spaced f-values from {F_VALUES[0]:.1e} to {F_VALUES[-1]:.1e}; eta = {ETA:.1e}.",
        "All runs used `companion_sweep_signature=True`.",
        "",
        "Canonical patterns exercised (see STATUS_CALCULUS.md and acceptance criteria 8):",
        "",
        "| Case | Alpha Status | Companion Sweep Status | Pattern |",
        "|---|---|---|---|",
    ]
    for rec in records:
        case = rec["case"]
        a = rec["alpha_status"]
        s = rec["sweep_companion_status"]
        lines.append(f"| {case} | {a} | {s} | see joint_observations.json |")
    lines.append("")
    lines.append("Full structured data in joint_observations.json.")
    return "\n".join(lines) + "\n"


if __name__ == "__main__":
    main()
