"""Extended calibration: symbolic analyzer v2 + Kerr photon + synthetics.

Adds ACOS and COS to the DSL (needed for Kerr photon sphere via
r_ph = 2*(1 + cos((2/3) * acos(-a)))) and runs four additional
calibration cases beyond the ISCO set to verify the v2 analyzer
generalises:

  1. Kerr photon sphere: r_ph(1-d) - 1 ~ (2*sqrt(6)/3) * sqrt(d)
                         expected: STERBENZ_SAFE_BENIGN, signal exp 1/2
  2. Pure power law: eps**0.5 (no subtractions)
                     expected: NO subtractions detected, NO crossing
  3. Synthetic catastrophic: (1+eps) - 1 = eps
                            expected: STERBENZ_SAFE_CATASTROPHIC, crossing ~ eps_machine
  4. Synthetic clean Sterbenz: (1 + sqrt(eps)) - 1 = sqrt(eps)
                              expected: STERBENZ_SAFE_BENIGN, crossing ~ eps_machine^2

Reuses the v2 core via import; this script only defines the new DSL
extensions and the four new observables.
"""

from __future__ import annotations

import math
import sys
from dataclasses import dataclass, replace
from enum import Enum
from fractions import Fraction
from pathlib import Path

# Make v2 importable
sys.path.insert(0, str(Path(__file__).parent))

from symbolic_analyzer_v2 import (
    Variable, Constant, BinaryOp, UnaryOp, BinaryOpKind, UnaryOpKind,
    add, sub, mul, div, neg, sqrtN, _wrap,
    evaluate_node as v2_evaluate_node,
    sample_profile as v2_sample_profile,
    classify_subtraction as v2_classify_subtraction,
    walk_and_classify as v2_walk_and_classify,
    analyze_expression as v2_analyze_expression,
    CancellationPattern, CancellationSite, PredictedBurdenVector,
    _round_to_clean_fraction,
)


# ============================================================================
# DSL extension: ACOS and COS as additional UnaryOpKind cells
#
# Rather than monkey-patch the v2 enum, we extend by defining new node
# wrappers that the evaluator handles via a thin polymorphic dispatcher.
# This keeps the v2 module clean and limits the calibration extension to
# this file.
# ============================================================================

class ExtendedUnaryOpKind(Enum):
    ACOS = "acos"
    COS = "cos"


@dataclass(frozen=True)
class ExtendedUnaryOp:
    op: ExtendedUnaryOpKind
    operand: object  # Node | ExtendedUnaryOp


def acos(a) -> ExtendedUnaryOp:
    return ExtendedUnaryOp(ExtendedUnaryOpKind.ACOS, _wrap(a))


def cos(a) -> ExtendedUnaryOp:
    return ExtendedUnaryOp(ExtendedUnaryOpKind.COS, _wrap(a))


def evaluate_extended(node, env: dict[str, float]) -> float:
    """Evaluator that handles both v2 nodes and ExtendedUnaryOp."""
    if isinstance(node, ExtendedUnaryOp):
        v = evaluate_extended(node.operand, env)
        if node.op == ExtendedUnaryOpKind.ACOS:
            if v < -1.0 or v > 1.0:
                return float("nan")
            return math.acos(v)
        if node.op == ExtendedUnaryOpKind.COS:
            return math.cos(v)
    if isinstance(node, BinaryOp):
        l = evaluate_extended(node.left, env)
        r = evaluate_extended(node.right, env)
        if node.op == BinaryOpKind.ADD: return l + r
        if node.op == BinaryOpKind.SUB: return l - r
        if node.op == BinaryOpKind.MUL: return l * r
        if node.op == BinaryOpKind.DIV: return l / r
    if isinstance(node, UnaryOp):
        v = evaluate_extended(node.operand, env)
        if node.op == UnaryOpKind.SQRT:
            if v < 0:
                return float("nan")
            return math.sqrt(v)
        if node.op == UnaryOpKind.NEG:
            return -v
    if isinstance(node, Constant):
        return node.value
    if isinstance(node, Variable):
        return env[node.name]
    raise TypeError(f"unknown node type {type(node).__name__}")


# Re-implement sample_profile + classify with extended evaluator
# (small wrapper that swaps v2's evaluate_node for evaluate_extended)

@dataclass(frozen=True)
class SampledProfileExt:
    constant_part: float
    perturbation_exponent: Fraction
    perturbation_coefficient: float
    samples: tuple[tuple[float, float], ...]
    is_pure_perturbation: bool


def sample_profile_ext(node, sweep_var: Variable, n_samples: int = 5) -> SampledProfileExt:
    lo, hi = sweep_var.sweep_range_low, sweep_var.sweep_range_high
    log_lo, log_hi = math.log10(lo), math.log10(hi)
    eps_values = sorted([10.0 ** (log_lo + (log_hi - log_lo) * i / (n_samples - 1))
                         for i in range(n_samples)])

    samples = []
    for eps in eps_values:
        try:
            v = evaluate_extended(node, {sweep_var.name: eps})
            if math.isfinite(v):
                samples.append((eps, v))
        except (ValueError, ZeroDivisionError, OverflowError):
            continue

    if len(samples) < 3:
        return SampledProfileExt(0.0, Fraction(0), 0.0, tuple(samples), True)

    f_smallest = samples[0][1]
    f_largest = samples[-1][1]
    eps_smallest = samples[0][0]

    # First-pass is_pure check: do values shrink toward zero as sweep -> 0?
    is_pure = (
        abs(f_smallest) < 1e-9
        or (abs(f_largest) > 0 and abs(f_smallest) / max(abs(f_largest), 1e-300) < 1e-3)
    )

    if is_pure:
        constant_v0 = 0.0
        residuals = list(samples)
    else:
        constant_v0 = f_smallest
        residuals = [(eps, v - constant_v0) for (eps, v) in samples if abs(v - constant_v0) > 1e-300]

    if len(residuals) < 2:
        # Constant-only or insufficient data
        return SampledProfileExt(constant_v0, Fraction(0), 0.0, tuple(samples), is_pure)

    log_eps = [math.log(e) for (e, r) in residuals if abs(r) > 1e-300]
    log_r = [math.log(abs(r)) for (e, r) in residuals if abs(r) > 1e-300]
    if len(log_eps) < 2:
        return SampledProfileExt(constant_v0, Fraction(0), 0.0, tuple(samples), is_pure)

    n = len(log_eps)
    mean_x = sum(log_eps) / n
    mean_y = sum(log_r) / n
    num = sum((log_eps[i] - mean_x) * (log_r[i] - mean_y) for i in range(n))
    den = sum((log_eps[i] - mean_x) ** 2 for i in range(n))
    slope = num / den if den > 0 else 0.0
    intercept = mean_y - slope * mean_x
    coef = math.exp(intercept)
    fitted_exp = _round_to_clean_fraction(slope)

    # Extrapolate to refine constant: subtract the fitted perturbation at
    # eps_smallest from f_smallest to estimate the limit as eps -> 0.
    if not is_pure and fitted_exp > 0:
        perturbation_at_smallest = coef * (eps_smallest ** float(fitted_exp))
        # The sign matters: f_smallest = constant + sign * perturbation
        # We assume sign matches the sign of (f_smallest - f_largest) / (eps_smallest - eps_largest)
        # but for the simple case here, just subtract the fitted contribution.
        # If residuals[0] was positive, perturbation pulled f_smallest above constant.
        first_residual_sign = 1.0 if residuals[0][1] >= 0 else -1.0
        constant_fitted = constant_v0 - first_residual_sign * perturbation_at_smallest
    else:
        constant_fitted = constant_v0

    return SampledProfileExt(
        constant_part=constant_fitted,
        perturbation_exponent=fitted_exp,
        perturbation_coefficient=coef,
        samples=tuple(samples),
        is_pure_perturbation=is_pure,
    )


def _structural_equal_ext(a, b) -> bool:
    if type(a) != type(b):
        return False
    if isinstance(a, Constant):
        return a.value == b.value
    if isinstance(a, Variable):
        return a.name == b.name
    if isinstance(a, BinaryOp):
        return a.op == b.op and _structural_equal_ext(a.left, b.left) and _structural_equal_ext(a.right, b.right)
    if isinstance(a, UnaryOp):
        return a.op == b.op and _structural_equal_ext(a.operand, b.operand)
    if isinstance(a, ExtendedUnaryOp):
        return a.op == b.op and _structural_equal_ext(a.operand, b.operand)
    return False


def _predicted_crossing_eps(C, p, coef):
    if p <= 0 or coef <= 0:
        return None
    EPS_MACHINE = 2.22e-16
    return (EPS_MACHINE * C / coef) ** (1.0 / float(p))


def classify_subtraction_ext(node: BinaryOp, sweep_var: Variable, path: str = "") -> CancellationSite:
    assert node.op == BinaryOpKind.SUB
    left, right = node.left, node.right
    if _structural_equal_ext(left, right):
        return CancellationSite(
            pattern=CancellationPattern.SELF_CANCELLATION,
            signal_exponent=Fraction(0), signal_coefficient=0.0,
            constant_magnitude=0.0, predicted_crossing_eps=None,
            description="X - X", location_hint=path,
        )
    pl = sample_profile_ext(left, sweep_var)
    pr = sample_profile_ext(right, sweep_var)
    cl, cr = pl.constant_part, pr.constant_part
    same_const = (
        not pl.is_pure_perturbation and not pr.is_pure_perturbation
        and abs(cl - cr) < 1e-3 * max(abs(cl), abs(cr), 1.0)
    )
    if same_const:
        pd = sample_profile_ext(node, sweep_var)
        sig_exp = pd.perturbation_exponent
        sig_coef = pd.perturbation_coefficient
        C = max(abs(cl), abs(cr))
        cross = _predicted_crossing_eps(C, sig_exp, sig_coef)
        if sig_exp >= 1:
            pat = CancellationPattern.STERBENZ_SAFE_CATASTROPHIC
        elif sig_exp > 0:
            pat = CancellationPattern.STERBENZ_SAFE_BENIGN
        else:
            pat = CancellationPattern.UNRECOGNISED
        desc = (
            f"(C+p) - (C+q) revealed by sample-eval; C ~ {C:.4g}, "
            f"signal ~ {sig_coef:.3g} * eps^{sig_exp}; "
            f"crosses precision floor at eps ~ {cross:.2e}"
            if cross else
            f"(C+p) - (C+q) with C ~ {C:.4g}, no crossing in range"
        )
        return CancellationSite(
            pattern=pat, signal_exponent=sig_exp, signal_coefficient=sig_coef,
            constant_magnitude=C, predicted_crossing_eps=cross,
            description=desc, location_hint=path,
        )
    return CancellationSite(
        pattern=CancellationPattern.NO_SUBTRACTION,
        signal_exponent=Fraction(0), signal_coefficient=0.0,
        constant_magnitude=0.0, predicted_crossing_eps=None,
        description=f"L ~ {cl:.3g}, R ~ {cr:.3g}; no cancellation",
        location_hint=path,
    )


def walk_ext(node, sweep_var: Variable, path: str = "root"):
    sites = []
    if isinstance(node, BinaryOp):
        if node.op == BinaryOpKind.SUB:
            sites.append(classify_subtraction_ext(node, sweep_var, path))
        sites.extend(walk_ext(node.left, sweep_var, f"{path}.L"))
        sites.extend(walk_ext(node.right, sweep_var, f"{path}.R"))
    elif isinstance(node, (UnaryOp, ExtendedUnaryOp)):
        sites.extend(walk_ext(node.operand, sweep_var, f"{path}.op"))
    return sites


def analyze_ext(root, sweep_var: Variable, label: str) -> PredictedBurdenVector:
    sites = walk_ext(root, sweep_var)
    n_cat = sum(1 for s in sites if s.pattern == CancellationPattern.STERBENZ_SAFE_CATASTROPHIC)
    n_safe = sum(1 for s in sites if s.pattern == CancellationPattern.STERBENZ_SAFE_BENIGN)
    n_self = sum(1 for s in sites if s.pattern == CancellationPattern.SELF_CANCELLATION)
    n_benign = sum(1 for s in sites if s.pattern == CancellationPattern.NO_SUBTRACTION)
    n_unrec = sum(1 for s in sites if s.pattern == CancellationPattern.UNRECOGNISED)
    cross = [s.predicted_crossing_eps for s in sites if s.predicted_crossing_eps is not None]
    overall = max(cross) if cross else None
    return PredictedBurdenVector(
        expression_label=label, n_catastrophic=n_cat, n_sterbenz_safe_benign=n_safe,
        n_self_cancellations=n_self, n_benign_subtractions=n_benign, n_unrecognised=n_unrec,
        predicted_precision_crossing_epsilon=overall, cancellation_sites=tuple(sites),
    )


# ============================================================================
# Extended calibration set
# ============================================================================

DELTA = Variable("delta", sweep_range_low=1e-10, sweep_range_high=1e-4)
EPS_GENERIC = Variable("eps", sweep_range_low=1e-10, sweep_range_high=1e-4)


# 1. Kerr photon sphere: r_ph(1-delta) - 1
def build_kerr_photon() -> object:
    """r_ph(a) = 2 * (1 + cos((2/3) * acos(-a))).
    Probe r_ph(1-delta) - 1 with delta -> 0.  Expected α=1/2, coef 2*sqrt(6)/3 ~ 1.633."""
    a_node = sub(1.0, DELTA)                                # a = 1 - delta
    inner = mul(Constant(2.0 / 3.0), acos(neg(a_node)))     # (2/3) * arccos(-a)
    r_ph = mul(Constant(2.0), add(1.0, cos(inner)))         # 2 * (1 + cos(...))
    return sub(r_ph, 1.0)


# 2. Pure power law: eps^(1/2) (no subtractions; built via sqrt)
def build_pure_sqrt() -> object:
    return sqrtN(EPS_GENERIC)


# 3. Synthetic catastrophic: (1 + eps) - 1
def build_synth_catastrophic() -> object:
    return sub(add(1.0, EPS_GENERIC), 1.0)


# 4. Synthetic clean Sterbenz: (1 + sqrt(eps)) - 1
def build_synth_clean_sterbenz() -> object:
    return sub(add(1.0, sqrtN(EPS_GENERIC)), 1.0)


# ============================================================================
# Demo
# ============================================================================

def fmt_eps(v):
    return f"{v:.2e}" if v is not None else "never"


def main():
    print("=" * 100)
    print("Extended calibration: symbolic analyzer v2 beyond ISCO")
    print("=" * 100)

    cases = [
        ("kerr_photon_pro      ", build_kerr_photon(),         DELTA,        "1/2 signal, coef ~ 1.633"),
        ("pure_sqrt            ", build_pure_sqrt(),           EPS_GENERIC,  "no subtractions, pure power"),
        ("synth_catastrophic   ", build_synth_catastrophic(),  EPS_GENERIC,  "(1+eps) - 1, signal O(eps), crossing ~ 2.2e-16"),
        ("synth_clean_sterbenz ", build_synth_clean_sterbenz(),EPS_GENERIC,  "(1+sqrt(eps)) - 1, signal O(sqrt(eps))"),
    ]

    for label, expr, sweep, expected in cases:
        print(f"\n{label}  EXPECTED: {expected}")
        pred = analyze_ext(expr, sweep, label.strip())
        print(f"  catastrophic={pred.n_catastrophic}  sterbenz_safe={pred.n_sterbenz_safe_benign}  "
              f"benign={pred.n_benign_subtractions}  unrec={pred.n_unrecognised}")
        print(f"  predicted crossing: {fmt_eps(pred.predicted_precision_crossing_epsilon)}")
        for site in pred.cancellation_sites:
            print(f"    [{site.pattern.value}] {site.description}")


if __name__ == "__main__":
    main()
