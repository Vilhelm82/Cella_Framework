# DEMO  (small set)
# ===========================================================================
def hdr(s): print("\n=== " + s)

if __name__ == "__main__":
    hdr("1. A founder seats (a conscious root)")
    class MetricTensor(Primitive, founder=True):
        produces = "metric"
    print("   citizens:", Substrate.citizens())

    hdr("2. Primitives seat by consuming a parent (inheritance edge = the claim)")
    class RiemannCurvature(MetricTensor):
        produces = "riemann"
    class KG(RiemannCurvature):                 # K_G curvature, built up from bedrock
        produces = "gauss_curvature"
    print("   citizens:", Substrate.citizens())

    hdr("3. pi tries to seat -> catches air (orphan: no parent, not a founder)")
    try:
        class Pi(Primitive):
            produces = "ratio"
        print("   pi seated?!")
    except CatchesAir as e:
        print("   CATCHES AIR:", e)

    hdr("4. An undeclared dead-end -> catches air ('why are you here?')")
    try:
        class MysteryNode(MetricTensor):        # inherits a parent, but declares nothing of its own
            pass
        print("   seated?!")
    except CatchesAir as e:
        print("   CATCHES AIR:", e)

    hdr("5. The FORK: a needed parent isn't on the substrate yet")
    try:
        class GeodesicDev(RicciScalar):         # RicciScalar undefined -> Python itself screams
            produces = "deviation"
    except NameError as e:
        print("   CATCHES AIR (free, from Python):", e)
    print("   ...so build the missing parent from existing bedrock, then it seats:")
    class RicciScalar(RiemannCurvature):
        produces = "ricci"
    class GeodesicDev(RicciScalar):
        produces = "deviation"
    print("   citizens:", Substrate.citizens())
    print("   (every child above RicciScalar now inherits it for free.)")

    hdr("6. An artifact CLAIMS K_G by subclassing it, declared as a final value")
    class CurvatureFinding(KG):
        terminal = True
    print("   CurvatureFinding seated:", "CurvatureFinding" in Substrate.citizens())

    hdr("7. PROVEN gate: closure, not reproducibility (construction-time)")
    third = Fraction(1, 3)
    proven = Proven("c2_identity", third, lambda: Fraction(2, 6))     # exact -> closes
    print("   ", proven)
    try:
        Proven("c2_identity", third, lambda: 1 / 3)                  # float -> reproduces, can't close
        print("   measurement seated?!")
    except CatchesAir as e:
        print("   CATCHES AIR:", e)
