            "Lattice' (BACL) as the V4 reference name."
        ),
    }


# ---------------------------------------------------------------------------
# Run audit
# ---------------------------------------------------------------------------


def run_audit() -> dict:
    proof_samples = run_proof_samples()
    chain_results = {}
    for fmt in ["float64", "float32"]:
        for chain_name, chain_fn in CHAINS.items():
            key = f"{chain_name}__{fmt}"
            chain_results[key] = audit_chain(chain_name, chain_fn, fmt, n_pairs=500)
    c2_reduction = reduce_c2_to_BACL()
    lit = literature_audit()

    # Predictions
    BACL_S_holds_everywhere = all(
        r["BACL_S_holds"]
        for k, r in chain_results.items()
        if not k.startswith("C7_")  # C7 intentionally violates proviso; not a BACL-S test
    )
    sharpness_demonstrated = any(
        r["proviso_violated_non_integer_count"] > 0
        for k, r in chain_results.items()
        if k.startswith("C7_")
    )
    sharpness_fraction = max(
        r["proviso_violated_non_integer_count"] / max(r["n_pairs"], 1)
        for k, r in chain_results.items()
        if k.startswith("C7_")
    )

    predictions = {
        "P_BACL_1_proof_is_deductively_sound": all(
            "proof_failed" not in s for s in proof_samples
        ),
        "P_BACL_2_zero_violations_C1_through_C6": bool(BACL_S_holds_everywhere),
        "P_BACL_3_sharpness_geq_50pct": bool(sharpness_fraction >= 0.5),
        "P_BACL_4_float32_holds": all(
            r["BACL_S_holds"]
            for k, r in chain_results.items()
            if k.endswith("__float32") and not k.startswith("C7_")
        ),
        "P_BACL_5_c2_reduces_to_BACL": c2_reduction["reduction_valid"],
        "P_BACL_6_literature_audit_done": True,  # qualitative; covered in lit
    }

    failures = []
    if not predictions["P_BACL_2_zero_violations_C1_through_C6"]:
        failures.append("F_BACL_1")
    if not predictions["P_BACL_3_sharpness_geq_50pct"]:
        failures.append("F_BACL_2")
    if not predictions["P_BACL_4_float32_holds"]:
        failures.append("F_BACL_3")
    if not predictions["P_BACL_5_c2_reduces_to_BACL"]:
        failures.append("F_BACL_4")

    if not failures:
        verdict = "BACL_proven_and_promoted_to_V4_substrate_lemma_reference"
    else:
        verdict = "BACL_partial_see_failure_modes"

    return {
        "audit_name": "bacl_invariant_audit",
        "preregistry_path": "Build_Docs/Reports/bacl_invariant_audit/preregistry.md",
        "BACL_statement": (
            "For a, b in positive normal-range IEEE 754 binary floats with "
            "floor_binade(a) >= floor_binade(b), the real difference (a - b) "
            "is an integer multiple of ulp(b). Sharpness: the proviso is "
            "necessary in the sense that violating it admits non-integer "
            "differences for ~50%+ of lower-binade pairs."
        ),
        "proof_samples": proof_samples,
        "chain_results": chain_results,
        "c2_reduction": c2_reduction,
        "literature_audit": lit,
        "predictions": predictions,
        "failure_modes_observed": failures,
        "verdict": verdict,
        "diag_sharpness_fraction_max": sharpness_fraction,
        "diag_total_records": sum(r["n_pairs"] for r in chain_results.values()),
    }


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--output", default=str(ARTIFACT))
    args = parser.parse_args()
    REPORT_DIR.mkdir(parents=True, exist_ok=True)
    data = run_audit()
    Path(args.output).write_text(json.dumps(data, indent=2, sort_keys=True))
    print(f"bacl-invariant-audit artifact written to {args.output}")
    print(f"  verdict: {data['verdict']}")
    print(f"  failure_modes_observed: {data['failure_modes_observed']}")
    print(f"  predictions:")
    for k, v in data["predictions"].items():
        if isinstance(v, bool):
            marker = "✓" if v else "✗"
            print(f"    {marker} {k}")
    print()
    print(f"  Per-chain results:")
    for k, r in data["chain_results"].items():
        marker = "✓" if r["BACL_S_holds"] else "✗"
        kind = "(sharpness demo)" if "C7" in k else ""
        print(
            f"    {marker} {k:45} proviso_ok={r['proviso_satisfied_count']:4}/{r['n_pairs']}, "
            f"BACL_S_violations={r['proviso_satisfied_non_integer_BACL_S_violations']}, "
            f"sharpness_count={r['proviso_violated_non_integer_count']} {kind}"
        )
    print()
    print(f"  c2 reduction: {data['c2_reduction']['proviso_satisfied_count']}/{data['c2_reduction']['n_pairs']} satisfy proviso, "
          f"{data['c2_reduction']['c2_integer_count']}/{data['c2_reduction']['n_pairs']} produce integer c2. "
          f"Reduction valid: {data['c2_reduction']['reduction_valid']}")
    print()
    print(f"  Literature audit: {data['literature_audit']['honest_status']}")
    print(f"  Total records: {data['diag_total_records']}")


if __name__ == "__main__":
    main()
