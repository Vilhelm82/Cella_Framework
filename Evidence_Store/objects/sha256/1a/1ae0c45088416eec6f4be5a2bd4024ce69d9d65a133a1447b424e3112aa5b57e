# ---------------------------------------------------------------------------
# Binade helpers
# ---------------------------------------------------------------------------


def floor_binade(x: float) -> int:
    """Return floor(log2(|x|)) for nonzero finite x; the binade index k
    such that x ∈ [2^k, 2^(k+1)) (for positive x)."""
    if x == 0.0 or not math.isfinite(x):
        return -2000
    return math.frexp(abs(x))[1] - 1


def ulp_f64(x: float) -> float:
    """ULP via the ``typed_ulp`` substrate primitive (GAP-003, precision='float64').

    Migrated from inline IEEE 754 ULP helper as part of the DRY-003 substrate
    consolidation. Byte-compatible with the original on finite normal inputs.
    """
    return float(typed_ulp(x, precision="float64").value.ulp)


def ulp_f32(x: float) -> float:
    """ULP via the ``typed_ulp`` substrate primitive (GAP-003, precision='float32').

    Migrated from inline IEEE 754 ULP helper as part of the DRY-003 substrate
    consolidation. Byte-compatible with the original on finite normal inputs.
    """
    return float(typed_ulp(x, precision="float32").value.ulp)


# ---------------------------------------------------------------------------
# Symbolic proof of BACL-S (assertion-checked)
# ---------------------------------------------------------------------------


def proof_BACL_S(a: float, b: float, ulp_fn=ulp_f64) -> dict:
    """Walk through the proof of BACL-S for a specific pair (a, b)
    satisfying floor_binade(a) >= floor_binade(b).
    Returns the intermediate quantities and verification result.
    """
    assert a > 0 and b > 0, "BACL stated for positive normals"
    k_a = floor_binade(a)
    k_b = floor_binade(b)
    assert k_a >= k_b, f"Hypothesis violated: floor_binade({a})={k_a} < floor_binade({b})={k_b}"
    u_a = ulp_fn(a)
    u_b = ulp_fn(b)
    # By proof line 3: u_a / u_b = 2^(k_a - k_b) is a positive integer
    ratio = u_a / u_b
    assert ratio == 2 ** (k_a - k_b), f"ulp ratio incorrect: {ratio} != 2^{k_a - k_b}"
    # Line 4: a is integer multiple of ulp(b)
    a_in_ulp_b = a / u_b
    assert a_in_ulp_b == round(a_in_ulp_b), (
        f"a / ulp(b) not integer for binade-aligned pair: a={a}, ulp_b={u_b}, ratio={a_in_ulp_b}"
    )
    # Line 5: b is integer multiple of ulp(b) trivially
    b_in_ulp_b = b / u_b
    assert b_in_ulp_b == round(b_in_ulp_b), f"b / ulp(b) not integer: {b_in_ulp_b}"
    # Line 6: difference is integer multiple of ulp(b)
    diff_real = a - b
    diff_in_ulp_b = diff_real / u_b
    is_integer = abs(diff_in_ulp_b - round(diff_in_ulp_b)) < 1e-9
    return {
        "a": a,
        "b": b,
        "k_a": k_a,
        "k_b": k_b,
        "ulp_a": u_a,
        "ulp_b": u_b,
        "ulp_ratio_a_over_b": float(ratio),
        "a_in_ulp_b_units": float(a_in_ulp_b),
        "b_in_ulp_b_units": float(b_in_ulp_b),
        "diff_real": diff_real,
        "diff_in_ulp_b": float(diff_in_ulp_b),
        "diff_in_ulp_b_int": int(round(diff_in_ulp_b)),
        "is_integer_multiple_of_ulp_b": bool(is_integer),
    }


# ---------------------------------------------------------------------------
# Pair generators for each algebraic chain (C1..C7)
# ---------------------------------------------------------------------------


def chain_C1_sqrt_square(n_pairs: int = 500, format: str = "float64") -> list[tuple[float, float]]:
    """sqrt + square chain: a = round(sqrt(f) * sqrt(f)), b = f."""
    pairs = []
    if format == "float64":
        f_values = np.linspace(1e-3, 1.0 - 1e-3, n_pairs)
        for f in f_values:
            R = math.sqrt(float(f))
            V = R * R
            pairs.append((V, float(f)))
    elif format == "float32":
        f_values = np.linspace(1e-3, 1.0 - 1e-3, n_pairs)
        for f in f_values:
            f32 = float(np.float32(f))
            R32 = float(np.float32(math.sqrt(f32)))
            V32 = float(np.float32(R32 * R32))
            pairs.append((V32, f32))
    return pairs


def chain_C2_cbrt_cube(n_pairs: int = 500, format: str = "float64") -> list[tuple[float, float]]:
    """cbrt + cube chain: a = round(R*R*R), b = f. R = cbrt(f)."""
    pairs = []
    if format == "float64":
        f_values = np.linspace(1e-3, 1.0 - 1e-3, n_pairs)
        for f in f_values:
            R = float(np.cbrt(float(f)))
            V = R * R * R
            pairs.append((V, float(f)))
    elif format == "float32":
        f_values = np.linspace(1e-3, 1.0 - 1e-3, n_pairs)
        for f in f_values:
            f32 = float(np.float32(f))
            R32 = float(np.float32(np.cbrt(f32)))
            V32 = float(np.float32(R32 * R32))
            V32 = float(np.float32(V32 * R32))
            pairs.append((V32, f32))
    return pairs


def chain_C3_nextafter(n_pairs: int = 500, format: str = "float64") -> list[tuple[float, float]]:
    """Same-binade adjacent floats: a = nextafter(b, +inf), b varies."""
    pairs = []
    bases = np.linspace(0.1, 2.0, n_pairs)
    for b in bases:
        if format == "float32":
            b32 = float(np.float32(b))
            a32 = float(np.nextafter(np.float32(b), np.float32(np.inf)))
            pairs.append((a32, b32))
        else:
            a = math.nextafter(float(b), math.inf)
            pairs.append((a, float(b)))
    return pairs


def chain_C4_twosum_residual(n_pairs: int = 500, format: str = "float64") -> list[tuple[float, float]]:
    """TwoSum-style: pick a, b in same binade, compute s = a + b, residual.
    Pair is (s + r, s) — should satisfy BACL trivially.
    For sharpness comparison, we check (s, s + r) — residual is in lower binade
    of s, which would violate BACL if r ≠ 0 and not aligned.
    Here we report the "trivially BACL-satisfying" form.
    """
    pairs = []
    rng = np.random.default_rng(seed=42)
    for _ in range(n_pairs):
        b_val = float(rng.uniform(0.5, 1.0))
        a_val = float(rng.uniform(0.5, 1.0))
        # TwoSum
        s = a_val + b_val
        if format == "float32":
            s32 = float(np.float32(s))
            b32 = float(np.float32(b_val))
            pairs.append((s32, b32))
        else:
            pairs.append((s, b_val))
    return pairs


def chain_C5_FMA(n_pairs: int = 500, format: str = "float64") -> list[tuple[float, float]]:
    """FMA-based square: a = fma(R, R, 0) = R*R (in IEEE FMA semantics).
    For most platforms, this is the same as non-FMA R*R, but the rounding
    can differ. We use math.fma if available; else equivalent.

    For float32, math.fma operates at float64 precision (no separate
    float32 FMA in Python's math API), so we explicitly cast to float32
    after each operation. This makes C5 at float32 equivalent to C1 at
    float32 (no fused FMA semantics distinct from non-fused at float32
    in pure Python — true float32 FMA would require numpy.float32 with
    intrinsic FMA support, not in standard library).
    """
    pairs = []
    f_values = np.linspace(1e-3, 1.0 - 1e-3, n_pairs)
    if format == "float64":
        for f in f_values:
            f_val = float(f)
            R = math.sqrt(f_val)
            try:
                V = math.fma(R, R, 0.0)
            except AttributeError:
                V = R * R
            pairs.append((V, f_val))
    elif format == "float32":
        # Float32 path: cast everything explicitly to float32. No genuine
        # float32 FMA available in Python's math; equivalent to non-fused
        # multiply.
        for f in f_values:
            f32 = float(np.float32(f))
            R32 = float(np.float32(math.sqrt(f32)))
            V32 = float(np.float32(R32 * R32))
            pairs.append((V32, f32))
    return pairs


def chain_C6_arbitrary_same_binade(n_pairs: int = 500, format: str = "float64") -> list[tuple[float, float]]:
    """Random pairs in the same binade [0.5, 1.0)."""
    pairs = []
    rng = np.random.default_rng(seed=43)
    for _ in range(n_pairs):
        a = float(rng.uniform(0.5, 1.0))
        b = float(rng.uniform(0.5, 1.0))
        if format == "float32":
            a = float(np.float32(a))
            b = float(np.float32(b))
        pairs.append((a, b))
    return pairs


def chain_C7_lower_binade(n_pairs: int = 500, format: str = "float64") -> list[tuple[float, float]]:
    """Sharpness demo: a in lower binade than b. Pairs intentionally violate
    BACL's proviso to test that non-integer differences are reachable.
    """
    pairs = []
    rng = np.random.default_rng(seed=44)
    for _ in range(n_pairs):
        b = float(rng.uniform(0.5, 1.0))  # binade [0.5, 1)
        a = float(rng.uniform(0.25, 0.5))  # binade [0.25, 0.5) — lower
        if format == "float32":
            a = float(np.float32(a))
            b = float(np.float32(b))
        pairs.append((a, b))
    return pairs


CHAINS = {
    "C1_sqrt_square": chain_C1_sqrt_square,
    "C2_cbrt_cube": chain_C2_cbrt_cube,
    "C3_nextafter": chain_C3_nextafter,
    "C4_twosum_pair": chain_C4_twosum_residual,
    "C5_FMA": chain_C5_FMA,
    "C6_same_binade_random": chain_C6_arbitrary_same_binade,
    "C7_lower_binade_sharpness": chain_C7_lower_binade,
}


# ---------------------------------------------------------------------------
# Audit per chain × format
# ---------------------------------------------------------------------------


def audit_chain(chain_name: str, chain_fn, format: str, n_pairs: int = 500) -> dict:
    pairs = chain_fn(n_pairs=n_pairs, format=format)
    ulp_fn = ulp_f64 if format == "float64" else ulp_f32
    total = 0
    proviso_satisfied_count = 0
    integer_lattice_count = 0
    proviso_violated_integer = 0
    proviso_satisfied_non_integer = 0  # this is what BACL-S forbids
    proviso_violated_non_integer = 0
    violations = []
    sharpness_examples = []
    for a, b in pairs:
        if a <= 0 or b <= 0:
            continue
        total += 1
        k_a = floor_binade(a)
        k_b = floor_binade(b)
        u_b = ulp_fn(b)
        if u_b == 0:
            continue
        proviso_ok = k_a >= k_b
        if proviso_ok:
            proviso_satisfied_count += 1
        diff = a - b
        diff_in_ulp = diff / u_b
        is_int = abs(diff_in_ulp - round(diff_in_ulp)) < 1e-9
        if is_int:
            integer_lattice_count += 1
        # Classify
        if proviso_ok and is_int:
            pass  # BACL-S says this must happen
        elif proviso_ok and not is_int:
            proviso_satisfied_non_integer += 1
            if len(violations) < 10:
                violations.append({
                    "a": a, "b": b, "k_a": k_a, "k_b": k_b,
                    "diff": diff, "diff_in_ulp_b": diff_in_ulp,
                    "violation": "BACL-S says this must be integer",
                })
        elif not proviso_ok and is_int:
            proviso_violated_integer += 1
        else:
            proviso_violated_non_integer += 1
            if len(sharpness_examples) < 5:
                sharpness_examples.append({
                    "a": a, "b": b, "k_a": k_a, "k_b": k_b,
                    "diff": diff, "diff_in_ulp_b": diff_in_ulp,
                    "note": "sharpness example",
                })
    return {
        "chain": chain_name,
        "format": format,
        "n_pairs": total,
        "proviso_satisfied_count": proviso_satisfied_count,
        "integer_lattice_count": integer_lattice_count,
        "proviso_satisfied_non_integer_BACL_S_violations": proviso_satisfied_non_integer,
        "proviso_violated_integer_count": proviso_violated_integer,
        "proviso_violated_non_integer_count": proviso_violated_non_integer,
        "BACL_S_holds": proviso_satisfied_non_integer == 0,
        "first_violations": violations,
        "first_sharpness_examples": sharpness_examples,
    }


# ---------------------------------------------------------------------------
# Symbolic proof of BACL-S (sample run)
# ---------------------------------------------------------------------------


def run_proof_samples() -> list[dict]:
    samples = []
    # Verify the proof on a few concrete pairs.
    test_pairs = [
        (0.75, 0.5),  # same binade [0.5, 1.0)
        (1.0, 0.5),  # different binade, a upper-adjacent
        (1.5, 0.6),  # upper-adjacent
        (0.500000001, 0.5),  # near-equal
        (math.nextafter(1.0, math.inf), 1.0),  # adjacent floats
    ]
    for a, b in test_pairs:
        try:
            r = proof_BACL_S(a, b)
            samples.append(r)
        except AssertionError as e:
            samples.append({"a": a, "b": b, "proof_failed": str(e)})
    return samples


# ---------------------------------------------------------------------------
# Reduction: c2 theorem as BACL corollary
# ---------------------------------------------------------------------------


def reduce_c2_to_BACL(n_pairs: int = 200) -> dict:
    """Demonstrate that the c2 lattice theorem reduces to BACL applied
    to chain C1 under Conjecture C."""
    # Take SR fixture's sweep
    f_values = np.linspace(1e-3, 1.0 - 1e-3, n_pairs)
    results = []
    proviso_satisfied = 0
    c2_integer = 0
    for f in f_values:
        f_val = float(f)
        R = math.sqrt(f_val)
        V = R * R
        x_term = 1.0 - f_val  # this is what x_term would be
        c2 = V + (x_term - 1.0)
        u_b = ulp_f64(f_val)
        c2_in_ulp = c2 / u_b
        c2_is_int = abs(c2_in_ulp - round(c2_in_ulp)) < 1e-9
        proviso = floor_binade(V) >= floor_binade(f_val)
        if proviso:
            proviso_satisfied += 1
        if c2_is_int:
            c2_integer += 1
        results.append({
            "f": f_val,
            "V_2": V,
            "k_V": floor_binade(V),
            "k_f": floor_binade(f_val),
            "BACL_proviso_satisfied": proviso,
            "c2_level": c2_in_ulp,
            "c2_integer_lattice": c2_is_int,
        })
    return {
        "n_pairs": len(results),
        "proviso_satisfied_count": proviso_satisfied,
        "c2_integer_count": c2_integer,
        "reduction_valid": proviso_satisfied == c2_integer == len(results),
        "first_5_samples": results[:5],
    }


