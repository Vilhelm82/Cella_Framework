    "arbiter_ground_classification": {
      "definition": "Per rung r, the arbiter computes Delta_q_ulp(r) = |q_true(x_r + ulp(x_r)) - q_true(x_r)| (the exact 1-ulp input transfer of the quantity, instrument-free).",
      "phenomenon_dominated": "Delta_q_ulp(r) <= tol_fixture * |q_true(r)| (structure is resolvable by SOME float64 reading at this rung)",
      "substrate_dominated": "Delta_q_ulp(r) > |q_true(r)| (one ulp of input slews the quantity by more than itself - any float64 reading is rounding-dominated)",
      "indeterminate": "between the two bounds"
    },
    "per_rung_consistency": {
      "phenomenon_dominated": ["phenomenon"],
      "substrate_dominated": ["substrate", "format_precision_pinned"],
      "indeterminate": "excluded from the attribution-quality denominator"
    },
    "attribution_quality": "consistent_rungs / classified_rungs (classified = arbiter class is not indeterminate and arbiter self-consistent).",
    "format_precision_pinned_scoreboard_mapping": "Counts as substrate-family evidence at both rung level and campaign level (it declares a format-artefact regime). Recorded distinctly in all artefacts so the mapping is auditable.",
