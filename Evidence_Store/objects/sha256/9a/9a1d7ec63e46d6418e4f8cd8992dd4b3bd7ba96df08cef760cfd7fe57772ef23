      "substrate": "attribution_quality >= 0.9 AND P empty",
      "contaminated": "attribution_quality >= 0.9 AND P nonempty AND S nonempty inside the claim regime (the V3 claim as stated mixes resolvable structure with substrate-dominated readings)",
      "ambiguous": "anything else, including attribution_quality < 0.9 or arbiter_unresolved before the claim regime is reached"
    }
  },

