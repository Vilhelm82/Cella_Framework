"""Rounding dial, generated by the BACL + early-rounding-absorption process (Will's spec).

The forms are NOT a precomputed catalogue. They EMERGE from the constraint's own combination
structure: to compute the constraint  R^2 - 1 + c  (= 0 on the surface) you must combine its
three contributions {R^2, -1, +c}, and the only real choice is WHICH PAIR you combine first.
That choice IS the early-rounding-absorption decision (Task-031 / §2.3 Corollary-1):

  - combine the two constant-scale terms (-1, +c) FIRST  -> absorbs their rounding in the high
    binade, leaving a BACL-governed final cancellation  -> CLEANEST (the dial origin).
  - combine the cancellation (R^2 - 1) first              -> Sterbenz-exact at that op but
    globally worse (lands off the integer lattice).
  - combine the sum (R^2 + c) first                       -> a third absorption order.

The dial coordinate = total rounding the chain incurs. BACL is checked at every form (residual
must be an integer multiple of ulp(f)). The notch-0 form is the one the early-absorption process
CONSTRUCTS; dialing up = absorbing later, spending more rounding. Eval-layer, exact (Fraction).
"""
import math
from fractions import Fraction as Fr

# the three contributions of the constraint R^2 - 1 + c, as (name, sign)
# the generative move is the choice of which PAIR to combine first (the absorption order)
PAIRINGS = {
    "(-1,+c) first  [early-absorb constants -> BACL-clean]": "BC",
    "(R^2,-1) first [cancellation first]":                   "AB",
    "(R^2,+c) first [sum first]":                            "AC",
}


def form_value_and_rounding(which, R, c, u):
    """Compute the constraint via the chosen first-pairing; return (float_value, total_rounding_ulp)."""
    A = R * R          # R^2 (its own squaring round-off is shared by all -> not part of the *choice*)
    tot = Fr(0)
    def add(x, y, sub=False):
        nonlocal tot
        fl = x - y if sub else x + y
        ex = (Fr(x) - Fr(y)) if sub else (Fr(x) + Fr(y))
        tot += abs(ex - Fr(fl)) / Fr(u)
        return fl
    if which == "BC":            # (c - 1) first, then + R^2     == R^2 + (c-1)  [c2/F1 class]
        t = add(c, 1.0, sub=True)
        v = add(A, t)
    elif which == "AB":          # (R^2 - 1) first, then + c      [F2/c1 class]
        t = add(A, 1.0, sub=True)
        v = add(t, c)
    else:                         # (R^2 + c) first, then - 1     [c3 class]
        t = add(A, c)
        v = add(t, 1.0, sub=True)
    return v, float(tot)


def bacl_cell(v, u):
    j = Fr(v) / Fr(u)
    return j, (j.denominator == 1)


def main():
    # operand sweep (Schwarzschild), exclude exact-zero cells so the absorption order actually matters
    rs = [2.2 + i * (9.8 - 2.2) / 240 for i in range(241)]
    agg = {k: {"round": 0.0, "n": 0, "bacl_int": 0, "halfcells": 0, "cells": set()} for k in PAIRINGS}
    for r in rs:
        c = 2.0 / r; f = 1.0 - c; R = math.sqrt(f); u = math.ulp(f)
        for label, which in PAIRINGS.items():
            v, rnd = form_value_and_rounding(which, R, c, u)
            j, isint = bacl_cell(v, u)
            a = agg[label]
            a["round"] += rnd; a["n"] += 1
            a["bacl_int"] += isint
            if not isint and abs(float(j) - round(float(j))) > 0.4:
                a["halfcells"] += 1
            a["cells"].add(round(float(j), 3))

    print("=" * 92)
    print("ROUNDING DIAL via BACL + early-rounding-absorption — forms emerge from the absorption choice")
    print("  Schwarzschild sweep r∈[2.2,9.8]; dial = total rounding (ulp); BACL = residual on integer-ulp lattice")
    print("-" * 92)
    rows = []
    for label in PAIRINGS:
        a = agg[label]
        mean_round = a["round"] / a["n"]
        bacl_int_frac = a["bacl_int"] / a["n"]
        off_int = 1.0 - bacl_int_frac
        max_level = max(abs(x) for x in a["cells"])
        # DIAL = BACL global cleanliness: (off-integer-lattice burden, then lattice spread). lower=cleaner.
        cleanliness = (round(off_int, 3), max_level)
        rows.append((cleanliness, mean_round, label, bacl_int_frac, a["halfcells"] / a["n"], sorted(a["cells"])[:7]))
    rows.sort(key=lambda t: t[0])   # by BACL global cleanliness -> the dial order (Will's directive)
    print("  DIAL = BACL global cleanliness (off-lattice burden, then spread); rounding shown as secondary")
    print("-" * 92)
    for i, (clean, mr, label, bf, hf, cells) in enumerate(rows):
        tag = "  <== DIAL ORIGIN (early-absorb, BACL-clean)" if i == 0 else ""
        print(f"  notch {i}:  off-lattice={clean[0]*100:4.1f}%  spread|j|≤{clean[1]:g}   {label}{tag}")
        print(f"            BACL integer-lattice {bf*100:5.1f}%   half-cells {hf*100:4.1f}%   "
              f"mean-rounding {mr:.4f}ulp   levels∈{cells}")
    print("-" * 92)
    print("  Dial origin = the EARLY-ABSORB / BACL-clean form, CONSTRUCTED by the cleanliness process.")
    print("  KEY: the minimal-*rounding* form (cancellation-first) is NOT the dial origin — it is")
    print("  globally LESS BACL-clean (off-lattice). Global cleanliness, not local rounding, is the dial.")
    print("  (This is Task-031 in the dial's own coordinates: operation-exactness != global lattice optimality.)")


if __name__ == "__main__":
    main()
