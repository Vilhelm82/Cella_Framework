# probe self-contained. Experiment constant, not a substrate math constant.
K_DRIFT = 2.0

mp.mp.dps = 80  # 80 decimal digits of exact working precision for the reference.

HERE = os.path.dirname(os.path.abspath(__file__))
ARTIFACT_PATH = os.path.join(HERE, "phase2C_typed_result.json")


# --------------------------------------------------------------------------- #
# Raw IEEE 754 binary64 introspection (measurement apparatus).
# --------------------------------------------------------------------------- #
def f64_hex(x: float) -> str:
    """Raw 16-hex-digit big-endian representation of a binary64."""
    return struct.pack(">d", float(x)).hex()


def f64_from_hex(h: str) -> float:
    return struct.unpack(">d", bytes.fromhex(h))[0]


# --------------------------------------------------------------------------- #
# Synthetic stress observables (Fixtures C / D / E). V4-native; NOT the
# four-form fixtures. Each generator returns an EXACT mpf value at scale f.
# --------------------------------------------------------------------------- #
@dataclass(frozen=True)
class FixtureSpec:
    name: str
    kind: str  # "algebraic" | "logarithmic" | "iterated_log"
    description: str
    s_inf: float
    coeff: float       # leading amplitude
    rho: float         # leading algebraic exponent
    sub_coeff: float   # sub-leading power correction amplitude (algebraic only)
    sub_rho: float     # sub-leading power correction exponent (algebraic only)


def fixture_value_exact(spec: FixtureSpec, f: "mp.mpf") -> "mp.mpf":
    s0 = mp.mpf(spec.s_inf)
    c = mp.mpf(spec.coeff)
    if spec.kind == "algebraic":
        # Fixture C: s(f) = s_inf + B*f^rho + B2*f^rho2
        rho = mp.mpf(spec.rho)
        sc = mp.mpf(spec.sub_coeff)
        srho = mp.mpf(spec.sub_rho)
        return s0 + c * mp.power(f, rho) + sc * mp.power(f, srho)
    if spec.kind == "logarithmic":
        # Fixture D: s(f) = s_inf + C*log(f)
        return s0 + c * mp.log(f)
    if spec.kind == "iterated_log":
        # Fixture E: s(f) = s_inf + D*log(f)*log(log(1/f))
        Linv = mp.log(1 / f)  # log(1/f) > 0 for f < 1
        return s0 + c * mp.log(f) * mp.log(Linv)
    raise ValueError("unknown fixture kind: %r" % (spec.kind,))


FIXTURES: Dict[str, FixtureSpec] = {
