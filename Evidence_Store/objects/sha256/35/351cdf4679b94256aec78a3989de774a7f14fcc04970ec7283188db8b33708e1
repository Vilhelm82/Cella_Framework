#!/usr/bin/env bash
# V4 environment self-check — run this in YOUR terminal on this box.
# Verifies the box matches what the repo expects (Python >=3.11, zero runtime deps, pytest for tests).
set -uo pipefail
cd "$(dirname "$0")/.." || exit 1

line() { printf '\n=== %s ===\n' "$1"; }

line "WHERE / GIT"
pwd
git rev-parse --abbrev-ref HEAD 2>/dev/null && git log --oneline -5 2>/dev/null
git status -sb 2>/dev/null | head -20

line "PYTHON"
which python python3
python3 --version
# repo requires >=3.11; bytecode cache on disk was built with cpython-314
python3 - <<'PY'
import sys
ok = sys.version_info[:2] >= (3, 11)
print(f"interpreter: {sys.version.split()[0]}  -> {'OK (>=3.11)' if ok else 'TOO OLD (<3.11)'}")
PY

line "VENV / ISOLATION"
echo "VIRTUAL_ENV=${VIRTUAL_ENV:-<none active>}"
[ -d .venv ] && echo ".venv/ present" || echo "no .venv/ in repo root"

line "PACKAGE IMPORT (editable-install check)"
PYTHONPATH=src python3 -c "import lloyd_v4; print('lloyd_v4 imports OK from', lloyd_v4.__file__)" \
  || echo "IMPORT FAILED — check PYTHONPATH=src or 'pip install -e .'"

line "PYTEST AVAILABLE?"
python3 -c "import pytest; print('pytest', pytest.__version__)" \
  || echo "pytest NOT installed in this interpreter -> pip install pytest"

line "STALE BYTECODE CHECK"
PYTAG=$(python3 -c "import sys;print('cpython-%d%d'%sys.version_info[:2])")
echo "current interpreter tag: $PYTAG"
echo "on-disk .pyc tags:"
find . -name '*.pyc' -path '*__pycache__*' 2>/dev/null \
  | sed -E 's/.*\.(cpython-[0-9]+)\..*/\1/' | sort -u
echo "(if these differ from $PYTAG, the .pyc cache is from another interpreter — harmless, but run: find . -name __pycache__ -type d -exec rm -rf {} + )"

line "FAST TEST RUN (skips slow)"
PYTHONPATH=src python3 -m pytest -q 2>&1 | tail -25

line "DONE"
