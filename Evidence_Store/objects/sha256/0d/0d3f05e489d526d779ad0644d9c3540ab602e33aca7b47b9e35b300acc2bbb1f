# Slot 10: branch fingerprint distribution (sign-pattern histogram on c1) ---

def slot_10_branch_fingerprint_distribution(fixture: str, variant: str) -> Slot:
    name = "slot_10_branch_fingerprint_distribution"
    entry = _test_a_entry(fixture)
    if entry is None:
        return _na_slot(name)
    levels = entry.get("c1_classification", {}).get("unique_levels", [])
    nonzero_count = int(entry.get("c1_classification", {}).get("nonzero_count", 0))
    sterbenz_grid_size = int(entry.get("sterbenz_region_grid_size", 0))
    if sterbenz_grid_size == 0:
        return _unobs_slot(name)
    n_pos = sum(1 for lv in levels if lv > 0)
    n_neg = sum(1 for lv in levels if lv < 0)
    n_zero = sum(1 for lv in levels if lv == 0)
    n_distinct = n_pos + n_neg + n_zero
    if n_distinct == 0:
        return _unobs_slot(name)
    counts = [c for c in (n_pos, n_neg, n_zero) if c > 0]
    # We use distinct-level *count distribution*, not occupancy — but with
    # available data this is the cleanest derived stat. Modal fraction is
    # max count / sum of counts; entropy is normalized.
    total = sum(counts)
    modal_fraction = max(counts) / total if total else 0.0
    if len(counts) <= 1:
        entropy = 0.0
    else:
        ps = [c / total for c in counts]
        entropy = -sum(p * math.log(p) for p in ps) / math.log(len(counts))
    if variant == "B":
        # Sign-pattern histogram is set-derived; route order is irrelevant.
        pass
    return _defined_slot(
        name,
        {
            "n_branch_types": len(counts),
            "modal_fraction": round(modal_fraction, 6),
            "normalized_entropy": round(entropy, 6),
        },
        bits=32,
    )


