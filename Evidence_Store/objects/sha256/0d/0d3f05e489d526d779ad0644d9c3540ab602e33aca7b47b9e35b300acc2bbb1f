SLOT_STATUS_VALUES = frozenset(
    {"defined", "not_applicable", "unobservable", "computation_failed"}
)


@dataclass(frozen=True)
class Slot:
    """A fingerprint slot with value and typed status."""

    name: str
    value: Any  # typed downstream
    status: str  # in SLOT_STATUS_VALUES
    bits: int = 0  # estimated serialized bit length

    def __post_init__(self):
        if self.status not in SLOT_STATUS_VALUES:
            raise ValueError(f"invalid slot status {self.status!r}")


def _na_slot(name: str) -> Slot:
    return Slot(name=name, value=None, status="not_applicable", bits=4)


def _unobs_slot(name: str) -> Slot:
    return Slot(name=name, value=None, status="unobservable", bits=4)


def _failed_slot(name: str, reason: str = "") -> Slot:
    return Slot(name=name, value={"reason": reason}, status="computation_failed", bits=8)


def _defined_slot(name: str, value: Any, bits: int) -> Slot:
    return Slot(name=name, value=value, status="defined", bits=bits)


