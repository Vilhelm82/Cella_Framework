# Main
# ---------------------------------------------------------------------------


def run_atlas() -> dict:
    fingerprints_A: list[dict] = []
    fingerprints_B: list[dict] = []
    for fixture in PHASE_ALPHA_FIXTURES:
        fingerprints_A.append(compute_fingerprint(fixture, variant="A"))
        fingerprints_B.append(compute_fingerprint(fixture, variant="B"))

    dist_A, names = distinguishability_matrix(fingerprints_A)
    route_inv: dict[str, float] = {}
    route_inv_details: dict[str, dict] = {}
    for fp_A, fp_B in zip(fingerprints_A, fingerprints_B):
        result = route_invariance(fp_A, fp_B)
        route_inv[fp_A["fixture"]] = result["invariance_ratio"]
        route_inv_details[fp_A["fixture"]] = result

    min_subset, indist_pairs = minimum_distinguishing_subset(fingerprints_A)

    failures = identify_failure_modes(fingerprints_A, dist_A, route_inv)
    predictions = evaluate_predictions(
        fingerprints_A, dist_A, route_inv, min_subset
    )
    verdict = derive_verdict(predictions, failures)

    return {
        "atlas_version": "phase_alpha_v1",
        "fixtures": list(PHASE_ALPHA_FIXTURES),
        "variants_per_fixture": ["A", "B"],
        "fingerprints_variant_A": fingerprints_A,
        "fingerprints_variant_B": fingerprints_B,
        "distinguishability_matrix": dist_A,
        "distinguishability_matrix_row_labels": names,
        "indistinguishable_pair_count": indist_pairs,
        "route_invariance_per_fixture": route_inv,
        "route_invariance_details": route_inv_details,
        "minimum_distinguishing_subset": min_subset,
        "predictions": predictions,
        "failure_modes_observed": failures,
        "verdict": verdict,
    }


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--output", default=str(ARTIFACT))
    args = parser.parse_args()

    REPORT_DIR.mkdir(parents=True, exist_ok=True)
    data = run_atlas()
    out_path = Path(args.output)
    out_path.write_text(json.dumps(data, indent=2, sort_keys=True))

    print(f"atlas artifact written to {out_path}")
    print(f"  verdict: {data['verdict']}")
    print(f"  failure_modes_observed: {data['failure_modes_observed']}")
    print(f"  predictions:")
    for k, v in data["predictions"].items():
        marker = "✓" if v else "✗"
        print(f"    {marker} {k}")
    print(f"  minimum_distinguishing_subset: {data['minimum_distinguishing_subset']}")
    print(f"  indistinguishable_pair_count: {data['indistinguishable_pair_count']}")
    print(f"  route_invariance_per_fixture:")
    for k, v in data["route_invariance_per_fixture"].items():
        print(f"    {k}: {v:.3f}")
    print(f"  distinguishability_matrix:")
    labels = data["distinguishability_matrix_row_labels"]
    header = "    " + " ".join(f"{n[:6]:>7}" for n in labels)
    print(header)
    for i, row in enumerate(data["distinguishability_matrix"]):
        print(f"    {labels[i][:6]:>6} " + " ".join(f"{c:>7}" for c in row))


if __name__ == "__main__":
    main()
