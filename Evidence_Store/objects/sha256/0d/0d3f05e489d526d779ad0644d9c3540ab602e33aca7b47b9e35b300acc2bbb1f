def _load_json(path: Path) -> dict | None:
    if not path.exists():
        return None
    with path.open() as f:
        return json.load(f)


def _test_a_entry(fixture: str) -> dict | None:
    """Find the per-fixture entry in the Test A artifact by Test A's internal name."""
    name = TEST_A_FIXTURE_NAMES.get(fixture)
    if name is None:
        return None
    data = _load_json(TEST_A_ARTIFACT)
    if data is None:
        return None
    for entry in data.get("per_fixture_results", []):
        if entry.get("fixture_name") == name:
            return entry
    return None


def _lifted_entry(fixture: str) -> dict | None:
    """Find the per-fixture entry in the lifted-singularity audit, float64 precision."""
    name = LIFTED_AUDIT_NAMES.get(fixture)
    if name is None:
        return None
    data = _load_json(LIFTED_ARTIFACT)
    if data is None:
        return None
    fixtures = data.get("results_per_fixture", {})
    entry = fixtures.get(name)
    if entry is None:
        return None
    return entry.get("float64")


