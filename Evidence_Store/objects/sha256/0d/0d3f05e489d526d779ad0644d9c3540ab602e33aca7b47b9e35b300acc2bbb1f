def compute_fingerprint(fixture: str, variant: str = "A") -> dict:
    slots: list[Slot] = []
    for fn in SLOT_FUNCTIONS:
        try:
            slot = fn(fixture, variant)
        except Exception as exc:  # noqa: BLE001
            slot = _failed_slot(fn.__name__, str(exc))
        slots.append(slot)
    total_bits = sum(s.bits for s in slots)
    defined_count = sum(1 for s in slots if s.status == "defined")
    return {
        "fixture": fixture,
        "variant": variant,
        "fingerprint": {s.name: {"value": s.value, "status": s.status} for s in slots},
        "compactness": {
            "total_bits": int(total_bits),
            "budget_bits": 256,
            "in_budget": bool(total_bits <= 256),
        },
        "validity": {
            "defined": defined_count > 0,
            "finite": all(
                _slot_finite(s) for s in slots if s.status == "defined"
            ),
            "observable": any(s.status == "defined" for s in slots),
            "selectable": True,
            "advanceable": True,  # filled by aggregator after route-invariance check
        },
    }


def _slot_finite(slot: Slot) -> bool:
    """Best-effort finite check on slot values."""
    val = slot.value
    if val is None:
        return True
    if isinstance(val, (int, float)):
        try:
            return math.isfinite(float(val))
        except (TypeError, ValueError):
            return False
    if isinstance(val, dict):
        for v in val.values():
            if isinstance(v, (int, float)):
                try:
                    if not math.isfinite(float(v)):
                        return False
                except (TypeError, ValueError):
                    return False
    return True


def distinguishability_matrix(
    fingerprints: list[dict],
) -> tuple[list[list[int]], list[str]]:
    n = len(fingerprints)
    names = [fp["fixture"] for fp in fingerprints]
    matrix = [[0] * n for _ in range(n)]
    for i in range(n):
        for j in range(n):
            if i == j:
                continue
            disagreements = 0
            fp_i = fingerprints[i]["fingerprint"]
            fp_j = fingerprints[j]["fingerprint"]
            for slot_name, s_i in fp_i.items():
                s_j = fp_j[slot_name]
                # Only count if both defined; not_applicable on either side
                # doesn't count as a disagreement.
                if s_i["status"] != "defined" or s_j["status"] != "defined":
                    continue
                if _values_equal(s_i["value"], s_j["value"]):
                    continue
                disagreements += 1
            matrix[i][j] = disagreements
    return matrix, names


def _values_equal(a: Any, b: Any, tol: float = 1e-9) -> bool:
    if type(a) is not type(b):
        # int vs float — coerce numerically
        if isinstance(a, (int, float)) and isinstance(b, (int, float)):
            return abs(float(a) - float(b)) < tol
        return False
    if isinstance(a, (int,)) and isinstance(b, (int,)):
        return a == b
    if isinstance(a, float) and isinstance(b, float):
        return abs(a - b) < tol
    if isinstance(a, str):
        return a == b
    if isinstance(a, dict):
        if set(a.keys()) != set(b.keys()):
            return False
        return all(_values_equal(a[k], b[k], tol) for k in a)
    if isinstance(a, (list, tuple)):
        if len(a) != len(b):
            return False
        return all(_values_equal(x, y, tol) for x, y in zip(a, b))
    return a == b


def route_invariance(
    variant_a: dict, variant_b: dict, tol: float = 1e-12
) -> dict:
    """Compare two variants for slot-by-slot agreement."""
    slot_results: dict[str, dict] = {}
    fp_a = variant_a["fingerprint"]
    fp_b = variant_b["fingerprint"]
    for slot_name in fp_a:
        s_a = fp_a[slot_name]
        s_b = fp_b[slot_name]
        # If both are not_applicable, count as agreement (trivially
        # invariant) but don't count toward the applicable denominator.
        if s_a["status"] != "defined" and s_b["status"] != "defined":
            slot_results[slot_name] = {
                "applicable": False,
                "agreement": True,
                "status_a": s_a["status"],
                "status_b": s_b["status"],
            }
            continue
        applicable = s_a["status"] == "defined" and s_b["status"] == "defined"
        if not applicable:
            slot_results[slot_name] = {
                "applicable": False,
                "agreement": False,
                "status_a": s_a["status"],
                "status_b": s_b["status"],
            }
            continue
        agreement = _values_equal(s_a["value"], s_b["value"], tol=tol)
        slot_results[slot_name] = {
            "applicable": True,
            "agreement": agreement,
            "status_a": s_a["status"],
            "status_b": s_b["status"],
        }
    applicable_slots = [v for v in slot_results.values() if v["applicable"]]
    agreed = [v for v in applicable_slots if v["agreement"]]
    return {
        "per_slot": slot_results,
        "applicable_slot_count": len(applicable_slots),
        "agreement_count": len(agreed),
        "invariance_ratio": (
            len(agreed) / len(applicable_slots) if applicable_slots else 1.0
        ),
    }


def minimum_distinguishing_subset(
    fingerprints: list[dict],
) -> tuple[list[str], int]:
    """Greedy: find the smallest subset of slots such that every pair of
    fixtures disagrees on at least one slot in the subset."""
    n = len(fingerprints)
    if n < 2:
        return [], 0
    slot_names = list(fingerprints[0]["fingerprint"].keys())
    # Pair-to-disagreeing-slots map
    pair_disagreements: dict[tuple[int, int], set[str]] = {}
    for i in range(n):
        for j in range(i + 1, n):
            fp_i = fingerprints[i]["fingerprint"]
            fp_j = fingerprints[j]["fingerprint"]
            slots = set()
            for sn in slot_names:
                s_i = fp_i[sn]
                s_j = fp_j[sn]
                if s_i["status"] != "defined" or s_j["status"] != "defined":
                    continue
                if not _values_equal(s_i["value"], s_j["value"]):
                    slots.add(sn)
            pair_disagreements[(i, j)] = slots
    # Greedy set cover
    uncovered_pairs = set(k for k, v in pair_disagreements.items() if v)
    chosen_slots: list[str] = []
    while uncovered_pairs:
        # Pick the slot that covers the most uncovered pairs
        scores: dict[str, int] = {}
        for sn in slot_names:
            if sn in chosen_slots:
                continue
            covered = sum(
                1
                for pair in uncovered_pairs
                if sn in pair_disagreements[pair]
            )
            scores[sn] = covered
        if not scores or max(scores.values()) == 0:
            break  # cannot cover remaining pairs
        best = max(scores, key=lambda s: scores[s])
        chosen_slots.append(best)
        uncovered_pairs = {
            pair for pair in uncovered_pairs
            if best not in pair_disagreements[pair]
        }
    # Also flag pairs that cannot be distinguished by any slot
    indistinguishable_pairs = [
        k for k, v in pair_disagreements.items() if not v
    ]
    return chosen_slots, len(indistinguishable_pairs)


def evaluate_predictions(
    fingerprints_A: list[dict],
    distinguishability_A: list[list[int]],
    route_invariance_per_fixture: dict[str, float],
    min_dist_subset: list[str],
) -> dict[str, bool]:
    names = [fp["fixture"] for fp in fingerprints_A]
    n = len(names)
    # P1: ≥ 14 of 15 pairs distinguishable
    pair_count = 0
    distinguishable_pair_count = 0
    for i in range(n):
        for j in range(i + 1, n):
            pair_count += 1
            if distinguishability_A[i][j] >= 1:
                distinguishable_pair_count += 1
    p1 = distinguishable_pair_count >= 14

    # P2: c2_lattice_range distinguishes cube-root from sqrt fixtures
    cr_idx = names.index("cube_root") if "cube_root" in names else None
    sqrt_idxs = [
        names.index(name)
        for name in ("SR", "Schwarzschild", "pure_algebraic")
        if name in names
    ]
    p2 = False
    if cr_idx is not None and sqrt_idxs:
        cr_fp = fingerprints_A[cr_idx]["fingerprint"]
        cr_slot = cr_fp["slot_04_c2_lattice_range"]
        if cr_slot["status"] == "defined":
            p2 = all(
                fingerprints_A[i]["fingerprint"]["slot_04_c2_lattice_range"][
                    "status"
                ] == "defined"
                and not _values_equal(
                    cr_slot["value"],
                    fingerprints_A[i]["fingerprint"][
                        "slot_04_c2_lattice_range"
                    ]["value"],
                )
                for i in sqrt_idxs
            )

    # P3: observability_ratio distinguishes Schwarzschild from SR
    p3 = False
    if "SR" in names and "Schwarzschild" in names:
        sr_fp = fingerprints_A[names.index("SR")]["fingerprint"]
        sw_fp = fingerprints_A[names.index("Schwarzschild")]["fingerprint"]
        slot = "slot_06_observability_ratio"
        if (
            sr_fp[slot]["status"] == "defined"
            and sw_fp[slot]["status"] == "defined"
        ):
            p3 = not _values_equal(
                sr_fp[slot]["value"], sw_fp[slot]["value"]
            )

    # P4: lifted-singularity slots not_applicable on pure-algebraic, cube-root, SR
    p4 = True
    for fixture_name in ("pure_algebraic", "cube_root", "SR"):
        if fixture_name not in names:
            continue
        idx = names.index(fixture_name)
        fp = fingerprints_A[idx]["fingerprint"]
        if fp["slot_08_null_tangent_alignment"]["status"] != "not_applicable":
            p4 = False
            break
        if fp["slot_09_hessian_rank_signature"]["status"] != "not_applicable":
            p4 = False
            break

    # P5: route invariance ≥ 80% across all 6 fixtures
    p5 = all(ratio >= 0.80 for ratio in route_invariance_per_fixture.values())

    # P6: minimum distinguishing subset includes a "cheap" slot
    cheap_slots = {
        "slot_06_observability_ratio",
        "slot_07_sterbenz_applicable_mass_fraction",
    }
    p6 = any(s in cheap_slots for s in min_dist_subset)

    # P7: compactness budget met for ≥ 4 of 6
    in_budget_count = sum(
        1 for fp in fingerprints_A if fp["compactness"]["in_budget"]
    )
    p7 = in_budget_count >= 4

    return {
        "P1_pairwise_distinguishability_geq_14_of_15": p1,
        "P2_c2_lattice_range_distinguishes_cube_root": p2,
        "P3_observability_distinguishes_schw_sr": p3,
        "P4_lifted_singularity_slots_NA_on_nonlifted_fixtures": p4,
        "P5_route_invariance_geq_80pct_all_fixtures": p5,
        "P6_min_distinguishing_subset_includes_cheap_slot": p6,
        "P7_compactness_budget_met_geq_4_of_6_fixtures": p7,
    }


def derive_verdict(predictions: dict[str, bool], failure_modes: list[str]) -> str:
    if failure_modes:
        if "F1" in failure_modes or "F2" in failure_modes:
            return "barcode_hypothesis_not_supported_at_phase_alpha"
        if "F3" in failure_modes or "F4" in failure_modes:
            return "barcode_hypothesis_supported_with_slot_redesign_needed"
        if "F5" in failure_modes:
            return "barcode_hypothesis_supported_but_not_yet_compact"
    if all(predictions.values()):
        return "barcode_hypothesis_supported_at_phase_alpha"
    return "barcode_hypothesis_supported_with_caveats"


def identify_failure_modes(
    fingerprints_A: list[dict],
    distinguishability_A: list[list[int]],
    route_invariance_per_fixture: dict[str, float],
) -> list[str]:
    """Identify which (if any) pre-registered failure modes triggered."""
    failures: list[str] = []
    n = len(fingerprints_A)
    # F1: all 6 identical (no off-diagonal entry > 0)
    all_identical = all(
        distinguishability_A[i][j] == 0
        for i in range(n)
        for j in range(n)
        if i != j
    )
    if all_identical:
        failures.append("F1")
    # F2: at least one pair has 0 disagreement (excluding self)
    has_alias = any(
        distinguishability_A[i][j] == 0
        for i in range(n)
        for j in range(n)
        if i != j
    )
    if has_alias and not all_identical:
        failures.append("F2")
    # F3: route invariance < 80% on any fixture
    if any(r < 0.80 for r in route_invariance_per_fixture.values()):
        failures.append("F3")
    # F4: ≥ 50% slots unobservable on ≥ 3 fixtures
    fixtures_with_high_unobs = 0
    for fp in fingerprints_A:
        unobs_count = sum(
            1
            for s in fp["fingerprint"].values()
            if s["status"] == "unobservable"
        )
        if unobs_count / len(fp["fingerprint"]) >= 0.50:
            fixtures_with_high_unobs += 1
    if fixtures_with_high_unobs >= 3:
        failures.append("F4")
    # F5: compactness exceeded for all 6
    if all(not fp["compactness"]["in_budget"] for fp in fingerprints_A):
        failures.append("F5")
    return failures


