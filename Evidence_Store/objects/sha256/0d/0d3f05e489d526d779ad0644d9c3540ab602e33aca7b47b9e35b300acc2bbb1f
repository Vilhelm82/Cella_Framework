def slot_11_dual_arm_split(fixture: str, variant: str) -> Slot:
    name = "slot_11_dual_arm_split"
    if not DUAL_ARM_CAPABLE.get(fixture, False):
        return _na_slot(name)
    data = _load_json(HARDENED_ARTIFACT)
    if data is None:
        return _unobs_slot(name)
    headline = data.get("headline", {})
    total = headline.get("total_records", 0)
    resolved = headline.get("resolved_count", 0)
    zero_sep = headline.get("underpromotion_breakdown", {}).get("armN_zero_path_separation", 0)
    if total == 0:
        return _unobs_slot(name)
    inactive = total - resolved - zero_sep
    return _defined_slot(
        name,
        {
            "resolved_frac": round(resolved / total, 6),
            "zero_sep_frac": round(zero_sep / total, 6),
            "inactive_frac": round(inactive / total, 6),
            "total": int(total),
        },
        bits=48,
    )


# Slot 12: channel-handover β location ---------------------------------------

def slot_12_channel_handover_beta(fixture: str, variant: str) -> Slot:
    name = "slot_12_channel_handover_beta"
    if fixture != "SR":  # only SR has the four-channel handover diagnostic
        return _na_slot(name)
    data = _load_json(V11_F2_F4_ARTIFACT)
    if data is None:
        return _unobs_slot(name)
    # The channel-handover β is the boundary of the F2-active region from
    # v11. We approximate via the activation interval lower edge if
    # available.
    primary = data.get("primary_scan", {})
    intervals = primary.get("active_N_intervals", [])
    if not intervals:
        return _unobs_slot(name)
    # Get the lowest β where ARM-N first activates in the primary scan
    records = primary.get("records", [])
    active_betas = [
        float(r["beta"])
        for r in records
        if r.get("armN", {}).get("active")
    ]
    if not active_betas:
        return _unobs_slot(name)
    handover = round(min(active_betas), 6)
    return _defined_slot(name, handover, bits=32)


