# Slot 7: Sterbenz-applicable β-mass fraction --------------------------------

def _sterbenz_mass(fixture: str) -> float | None:
    """Compute, for this fixture, the fraction of the β grid that satisfies
    the fixture's Sterbenz predicate."""
    if fixture == "SR":
        grid = list(sr_beta_grid())
        in_region = sum(1 for b in grid if b <= 1.0 / math.sqrt(2.0))
        return in_region / len(grid) if grid else 0.0
    if fixture == "Schwarzschild":
        grid = list(sweep_r_values())
        in_region = sum(1 for r in grid if r >= 4.0)
        return in_region / len(grid) if grid else 0.0
    if fixture == "pure_algebraic":
        grid = list(pa_x_grid())
        in_region = sum(1 for x in grid if float(x) <= 0.5)
        return in_region / len(grid) if grid else 0.0
    if fixture == "cube_root":
        # Cube-root shares grid with pure_algebraic; Sterbenz threshold is
        # different in principle (1 - x >= 1/2 → x <= 0.5 too, for n=3).
        grid = list(pa_x_grid())
        in_region = sum(1 for x in grid if float(x) <= 0.5)
        return in_region / len(grid) if grid else 0.0
    return None


def slot_07_sterbenz_applicable_mass_fraction(fixture: str, variant: str) -> Slot:
    name = "slot_07_sterbenz_applicable_mass_fraction"
    val = _sterbenz_mass(fixture)
    if val is None:
        return _na_slot(name)
    if variant == "B":
        # Permute grid order — Sterbenz mass is set-membership, so this
        # should be invariant. We don't bother actually permuting (no
        # randomness), but the structural argument holds.
        pass
    return _defined_slot(name, round(val, 6), bits=32)


