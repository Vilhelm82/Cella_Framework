+# any bench module drifts from the known-good instrument.
+_XCHECK = {
+    "src/lloyd_v4/evals/three_channel_kg/probe.py": "1f999658",
+    "src/lloyd_v4/evals/three_channel_kg/schema.py": "40335dc1",
+    "src/lloyd_v4/evals/three_channel_kg/fixtures.py": "3d415011",
