+checkout BENCH below (NOT from the bench-less worktree). Its module shas are
+cross-checked against the launch instruction's pins and recorded in depends_on.
+"""
+
+from __future__ import annotations
+
+import hashlib
+import json
+import os
+
+STAGE = os.path.dirname(os.path.abspath(__file__))
+RESULTS = os.path.dirname(STAGE)
+# The frozen+committed bench lives on `main` (the worktree is bench-less). Read
+# it READ-ONLY by exact file path from the stable main checkout.
+MAIN_REPO = "/home/wlloyd/Lloyd_Engine_V4"
+BENCH = os.path.join(MAIN_REPO, "src/lloyd_v4/evals/three_channel_kg")
+
+
+def sha256_file(path: str) -> str:
+    with open(path, "rb") as fh:
+        return hashlib.sha256(fh.read()).hexdigest()
+
+
+def read_text(path: str) -> str:
+    with open(path, "r", encoding="utf-8") as fh:
+        return fh.read()
+
+
