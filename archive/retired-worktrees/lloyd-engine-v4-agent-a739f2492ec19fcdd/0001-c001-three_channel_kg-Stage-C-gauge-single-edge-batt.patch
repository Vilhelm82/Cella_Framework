+            moved = any(x != 0 for x in dC)
+            per_t[fr(t)] = {"Sigma_deltaC": fr(sigma_dC), "in_ker_Sigma": in_ker,
+                            "deltaC": [fr(x) for x in dC], "A_eq_Bprime": ab,
+                            "deltaC_nonzero": moved}
+            pc4_ok = pc4_ok and in_ker and ab
+        pc4_detail[f"e{i+1}"] = per_t
